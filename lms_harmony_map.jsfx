desc:LMS Harmony Map
//tags: MIDI chord sequencer harmony theory composition
//author: LMS
//version: 0.1.0
filename:0,shakebot_logo.png

import lms_core.jsfx-inc
options:gmem=DrumBanger

slider1:0<0,11,1{C,C#,D,D#,E,F,F#,G,G#,A,A#,B}>-Key Root
slider2:0<0,1,1{Major,Minor}>-Key Mode
slider3:4<1,32,1>-Number of Steps
slider4:0<0,15,1>-MIDI Channel (0=1)
slider5:0<0,5,1{Triad,7th,9th,Power,sus2,sus4}>-Voicing
slider6:0<-2,3,1>-Octave
slider7:1<1,32,1>-Edit Bar

@init
gfx_clear = -1;  // disable auto-clear, we draw the full background manually in @gfx

// ============================================================================
//  MEMORY LAYOUT
// ============================================================================
// 0-63:     CHORD_SLOTS (32 bars x 2: [root, quality])
// 64-127:   NOTES_ON (currently sounding MIDI)
// 128-191:  STEP_NOTES (notes to fire)
// 192-255:  STEP_VELS (velocities)
// 300-320:  DIATONIC (7 chords x 3: [root, quality, degree])
// 400-471:  CONN_MAP (24 connections x 3: [root, quality, type])
// 500-523:  CONN_RING (24 ring assignments: 0=inner,1=mid,2=outer)

CHORD_SLOTS = 1000;
NOTES_ON = 1100;
STEP_NOTES = 1200;
STEP_VELS = 1300;
DIATONIC = 1400;
CONN_MAP = 1500;
CONN_RING = 1600;
CHORD_FILLED = 1700;  // 32 flags: 0=empty, 1=has chord
CHORD_BARS = 1740;    // 32 duration values: how many bars each step plays (1-8, default 1)
CHORD_SUBDIV = 1780;  // 32 subdivision values: retriggers per step (1,2,4,8,16)
CHORD_PATTERN = 1820; // 32 steps x 16 ticks = 512 entries (0=off, 1=on)
                      // address = CHORD_PATTERN + step*16 + tick
CHORD_VEL     = 2400;  // 32 velocity values (0-127, 0 = default 100)
CHORD_MOD_STEP = 2450;  // 32 step-level mod flags (shift+click whole cell)
CHORD_MOD_TICK = 2490;  // 32*16 = 512 tick-level mod flags (shift+click individual ticks)
CHORD_MOD_SUS  = 3010;  // 32 sus4 flags per step
CHORD_MOD_ADD9 = 3050;  // 32 add-9th flags per step
CHORD_MOD_ADD7 = 3090;  // 32 add-7th flags per step
CHORD_MOD_INV  = 3130;  // 32 inversion values per step (1-5, 0=default 1)
CHORD_MOD_DOM7 = 3170;  // 32 dominant 7th flags (always flat 7th, quality-agnostic)
CHORD_MOD_ADD6 = 3210;  // 32 add-6th flags per step (major 6th, +9 semitones)

// ============================================================================
//  MULTI-PATTERN BANK  (8 patterns × 1500 floats = 12000, addr 5000-16999)
// ============================================================================
PAT_BASE = 5000;
PAT_SIZE = 1500;
// Per-pattern offsets
PO_SLOTS   = 0;    // 64  (32 steps × 2)
PO_FILLED  = 64;   // 32
PO_BARS    = 96;   // 32
PO_SUBDIV  = 128;  // 32
PO_NSTEPS  = 160;  // 1
PO_PATTERN = 200;  // 512 (32 × 16 ticks)
PO_VEL     = 712;  // 32
PO_MSTEP   = 744;  // 32
PO_MTICK   = 776;  // 512 (32 × 16)
PO_MSUS    = 1288; // 32
PO_MADD9   = 1320; // 32
PO_MADD7   = 1352; // 32
PO_MINV    = 1384; // 32
PO_MDOM7   = 1416; // 32
PO_MADD6   = 1448; // 32
// Total used: 1480 < 1500 ✓
// current_pat / num_pats NOT initialized here — persist across transport start

// ============================================================================
//  ARRANGEMENT GRID  (64 cols × 8 rows)
// ============================================================================
ARR_BASE    = 17000;  // 64*8 = 512 entries: ARR_BASE[col*8 + row] = pat_idx+1 (0=empty)
ARR_SEQ     = 17600;  // 512 entries: flat sequence of pattern indices (runtime, not saved)
ARR_CUM     = 18200;  // 512 entries: cumulative beat offsets per seq entry (runtime)
ARR_COL     = 18800;  // 512 entries: grid column of each seq entry (runtime)
ARR_ROW     = 19400;  // 512 entries: grid row of each seq entry (runtime)
MAX_ARR_COLS = 64;
// arr_mode / arr_ncols kept for serialize backward compat (unused)
// song_mode / song_num_parts / song_seq_len / song_sel_part — persist across transport start

// ============================================================================
//  SONG MODE  (16 parts × 8 fields, 64-entry sequence)
// ============================================================================
SONG_PARTS    = 30100;  // 16 parts × 8 fields = 128 slots
                        // Per part: [category, number, pat_idx, repeats, mod_key, mod_mode, mod_vel, arp_mode]
                        // category: 0=Verse, 1=Chorus, 2=Bridge, 3=Intro, 4=Outro
                        // mod_key: 0=no change, 1-12 = C..B target key
                        // mod_mode: 0=inherit, 1=force major, 2=force minor
                        // mod_vel: 0=normal, 1=quiet, 2=loud
SONG_SEQ      = 30300;  // 64 entries: index into SONG_PARTS (255=empty)
SONG_SEQ_CUM  = 30400;  // 64 entries: cumulative beat offsets (runtime, not saved)
SONG_SEQ_PAT  = 30500;  // 64 entries: resolved pattern index per seq slot (runtime)
SONG_SEQ_PART = 30600;  // 64 entries: part index per seq slot (runtime, for mod lookup)
SONG_SEQ_SRC  = 30700;  // 64 entries: original SONG_SEQ index per expanded slot (for UI highlight)
SONG_PART_OCT = 30800;  // 16 entries: octave offset per part (-2 to +3, 0=inherit from slider6)
                        // Stored as 0-5 (0=no override, 1=-2, 2=-1, 3=0, 4=+1, 5=+2, 6=+3)
MAX_SONG_PARTS = 16;
MAX_SONG_SEQ   = 64;
SONG_PART_SIZE = 8;
// song_mode / song_num_parts / song_seq_len / song_sel_part — persist across transport
song_cur_seq = -1;  // currently playing sequence index (runtime)

// Conductor/Player roles (persist via serialize)
// hm_role: 0=standalone, 1=conductor, 2=player
// player_seeded: 0=needs seed from conductor, 1=already seeded
// conductor_seed_dirty: 1=need to republish chord data to gmem
COND_BUS       = 960100;  // conductor structure broadcast base
COND_PARTS     = 960110;  // song parts mirror (16×8 = 128)
COND_SEQ       = 960240;  // song sequence mirror (64)
COND_OCT       = 960310;  // song part octave mirror (16)
COND_PAT_STRUCT = 960400; // pattern structure (16×80 = 1280)
COND_SEED      = 962000;  // chord seed area (16 patterns × PAT_SIZE)
conductor_seed_dirty = 1;
conductor_found_id = 0;   // runtime: ID of conductor we're following

// ============================================================================
//  UNDO SYSTEM  (Ctrl+Z / Ctrl+Y)
// ============================================================================
// Per snapshot: full pattern bank + working copy + song state + metadata
// Bank: 16 × 1500 = 24000. Song: 128+64+16+4 = 212. Working: ~1450. Meta: 10.
// Total per level: ~25672 floats. 20 levels = ~513K floats (well within 8M)
UNDO_SNAP_SIZE = 25700;
UNDO_MAX       = 20;
UNDO_BASE      = 400000;   // 400000 to 400000+20*25700 = ~914000
// Offsets within each snapshot
UO_BANK    = 0;       // 24000 (16 × PAT_SIZE)
UO_SONG_P  = 24000;   // 128 (SONG_PARTS)
UO_SONG_S  = 24128;   // 64 (SONG_SEQ)
UO_SONG_O  = 24192;   // 16 (SONG_PART_OCT)
UO_META    = 24208;   // metadata: slider3, current_pat, num_pats, song_num_parts,
                       // song_seq_len, song_sel_part, song_mode
UO_WC_SLOTS  = 24220; // 64  CHORD_SLOTS
UO_WC_FILLED = 24284; // 32
UO_WC_BARS   = 24316; // 32
UO_WC_SUBDIV = 24348; // 32
UO_WC_PAT    = 24380; // 512
UO_WC_VEL    = 24892; // 32
UO_WC_MSTEP  = 24924; // 32
UO_WC_MTICK  = 24956; // 512
UO_WC_MSUS   = 25468; // 32
UO_WC_MADD9  = 25500; // 32
UO_WC_MADD7  = 25532; // 32
UO_WC_MINV   = 25564; // 32
UO_WC_MDOM7  = 25596; // 32
UO_WC_MADD6  = 25628; // 32
// Total used: 25660 < 25700 ✓

undo_head = 0;  // next write position (circular)
undo_count = 0; // how many undos available
undo_redo_count = 0; // how many redos available

// Chord slots initialized via @serialize (do NOT zero here — @init re-runs on play)
// Empty = root value 255 (not -1, since @init zeros memory)

// Song mode runtime (reset on play)
song_mod_key = 0; song_mod_mode = 0; song_mod_vel = 0; song_mod_arp = 0; song_mod_oct = 0;
song_mode_play = 0;  // conductor's song mode state (for player playback)

// State
notes_on_count = 0;
step_notes_count = 0;
cur_bar = 0;
cur_step = 0;
last_step = -1;
last_sub = -1;
transport_playing = 0;
prev_playing = 0;
conn_count = 0;
conn_dirty = 1;
edit_override = 0;

notice_show = 0;

// Preview
preview_chord_dirty = 0;


// Drag-to-copy (timeline)
drag_src = -1;
drag_dst = -1;

// Drag-to-reorder (song sequence)
seq_drag_src = -1;
seq_drag_dst = -1;

// Velocity editor (timeline steps)
vel_edit_open = 0;
vel_edit_step = 0;
vel_edit_x = 0;
vel_edit_y = 0;
vel_edit_dragging = 0;

// Song part velocity drag state
svel_drag_part = -1;
svel_drag_start_y = 0;
svel_drag_start_val = 0;
preview_root = 0;
preview_qual = 0;
preview_ticks = 0;

// Harmony bus gmem base
HARMONY_BUS = 960000;

// Broadcast system
bc.lms_bc_init(29, 10, 930000);  // 10 params: 0-6 sliders, 7=role, 8=num_pats, 9=seed_gen

// ============================================================================
//  MUSIC THEORY FUNCTIONS
// ============================================================================

// ---- Get triad pitch classes (sets globals: t_n0, t_n1, t_n2) ----
function get_triad(root, quality) (
  // Returns 3 pitch classes (0-11) via globals t_n0/1/2
  quality == 0 || quality == 2 || quality == 4 || quality == 9 || quality == 11 || quality == 13 || quality == 14 ? (
    // Major-based: maj, maj7, dom7, dom9, add9, maj9
    t_n0 = root % 12;
    t_n1 = (root + 4) % 12;
    t_n2 = (root + 7) % 12;
  ) : quality == 1 || quality == 3 || quality == 8 || quality == 12 || quality == 15 ? (
    // Minor-based: min, min7, half-dim, min9, dom7#9
    t_n0 = root % 12;
    t_n1 = (root + 3) % 12;
    t_n2 = (root + 7) % 12;
  ) : quality == 5 || quality == 7 ? (
    // Diminished: dim, dim7
    t_n0 = root % 12;
    t_n1 = (root + 3) % 12;
    t_n2 = (root + 6) % 12;
  ) : quality == 6 ? (
    // Augmented
    t_n0 = root % 12;
    t_n1 = (root + 4) % 12;
    t_n2 = (root + 8) % 12;
  ) : quality == 10 ? (
    // sus4
    t_n0 = root % 12;
    t_n1 = (root + 5) % 12;
    t_n2 = (root + 7) % 12;
  ) : (
    // Default/sus2
    t_n0 = root % 12;
    t_n1 = (root + 2) % 12;
    t_n2 = (root + 7) % 12;
  );
);

// ---- Count shared pitch classes between two chords ----
function count_shared(r1, q1, r2, q2) local(count, a0, a1, a2, b0, b1, b2) (
  get_triad(r1, q1); a0 = t_n0; a1 = t_n1; a2 = t_n2;
  get_triad(r2, q2); b0 = t_n0; b1 = t_n1; b2 = t_n2;
  count = 0;
  (a0 == b0 || a0 == b1 || a0 == b2) ? count += 1;
  (a1 == b0 || a1 == b1 || a1 == b2) ? count += 1;
  (a2 == b0 || a2 == b1 || a2 == b2) ? count += 1;
  count;
);

// ---- Build diatonic chords for key (populates DIATONIC[]) ----
// Each entry: [root, quality, degree_index]
function build_diatonic(key_root, mode) local(i) (
  mode == 0 ? (
    // Major: I ii iii IV V vi vii°
    DIATONIC[0] = key_root;       DIATONIC[1] = 0; DIATONIC[2] = 0;  // I maj
    DIATONIC[3] = (key_root+2)%12;DIATONIC[4] = 1; DIATONIC[5] = 1;  // ii min
    DIATONIC[6] = (key_root+4)%12;DIATONIC[7] = 1; DIATONIC[8] = 2;  // iii min
    DIATONIC[9] = (key_root+5)%12;DIATONIC[10]= 0; DIATONIC[11]= 3;  // IV maj
    DIATONIC[12]= (key_root+7)%12;DIATONIC[13]= 0; DIATONIC[14]= 4;  // V maj
    DIATONIC[15]= (key_root+9)%12;DIATONIC[16]= 1; DIATONIC[17]= 5;  // vi min
    DIATONIC[18]= (key_root+11)%12;DIATONIC[19]=5; DIATONIC[20]= 6;  // vii dim
  ) : (
    // Minor: i ii° III iv v VI VII
    DIATONIC[0] = key_root;       DIATONIC[1] = 1; DIATONIC[2] = 0;  // i min
    DIATONIC[3] = (key_root+2)%12;DIATONIC[4] = 5; DIATONIC[5] = 1;  // ii° dim
    DIATONIC[6] = (key_root+3)%12;DIATONIC[7] = 0; DIATONIC[8] = 2;  // III maj
    DIATONIC[9] = (key_root+5)%12;DIATONIC[10]= 1; DIATONIC[11]= 3;  // iv min
    DIATONIC[12]= (key_root+7)%12;DIATONIC[13]= 1; DIATONIC[14]= 4;  // v min
    DIATONIC[15]= (key_root+8)%12;DIATONIC[16]= 0; DIATONIC[17]= 5;  // VI maj
    DIATONIC[18]= (key_root+10)%12;DIATONIC[19]=0; DIATONIC[20]= 6;  // VII maj
  );
);

// ---- Add a connection to CONN_MAP ----
function add_conn(root, quality, conn_type, ring) (
  // Deduplicate: check if this root+quality already in the map
  _dup = 0;
  _ci = 0;
  loop(conn_count,
    CONN_MAP[_ci*3] == root && CONN_MAP[_ci*3+1] == quality ? _dup = 1;
    _ci += 1;
  );
  !_dup && conn_count < 24 ? (
    CONN_MAP[conn_count*3] = root;
    CONN_MAP[conn_count*3+1] = quality;
    CONN_MAP[conn_count*3+2] = conn_type;
    CONN_RING[conn_count] = ring;
    conn_count += 1;
  );
);

// ---- Compute all connections from a chord ----
function compute_connections(cur_root, cur_quality) local(i, dr, dq, shared, dom_root, tri_root) (
  conn_count = 0;

  // 1. Diatonic chords (inner ring)
  i = 0;
  loop(7,
    dr = DIATONIC[i*3];
    dq = DIATONIC[i*3+1];
    // Skip if it's the same chord
    !(dr == cur_root && dq == cur_quality) ? (
      shared = count_shared(cur_root, cur_quality, dr, dq);
      shared >= 2 ? add_conn(dr, dq, 1, 0);  // close proximity
      shared == 1 ? add_conn(dr, dq, 2, 0);  // moderate proximity
      shared == 0 ? add_conn(dr, dq, 2, 0);  // still diatonic, inner ring
    );
    i += 1;
  );

  // 2. Dominant of current chord (V7 → this chord, middle ring)
  dom_root = (cur_root + 7) % 12;
  add_conn(dom_root, 4, 3, 1);  // V7 as dominant

  // 3. Current chord AS dominant (resolves down a fifth)
  add_conn((cur_root + 5) % 12, 0, 3, 1);  // I it resolves to (major)
  add_conn((cur_root + 5) % 12, 1, 3, 1);  // i it resolves to (minor)

  // 4. Tritone substitute (middle ring)
  tri_root = (cur_root + 6) % 12;
  add_conn(tri_root, 4, 4, 1);  // bII7 (tritone sub as dom7)

  // 5. Secondary dominants of diatonic chords (middle ring)
  i = 0;
  loop(7,
    dr = DIATONIC[i*3];
    // The dominant OF each diatonic chord
    add_conn((dr + 7) % 12, 4, 3, 1);
    i += 1;
  );

  // 6. Diminished bridges (outer ring)
  // dim7 symmetry: every 3 semitones is the same chord — 4 dim triads are all bridges
  i = 0;
  loop(4,
    _dim_root = (cur_root + 11 + i * 3) % 12;
    add_conn(_dim_root, 5, 5, 2);
    i += 1;
  );

  // 7. Augmented bridges (outer ring)
  // aug symmetry: every 4 semitones is the same chord — 3 aug triads are all bridges
  i = 0;
  loop(3,
    _aug_root = (cur_root + i * 4) % 12;
    add_conn(_aug_root, 6, 6, 2);
    i += 1;
  );
);

// ---- Build MIDI notes for a chord ----
function build_chord_midi(root, quality, voicing, octave)
  local(base, third, fifth, seventh)
(
  step_notes_count = 0;
  base = 48 + octave * 12 + root;  // C3 + octave offset + root

  // Determine intervals
  quality == 0 || quality == 2 || quality == 4 || quality == 9 || quality == 11 || quality == 13 || quality == 14 ? (
    third = 4; fifth = 7;
  ) : quality == 1 || quality == 3 || quality == 8 || quality == 12 || quality == 15 ? (
    third = 3; fifth = 7;
  ) : quality == 5 || quality == 7 ? (
    third = 3; fifth = 6;
  ) : quality == 6 ? (
    third = 4; fifth = 8;
  ) : quality == 10 ? (
    third = 5; fifth = 7;  // sus4
  ) : (
    third = 2; fifth = 7;  // sus2
  );

  // Seventh interval
  quality == 2 || quality == 14 ? seventh = 11;          // maj7
  quality == 3 || quality == 8 || quality == 12 ? seventh = 10;  // min7
  quality == 4 || quality == 13 || quality == 15 ? seventh = 10; // dom7
  quality == 7 ? seventh = 9;                              // dim7
  seventh == 0 && quality != 7 ? seventh = -1;             // no 7th

  // Voice the chord
  voicing == 0 ? (
    // Triad + bass octave
    STEP_NOTES[0] = base - 12; STEP_VELS[0] = 90;
    STEP_NOTES[1] = base;      STEP_VELS[1] = 100;
    STEP_NOTES[2] = base + third; STEP_VELS[2] = 100;
    STEP_NOTES[3] = base + fifth; STEP_VELS[3] = 100;
    step_notes_count = 4;
  ) : voicing == 1 ? (
    // 7th + bass
    STEP_NOTES[0] = base - 12; STEP_VELS[0] = 90;
    STEP_NOTES[1] = base;      STEP_VELS[1] = 100;
    STEP_NOTES[2] = base + third; STEP_VELS[2] = 100;
    STEP_NOTES[3] = base + fifth; STEP_VELS[3] = 100;
    step_notes_count = 4;
    seventh > 0 ? (
      STEP_NOTES[4] = base + seventh; STEP_VELS[4] = 90;
      step_notes_count = 5;
    );
  ) : voicing == 2 ? (
    // 9th + bass
    STEP_NOTES[0] = base - 12; STEP_VELS[0] = 85;
    STEP_NOTES[1] = base;      STEP_VELS[1] = 100;
    STEP_NOTES[2] = base + third; STEP_VELS[2] = 100;
    STEP_NOTES[3] = base + fifth; STEP_VELS[3] = 100;
    step_notes_count = 4;
    seventh > 0 ? (
      STEP_NOTES[step_notes_count] = base + seventh; STEP_VELS[step_notes_count] = 85;
      step_notes_count += 1;
    );
    STEP_NOTES[step_notes_count] = base + 14; STEP_VELS[step_notes_count] = 80;  // 9th
    step_notes_count += 1;
  ) : voicing == 3 ? (
    // Power: root + 5th + octave
    STEP_NOTES[0] = base - 12; STEP_VELS[0] = 100;
    STEP_NOTES[1] = base;      STEP_VELS[1] = 100;
    STEP_NOTES[2] = base + fifth; STEP_VELS[2] = 100;
    STEP_NOTES[3] = base + 12; STEP_VELS[3] = 90;
    step_notes_count = 4;
  ) : voicing == 4 ? (
    // sus2: root + 2nd + 5th
    STEP_NOTES[0] = base - 12; STEP_VELS[0] = 90;
    STEP_NOTES[1] = base;      STEP_VELS[1] = 100;
    STEP_NOTES[2] = base + 2;  STEP_VELS[2] = 100;
    STEP_NOTES[3] = base + fifth; STEP_VELS[3] = 100;
    step_notes_count = 4;
  ) : (
    // sus4: root + 4th + 5th
    STEP_NOTES[0] = base - 12; STEP_VELS[0] = 90;
    STEP_NOTES[1] = base;      STEP_VELS[1] = 100;
    STEP_NOTES[2] = base + 5;  STEP_VELS[2] = 100;
    STEP_NOTES[3] = base + fifth; STEP_VELS[3] = 100;
    step_notes_count = 4;
  );
);

// ---- MIDI note off/on (same pattern as DroneMIDI2) ----
function all_notes_off() local(i, ch) (
  ch = slider4;
  i = 0;
  loop(notes_on_count,
    midisend(0, 0x80 | ch, NOTES_ON[i], 0);
    i += 1;
  );
  notes_on_count = 0;
);

function fire_all_notes() local(i, ch) (
  ch = slider4;
  i = 0;
  loop(step_notes_count,
    STEP_NOTES[i] >= 0 && STEP_NOTES[i] <= 127 ? (
      midisend(0, 0x90 | ch, STEP_NOTES[i], STEP_VELS[i]);
      NOTES_ON[notes_on_count] = STEP_NOTES[i];
      notes_on_count += 1;
    );
    i += 1;
  );
);

// ---- Apply per-step mods to STEP_NOTES/STEP_VELS ----
// Uses P_* pointers set in @block (bank in song mode, working copy otherwise)
function apply_step_mods(step) local(i, j, tmp, n, _root, _qual, _7int, _7pc, _9pc, _6pc, _has, _inv, _old_pc, _new_pc, _new_note, _base) (
  _root = P_SLOTS[step*2];
  _qual = P_SLOTS[step*2+1];
  _base = 48 + slider6 * 12 + _root;

  // Add 7th (before sus so quality detection is intact)
  P_MADD7[step] && step_notes_count < 8 ? (
    _qual == 7 ? _7int = 9 : (_qual == 1 || _qual == 3 || _qual == 5 || _qual == 8 || _qual == 12 || _qual == 15) ? _7int = 10 : _7int = 11;
    _7pc = (_root + _7int) % 12;
    _has = 0; i = 0; loop(step_notes_count, STEP_NOTES[i] % 12 == _7pc ? _has = 1; i += 1);
    !_has ? (
      STEP_NOTES[step_notes_count] = _base + _7int;
      STEP_VELS[step_notes_count] = 85;
      step_notes_count += 1;
    );
  );

  // Dom 7th (flat 7, always root+10 regardless of quality)
  P_MDOM7[step] && step_notes_count < 8 ? (
    _has = 0; i = 0; loop(step_notes_count, STEP_NOTES[i] % 12 == (_root + 10) % 12 ? _has = 1; i += 1);
    !_has ? (
      STEP_NOTES[step_notes_count] = _base + 10;
      STEP_VELS[step_notes_count] = 85;
      step_notes_count += 1;
    );
  );

  // Add 9th
  P_MADD9[step] && step_notes_count < 8 ? (
    _9pc = (_root + 2) % 12;
    _has = 0; i = 0; loop(step_notes_count, STEP_NOTES[i] % 12 == _9pc ? _has = 1; i += 1);
    !_has ? (
      STEP_NOTES[step_notes_count] = _base + 14;
      STEP_VELS[step_notes_count] = 80;
      step_notes_count += 1;
    );
  );

  // Add 6th (major 6th, +9 semitones)
  P_MADD6[step] && step_notes_count < 8 ? (
    _6pc = (_root + 9) % 12;
    _has = 0; i = 0; loop(step_notes_count, STEP_NOTES[i] % 12 == _6pc ? _has = 1; i += 1);
    !_has ? (
      STEP_NOTES[step_notes_count] = _base + 9;
      STEP_VELS[step_notes_count] = 82;
      step_notes_count += 1;
    );
  );

  // Sus4: replace minor/major 3rd with perfect 4th
  P_MSUS[step] ? (
    i = 0;
    loop(step_notes_count,
      _old_pc = STEP_NOTES[i] % 12;
      (_old_pc == (_root + 3) % 12 || _old_pc == (_root + 4) % 12) ? (
        _new_pc = (_root + 5) % 12;
        _new_note = STEP_NOTES[i] - _old_pc + _new_pc;
        _new_note < STEP_NOTES[i] ? _new_note += 12;
        STEP_NOTES[i] = _new_note;
      );
      i += 1;
    );
  );

  // Inversion: sort ascending, raise (inv-1) lowest notes by one octave
  _inv = P_MINV[step]; _inv <= 0 ? _inv = 1;
  _inv > 1 ? (
    n = step_notes_count;
    i = 0; loop(n - 1,
      j = 0; loop(n - 1 - i,
        STEP_NOTES[j] > STEP_NOTES[j+1] ? (
          tmp = STEP_NOTES[j]; STEP_NOTES[j] = STEP_NOTES[j+1]; STEP_NOTES[j+1] = tmp;
          tmp = STEP_VELS[j]; STEP_VELS[j] = STEP_VELS[j+1]; STEP_VELS[j+1] = tmp;
        );
        j += 1;
      );
      i += 1;
    );
    i = 0; loop(min(_inv - 1, n), STEP_NOTES[i] += 12; i += 1);
  );
);

// ---- Pattern bank helpers ----
function pat_save(p) local(_b, _i) (
  _b = PAT_BASE + p * PAT_SIZE;
  _i = 0; loop(64,  (_b+PO_SLOTS  )[_i] = CHORD_SLOTS[_i];    _i+=1);
  _i = 0; loop(32,  (_b+PO_FILLED )[_i] = CHORD_FILLED[_i];   _i+=1);
  _i = 0; loop(32,  (_b+PO_BARS   )[_i] = CHORD_BARS[_i];     _i+=1);
  _i = 0; loop(32,  (_b+PO_SUBDIV )[_i] = CHORD_SUBDIV[_i];   _i+=1);
  (_b+PO_NSTEPS)[0]                     = slider3;
  _i = 0; loop(512, (_b+PO_PATTERN)[_i] = CHORD_PATTERN[_i];  _i+=1);
  _i = 0; loop(32,  (_b+PO_VEL    )[_i] = CHORD_VEL[_i];      _i+=1);
  _i = 0; loop(32,  (_b+PO_MSTEP  )[_i] = CHORD_MOD_STEP[_i]; _i+=1);
  _i = 0; loop(512, (_b+PO_MTICK  )[_i] = CHORD_MOD_TICK[_i]; _i+=1);
  _i = 0; loop(32,  (_b+PO_MSUS   )[_i] = CHORD_MOD_SUS[_i];  _i+=1);
  _i = 0; loop(32,  (_b+PO_MADD9  )[_i] = CHORD_MOD_ADD9[_i]; _i+=1);
  _i = 0; loop(32,  (_b+PO_MADD7  )[_i] = CHORD_MOD_ADD7[_i]; _i+=1);
  _i = 0; loop(32,  (_b+PO_MINV   )[_i] = CHORD_MOD_INV[_i];  _i+=1);
  _i = 0; loop(32,  (_b+PO_MDOM7  )[_i] = CHORD_MOD_DOM7[_i]; _i+=1);
  _i = 0; loop(32,  (_b+PO_MADD6  )[_i] = CHORD_MOD_ADD6[_i]; _i+=1);
  hm_role == 1 ? conductor_seed_dirty = 1;
);

function pat_load(p) local(_b, _i) (
  _b = PAT_BASE + p * PAT_SIZE;
  _i = 0; loop(64,  CHORD_SLOTS[_i]    = (_b+PO_SLOTS  )[_i]; _i+=1);
  _i = 0; loop(32,  CHORD_FILLED[_i]   = (_b+PO_FILLED )[_i]; _i+=1);
  _i = 0; loop(32,  CHORD_BARS[_i]     = (_b+PO_BARS   )[_i]; _i+=1);
  _i = 0; loop(32,  CHORD_SUBDIV[_i]   = (_b+PO_SUBDIV )[_i]; _i+=1);
  slider3 = max(1, (_b+PO_NSTEPS)[0]);
  _i = 0; loop(512, CHORD_PATTERN[_i]  = (_b+PO_PATTERN)[_i]; _i+=1);
  _i = 0; loop(32,  CHORD_VEL[_i]      = (_b+PO_VEL    )[_i]; _i+=1);
  _i = 0; loop(32,  CHORD_MOD_STEP[_i] = (_b+PO_MSTEP  )[_i]; _i+=1);
  _i = 0; loop(512, CHORD_MOD_TICK[_i] = (_b+PO_MTICK  )[_i]; _i+=1);
  _i = 0; loop(32,  CHORD_MOD_SUS[_i]  = (_b+PO_MSUS   )[_i]; _i+=1);
  _i = 0; loop(32,  CHORD_MOD_ADD9[_i] = (_b+PO_MADD9  )[_i]; _i+=1);
  _i = 0; loop(32,  CHORD_MOD_ADD7[_i] = (_b+PO_MADD7  )[_i]; _i+=1);
  _i = 0; loop(32,  CHORD_MOD_INV[_i]  = (_b+PO_MINV   )[_i]; _i+=1);
  _i = 0; loop(32,  CHORD_MOD_DOM7[_i] = (_b+PO_MDOM7  )[_i]; _i+=1);
  _i = 0; loop(32,  CHORD_MOD_ADD6[_i] = (_b+PO_MADD6  )[_i]; _i+=1);
  sliderchange(slider3);
  conn_dirty = 1;
);

function pat_init(p) local(_b, _i, _j) (
  _b = PAT_BASE + p * PAT_SIZE;
  _i = 0; loop(PAT_SIZE, _b[_i] = 0; _i+=1);
  (_b+PO_NSTEPS)[0] = 4;
  _i = 0; loop(4,
    (_b+PO_BARS  )[_i] = 1;
    (_b+PO_SUBDIV)[_i] = 1;
    _j = 0; loop(16, (_b+PO_PATTERN)[_i*16+_j] = 1; _j+=1);
    _i += 1;
  );
);

// Set gfx_r/g/b to pattern p's color
function pat_set_color(p) (
  p == 0  ? (gfx_r=0.90; gfx_g=0.30; gfx_b=0.30) :  // red
  p == 1  ? (gfx_r=0.90; gfx_g=0.58; gfx_b=0.18) :  // orange
  p == 2  ? (gfx_r=0.78; gfx_g=0.78; gfx_b=0.18) :  // yellow
  p == 3  ? (gfx_r=0.28; gfx_g=0.80; gfx_b=0.42) :  // green
  p == 4  ? (gfx_r=0.18; gfx_g=0.68; gfx_b=0.90) :  // cyan
  p == 5  ? (gfx_r=0.30; gfx_g=0.38; gfx_b=0.90) :  // blue
  p == 6  ? (gfx_r=0.68; gfx_g=0.28; gfx_b=0.90) :  // purple
  p == 7  ? (gfx_r=0.90; gfx_g=0.28; gfx_b=0.68) :  // pink
  p == 8  ? (gfx_r=0.70; gfx_g=0.20; gfx_b=0.20) :  // dark red
  p == 9  ? (gfx_r=0.70; gfx_g=0.45; gfx_b=0.10) :  // dark orange
  p == 10 ? (gfx_r=0.60; gfx_g=0.60; gfx_b=0.10) :  // dark yellow
  p == 11 ? (gfx_r=0.18; gfx_g=0.60; gfx_b=0.30) :  // dark green
  p == 12 ? (gfx_r=0.10; gfx_g=0.50; gfx_b=0.70) :  // dark cyan
  p == 13 ? (gfx_r=0.20; gfx_g=0.25; gfx_b=0.70) :  // dark blue
  p == 14 ? (gfx_r=0.50; gfx_g=0.18; gfx_b=0.70) :  // dark purple
            (gfx_r=0.70; gfx_g=0.18; gfx_b=0.50);   // dark pink
);

// ---- Undo/Redo functions (must be after pat_save) ----
function undo_push() local(_ub, _i) (
  pat_save(current_pat);
  _ub = UNDO_BASE + undo_head * UNDO_SNAP_SIZE;
  _i = 0; loop(16 * PAT_SIZE, _ub[UO_BANK + _i] = PAT_BASE[_i]; _i += 1);
  _i = 0; loop(MAX_SONG_PARTS * SONG_PART_SIZE, _ub[UO_SONG_P + _i] = SONG_PARTS[_i]; _i += 1);
  _i = 0; loop(MAX_SONG_SEQ, _ub[UO_SONG_S + _i] = SONG_SEQ[_i]; _i += 1);
  _i = 0; loop(MAX_SONG_PARTS, _ub[UO_SONG_O + _i] = SONG_PART_OCT[_i]; _i += 1);
  _ub[UO_META+0]=slider3; _ub[UO_META+1]=current_pat; _ub[UO_META+2]=num_pats;
  _ub[UO_META+3]=song_num_parts; _ub[UO_META+4]=song_seq_len;
  _ub[UO_META+5]=song_sel_part; _ub[UO_META+6]=song_mode;
  _i=0; loop(64,  _ub[UO_WC_SLOTS +_i]=CHORD_SLOTS[_i];    _i+=1);
  _i=0; loop(32,  _ub[UO_WC_FILLED+_i]=CHORD_FILLED[_i];   _i+=1);
  _i=0; loop(32,  _ub[UO_WC_BARS  +_i]=CHORD_BARS[_i];     _i+=1);
  _i=0; loop(32,  _ub[UO_WC_SUBDIV+_i]=CHORD_SUBDIV[_i];   _i+=1);
  _i=0; loop(512, _ub[UO_WC_PAT   +_i]=CHORD_PATTERN[_i];  _i+=1);
  _i=0; loop(32,  _ub[UO_WC_VEL   +_i]=CHORD_VEL[_i];      _i+=1);
  _i=0; loop(32,  _ub[UO_WC_MSTEP +_i]=CHORD_MOD_STEP[_i]; _i+=1);
  _i=0; loop(512, _ub[UO_WC_MTICK +_i]=CHORD_MOD_TICK[_i]; _i+=1);
  _i=0; loop(32,  _ub[UO_WC_MSUS  +_i]=CHORD_MOD_SUS[_i];  _i+=1);
  _i=0; loop(32,  _ub[UO_WC_MADD9 +_i]=CHORD_MOD_ADD9[_i]; _i+=1);
  _i=0; loop(32,  _ub[UO_WC_MADD7 +_i]=CHORD_MOD_ADD7[_i]; _i+=1);
  _i=0; loop(32,  _ub[UO_WC_MINV  +_i]=CHORD_MOD_INV[_i];  _i+=1);
  _i=0; loop(32,  _ub[UO_WC_MDOM7 +_i]=CHORD_MOD_DOM7[_i]; _i+=1);
  _i=0; loop(32,  _ub[UO_WC_MADD6 +_i]=CHORD_MOD_ADD6[_i]; _i+=1);
  undo_head = (undo_head + 1) % UNDO_MAX;
  undo_count = min(undo_count + 1, UNDO_MAX);
  undo_redo_count = 0;
);

function undo_restore(_ub) local(_i) (
  _i=0; loop(16 * PAT_SIZE, PAT_BASE[_i] = _ub[UO_BANK+_i]; _i+=1);
  _i=0; loop(MAX_SONG_PARTS * SONG_PART_SIZE, SONG_PARTS[_i] = _ub[UO_SONG_P+_i]; _i+=1);
  _i=0; loop(MAX_SONG_SEQ, SONG_SEQ[_i] = _ub[UO_SONG_S+_i]; _i+=1);
  _i=0; loop(MAX_SONG_PARTS, SONG_PART_OCT[_i] = _ub[UO_SONG_O+_i]; _i+=1);
  slider3=_ub[UO_META+0]; current_pat=_ub[UO_META+1]; num_pats=_ub[UO_META+2];
  song_num_parts=_ub[UO_META+3]; song_seq_len=_ub[UO_META+4];
  song_sel_part=_ub[UO_META+5]; song_mode=_ub[UO_META+6];
  _i=0; loop(64,  CHORD_SLOTS[_i]   =_ub[UO_WC_SLOTS +_i]; _i+=1);
  _i=0; loop(32,  CHORD_FILLED[_i]  =_ub[UO_WC_FILLED+_i]; _i+=1);
  _i=0; loop(32,  CHORD_BARS[_i]    =_ub[UO_WC_BARS  +_i]; _i+=1);
  _i=0; loop(32,  CHORD_SUBDIV[_i]  =_ub[UO_WC_SUBDIV+_i]; _i+=1);
  _i=0; loop(512, CHORD_PATTERN[_i] =_ub[UO_WC_PAT   +_i]; _i+=1);
  _i=0; loop(32,  CHORD_VEL[_i]     =_ub[UO_WC_VEL   +_i]; _i+=1);
  _i=0; loop(32,  CHORD_MOD_STEP[_i]=_ub[UO_WC_MSTEP +_i]; _i+=1);
  _i=0; loop(512, CHORD_MOD_TICK[_i]=_ub[UO_WC_MTICK +_i]; _i+=1);
  _i=0; loop(32,  CHORD_MOD_SUS[_i] =_ub[UO_WC_MSUS  +_i]; _i+=1);
  _i=0; loop(32,  CHORD_MOD_ADD9[_i]=_ub[UO_WC_MADD9 +_i]; _i+=1);
  _i=0; loop(32,  CHORD_MOD_ADD7[_i]=_ub[UO_WC_MADD7 +_i]; _i+=1);
  _i=0; loop(32,  CHORD_MOD_INV[_i] =_ub[UO_WC_MINV  +_i]; _i+=1);
  _i=0; loop(32,  CHORD_MOD_DOM7[_i]=_ub[UO_WC_MDOM7 +_i]; _i+=1);
  _i=0; loop(32,  CHORD_MOD_ADD6[_i]=_ub[UO_WC_MADD6 +_i]; _i+=1);
  conn_dirty = 1;
);

function undo_pop() local(_ub) (
  undo_count > 0 ? (
    undo_head = (undo_head - 1 + UNDO_MAX) % UNDO_MAX;
    _ub = UNDO_BASE + undo_head * UNDO_SNAP_SIZE;
    undo_restore(_ub);
    undo_count -= 1;
    undo_redo_count += 1;
  );
);

// ---- Initial diatonic build ----
build_diatonic(slider1, slider2);

// ============================================================================
//  @SLIDER
// ============================================================================
@slider
  build_diatonic(slider1, slider2);
  conn_dirty = 1;

// ============================================================================
//  @BLOCK — Transport sync, MIDI output, broadcast
// ============================================================================
@block
// Recalculate from sliders
build_diatonic(slider1, slider2);

// Broadcast
bc.lms_bc_block();
bc.bc_leader_pbase > 0 ? (
  slider1 = gmem[bc.bc_leader_pbase + 0];
  slider2 = gmem[bc.bc_leader_pbase + 1];
  slider3 = gmem[bc.bc_leader_pbase + 2];
  slider4 = gmem[bc.bc_leader_pbase + 3];
  slider5 = gmem[bc.bc_leader_pbase + 4];
  slider6 = gmem[bc.bc_leader_pbase + 5];
  slider7 = gmem[bc.bc_leader_pbase + 6];
);
bc.bc_did_steal ? (
  slider1 = gmem[bc.bc_steal_pbase + 0];
  slider2 = gmem[bc.bc_steal_pbase + 1];
  slider3 = gmem[bc.bc_steal_pbase + 2];
  slider4 = gmem[bc.bc_steal_pbase + 3];
  slider5 = gmem[bc.bc_steal_pbase + 4];
  slider6 = gmem[bc.bc_steal_pbase + 5];
  slider7 = gmem[bc.bc_steal_pbase + 6];
);
bc.bc_my_pbase > 0 ? (
  gmem[bc.bc_my_pbase + 0] = slider1;
  gmem[bc.bc_my_pbase + 1] = slider2;
  gmem[bc.bc_my_pbase + 2] = slider3;
  gmem[bc.bc_my_pbase + 3] = slider4;
  gmem[bc.bc_my_pbase + 4] = slider5;
  gmem[bc.bc_my_pbase + 5] = slider6;
  gmem[bc.bc_my_pbase + 6] = slider7;
  gmem[bc.bc_my_pbase + 7] = hm_role;
  gmem[bc.bc_my_pbase + 8] = num_pats;
  gmem[bc.bc_my_pbase + 9] = conductor_seed_gen;
);

// ============================================================================
//  CONDUCTOR BROADCAST — publish structure to HARMONY_BUS for players
// ============================================================================
hm_role == 1 ? (
  gmem[COND_BUS + 0] = bc.bc_my_id;
  gmem[COND_BUS + 1] = num_pats;
  gmem[COND_BUS + 2] = _song_mode_eff;  // broadcast playback state, not UI toggle
  gmem[COND_BUS + 3] = song_num_parts;
  gmem[COND_BUS + 4] = song_seq_len;
  gmem[COND_BUS + 5] = current_pat;

  // Song parts (16 × 8 = 128 floats)
  _ci = 0; loop(MAX_SONG_PARTS * SONG_PART_SIZE, gmem[COND_PARTS + _ci] = SONG_PARTS[_ci]; _ci += 1);
  // Song sequence (64 floats)
  _ci = 0; loop(MAX_SONG_SEQ, gmem[COND_SEQ + _ci] = SONG_SEQ[_ci]; _ci += 1);
  // Song octave overrides (16 floats)
  _ci = 0; loop(MAX_SONG_PARTS, gmem[COND_OCT + _ci] = SONG_PART_OCT[_ci]; _ci += 1);

  // Per-pattern structure: nsteps, bar durations, subdivisions
  pat_save(current_pat);  // ensure bank is current
  _pi = 0;
  loop(num_pats,
    _cpb = PAT_BASE + _pi * PAT_SIZE;
    _go = COND_PAT_STRUCT + _pi * 80;
    gmem[_go] = (_cpb + PO_NSTEPS)[0];
    _si = 0; loop(32,
      gmem[_go + 1 + _si]  = (_cpb + PO_BARS)[_si];
      gmem[_go + 33 + _si] = (_cpb + PO_SUBDIV)[_si];
      _si += 1;
    );
    _pi += 1;
  );

  // Chord seed — publish full pattern bank when dirty
  conductor_seed_dirty ? (
    _ci = 0; loop(num_pats * PAT_SIZE, gmem[COND_SEED + _ci] = PAT_BASE[_ci]; _ci += 1);
    conductor_seed_dirty = 0;
    conductor_seed_gen += 1;  // increment so players detect new seed
  );
);

// ============================================================================
//  PLAYER READ — import structure from conductor, keep own chords
// ============================================================================
hm_role == 2 ? (
  // Find conductor by scanning BC region
  conductor_found_id = 0;
  _si = 0;
  loop(32,
    _sb = bc.BC_MY_REGION + _si * 512;
    gmem[_sb + 1] > 0 && gmem[_sb + 8 + 7] == 1 ? (  // param[7] == 1 = conductor
      conductor_found_id = gmem[_sb + 1];
    );
    _si += 1;
  );

  conductor_found_id > 0 && gmem[COND_BUS + 0] == conductor_found_id ? (
    // Read song mode state (for playback only — don't override player's UI view toggle)
    song_mode_play = gmem[COND_BUS + 2];
    song_num_parts = gmem[COND_BUS + 3];
    song_seq_len   = gmem[COND_BUS + 4];

    // Read song parts
    _ci = 0; loop(MAX_SONG_PARTS * SONG_PART_SIZE, SONG_PARTS[_ci] = gmem[COND_PARTS + _ci]; _ci += 1);
    // Read song sequence
    _ci = 0; loop(MAX_SONG_SEQ, SONG_SEQ[_ci] = gmem[COND_SEQ + _ci]; _ci += 1);
    // Read octave overrides
    _ci = 0; loop(MAX_SONG_PARTS, SONG_PART_OCT[_ci] = gmem[COND_OCT + _ci]; _ci += 1);

    // Read pattern structure — apply to local bank WITHOUT touching chords
    _cond_npats = gmem[COND_BUS + 1];
    num_pats = max(num_pats, _cond_npats);  // grow to match conductor
    _pi = 0;
    loop(_cond_npats,
      _cpb = PAT_BASE + _pi * PAT_SIZE;
      _go = COND_PAT_STRUCT + _pi * 80;
      (_cpb + PO_NSTEPS)[0] = gmem[_go];
      _si = 0; loop(32,
        (_cpb + PO_BARS)[_si] = gmem[_go + 1 + _si];
        // PO_SUBDIV stays local — player owns subdivisions + tick patterns
        _si += 1;
      );
      _pi += 1;
    );
    // Sync working copy structure if viewing a conductor-managed pattern
    _pi = current_pat;
    _pi < _cond_npats ? (
      _cpb = PAT_BASE + _pi * PAT_SIZE;
      slider3 = max(1, (_cpb + PO_NSTEPS)[0]);
      _si = 0; loop(32,
        CHORD_BARS[_si] = (_cpb + PO_BARS)[_si];
        // CHORD_SUBDIV stays local — player owns subdivisions
        _si += 1;
      );
    );

    // One-time chord steal from conductor
    !player_seeded ? (
      _seed_npats = gmem[COND_BUS + 1];
      _ci = 0; loop(_seed_npats * PAT_SIZE, PAT_BASE[_ci] = gmem[COND_SEED + _ci]; _ci += 1);
      pat_load(current_pat);
      player_seeded = 1;
    );
  );
);

// Transport sync
ts_num > 0 && ts_denom > 0 ? (
  beats_per_measure = ts_num * 4.0 / ts_denom;
) : (
  beats_per_measure = 4;
);

prev_playing = transport_playing;
transport_playing = (play_state & 1);
transport_started = transport_playing && !prev_playing;
transport_started ? (edit_override = 0; arr_cur_pat = -1; song_cur_seq = -1;);

// Effective song mode for playback: players use conductor's state
// Song playback is active whenever a sequence exists — view toggle is independent
_song_mode_eff = hm_role == 2 ? song_mode_play : (song_seq_len > 0 && song_num_parts > 0);

// Song mode: build flat sequence from parts + repeats, map beat_position
_song_mode_eff && transport_playing && song_seq_len > 0 ? (
  // Build expanded sequence: walk SONG_SEQ, expand repeats
  _sng_len = 0; _sng_cum = 0;
  _sqi = 0;
  loop(song_seq_len,
    _sp_idx = SONG_SEQ[_sqi];
    _sp_idx < song_num_parts ? (
      _sp_base = _sp_idx * SONG_PART_SIZE;
      _sp_pat = SONG_PARTS[_sp_base + 2];
      _sp_reps = max(1, SONG_PARTS[_sp_base + 3]);
      // Compute pattern duration in beats
      _sp_pat == current_pat ? (
        _spns = max(1, slider3);
        _spdur = 0; _spsi = 0; loop(_spns, _spdur += max(1, CHORD_BARS[_spsi]); _spsi+=1);
      ) : (
        _sppb = PAT_BASE + _sp_pat * PAT_SIZE;
        _spns = max(1, (_sppb+PO_NSTEPS)[0]);
        _spdur = 0; _spsi = 0; loop(_spns, _spdur += max(1, (_sppb+PO_BARS)[_spsi]); _spsi+=1);
      );
      _sp_beats = _spdur * beats_per_measure;
      // Expand repeats
      _ri = 0;
      loop(_sp_reps,
        _sng_len < MAX_SONG_SEQ ? (
          SONG_SEQ_CUM[_sng_len]  = _sng_cum;
          SONG_SEQ_PAT[_sng_len]  = _sp_pat;
          SONG_SEQ_PART[_sng_len] = _sp_idx;
          SONG_SEQ_SRC[_sng_len]  = _sqi;
          _sng_cum += _sp_beats;
          _sng_len += 1;
        );
        _ri += 1;
      );
    );
    _sqi += 1;
  );
  _sng_len > 0 ? (
    _sng_total = _sng_cum;
    _sng_cycle = floor(beat_position / _sng_total);
    _sng_beat  = beat_position - _sng_cycle * _sng_total;
    _sng_idx = 0; _si = 0;
    loop(_sng_len, _sng_beat >= SONG_SEQ_CUM[_si] ? _sng_idx = _si; _si += 1);
    song_cur_seq = _sng_idx;
    song_cur_src = SONG_SEQ_SRC[_sng_idx];  // original SONG_SEQ index for UI
    song_cur_part_idx = SONG_SEQ_PART[_sng_idx];
    arr_cur_pat = SONG_SEQ_PAT[_sng_idx];
    play_beat = _sng_beat - SONG_SEQ_CUM[_sng_idx];
    arr_seq_ok = 1;
    // Song mode modifiers — store for @block velocity/key application
    _smp_base = song_cur_part_idx * SONG_PART_SIZE;
    song_mod_key = SONG_PARTS[_smp_base + 4];
    song_mod_mode = SONG_PARTS[_smp_base + 5];
    song_mod_vel = SONG_PARTS[_smp_base + 6];
    song_mod_arp = SONG_PARTS[_smp_base + 7];
    song_mod_oct = SONG_PART_OCT[song_cur_part_idx];
  ) : (
    song_cur_seq = -1; song_cur_src = -1;
    arr_cur_pat = -1;
    arr_seq_ok = 0;
    play_beat = beat_position;
    song_mod_key = 0; song_mod_mode = 0; song_mod_vel = 0; song_mod_arp = 0; song_mod_oct = 0;
    song_mod_arp = 0; song_mod_oct = 0;
  );
) : (
  // No song mode: simple playback from current pattern
  arr_seq_ok = 1;
  play_beat = beat_position;
  arr_cur_pat = -1;
);

// Auto-switch working copy to follow song playback — view always shows what's playing
_song_mode_eff && arr_seq_ok && arr_cur_pat >= 0 && arr_cur_pat != current_pat && transport_playing ? (
  pat_save(current_pat);
  current_pat = arr_cur_pat;
  pat_load(current_pat);
);

// P_* pointer setup: point at bank for non-current patterns in song mode, working copy otherwise
_song_mode_eff && arr_seq_ok && arr_cur_pat >= 0 && arr_cur_pat != current_pat ? (
  _apb = PAT_BASE + arr_cur_pat * PAT_SIZE;
  P_SLOTS   = _apb + PO_SLOTS;   P_FILLED  = _apb + PO_FILLED;
  P_BARS    = _apb + PO_BARS;    P_SUBDIV  = _apb + PO_SUBDIV;
  P_NSTEPS  = max(1, (_apb+PO_NSTEPS)[0]);
  P_PATTERN = _apb + PO_PATTERN; P_VEL     = _apb + PO_VEL;
  P_MSTEP   = _apb + PO_MSTEP;  P_MTICK   = _apb + PO_MTICK;
  P_MSUS    = _apb + PO_MSUS;   P_MADD9   = _apb + PO_MADD9;
  P_MADD7   = _apb + PO_MADD7;  P_MINV    = _apb + PO_MINV;
  P_MDOM7   = _apb + PO_MDOM7;  P_MADD6   = _apb + PO_MADD6;
) : (
  P_SLOTS   = CHORD_SLOTS;       P_FILLED  = CHORD_FILLED;
  P_BARS    = CHORD_BARS;        P_SUBDIV  = CHORD_SUBDIV;
  P_NSTEPS  = max(1, slider3);
  P_PATTERN = CHORD_PATTERN;     P_VEL     = CHORD_VEL;
  P_MSTEP   = CHORD_MOD_STEP;   P_MTICK   = CHORD_MOD_TICK;
  P_MSUS    = CHORD_MOD_SUS;    P_MADD9   = CHORD_MOD_ADD9;
  P_MADD7   = CHORD_MOD_ADD7;   P_MINV    = CHORD_MOD_INV;
  P_MDOM7   = CHORD_MOD_DOM7;   P_MADD6   = CHORD_MOD_ADD6;
);

// Count total bars from step durations (via P_* pointers)
num_steps = P_NSTEPS;
total_bars_sum = 0;
_si = 0;
loop(num_steps,
  _dur = P_BARS[_si]; _dur < 1 ? _dur = 1;
  total_bars_sum += _dur;
  _si += 1;
);
total_beats = beats_per_measure * total_bars_sum;

// Find which step we're in based on beat position
beats_per_measure > 0 && transport_playing ? (
  total_beats > 0 ? (
    pattern_cycle = floor(play_beat / total_beats);
    beat_in_pattern = play_beat - pattern_cycle * total_beats;
  ) : (
    beat_in_pattern = 0;
  );
  cur_bar_in_pattern = floor(beat_in_pattern / beats_per_measure);
  cur_bar_in_pattern = max(0, min(total_bars_sum - 1, cur_bar_in_pattern));

  // Map bar position to step index
  _acc = 0;
  cur_step = 0;
  _si = 0;
  loop(num_steps,
    _dur = max(1, P_BARS[_si]);
    cur_bar_in_pattern >= _acc && cur_bar_in_pattern < _acc + _dur ? cur_step = _si;
    _acc += _dur;
    _si += 1;
  );
  edit_override == 0 && !(_song_mode_eff && song_cur_seq >= 0 && arr_cur_pat >= 0 && arr_cur_pat != current_pat) ? slider7 = cur_step + 1;
) : (
  cur_step = max(0, slider7 - 1);
);

// Compute sub-beat position within current step
_step_start_bar = 0;
_si = 0;
loop(cur_step, _step_start_bar += max(1, P_BARS[_si]); _si += 1);
_step_dur_bars = max(1, P_BARS[cur_step]);
_step_subdiv = max(1, P_SUBDIV[cur_step]);
_step_subdiv < 1 ? _step_subdiv = 1;

// Beat position within this step
_step_start_beat = _step_start_bar * beats_per_measure;
_step_dur_beats = _step_dur_bars * beats_per_measure;
_beat_in_step = beat_in_pattern - _step_start_beat;
_beat_in_step < 0 ? _beat_in_step = 0;

// Current sub-beat index
_sub_beat_dur = _step_dur_beats / _step_subdiv;
_sub_beat_dur > 0 ? (
  cur_sub = floor(_beat_in_step / _sub_beat_dur);
  cur_sub = max(0, min(_step_subdiv - 1, cur_sub));
) : (
  cur_sub = 0;
);

// Detect step OR sub-beat change
step_changed = transport_playing && (cur_step != last_step || transport_started);
sub_changed = transport_playing && cur_step == last_step && cur_sub != last_sub;

!transport_playing && prev_playing ? all_notes_off();

(step_changed || sub_changed) && transport_playing ? (
  all_notes_off();
  step_notes_count = 0;

  // Check if this sub-beat is active in the pattern
  _sdv = max(1, P_SUBDIV[cur_step]);
  _sdv <= 1 ? _tick_on = 1 : _tick_on = P_PATTERN[cur_step*16 + cur_sub];

  _tick_on && P_FILLED[cur_step] && arr_seq_ok ? (
    bar_root = P_SLOTS[cur_step * 2];
    bar_qual = P_SLOTS[cur_step * 2 + 1];
    // Song mode modifiers: modulate key, force mode
    _song_mode_eff && song_cur_seq >= 0 ? (
      // Modulate: transpose root by (target_key - original_key) semitones
      song_mod_key > 0 ? (
        _target_key = song_mod_key - 1;  // 1-12 → 0-11
        _transpose = (_target_key - slider1 + 12) % 12;
        bar_root = (bar_root + _transpose) % 12;
      );
      // Force major/minor: remap quality
      song_mod_mode == 1 ? (  // force major
        bar_qual == 1 ? bar_qual = 0;   // min → maj
        bar_qual == 3 ? bar_qual = 2;   // min7 → maj7
        bar_qual == 12 ? bar_qual = 14; // min9 → maj9
      );
      song_mod_mode == 2 ? (  // force minor
        bar_qual == 0 ? bar_qual = 1;   // maj → min
        bar_qual == 2 ? bar_qual = 3;   // maj7 → min7
        bar_qual == 14 ? bar_qual = 12; // maj9 → min9
      );
    );
    // Song mode octave override (relative to each instance's own octave)
    _use_oct = slider6;
    _song_mode_eff && song_cur_seq >= 0 && song_mod_oct > 0 ? (
      // 1=-2, 2=-1, 3=0(no shift), 4=+1, 5=+2, 6=+3
      _use_oct = max(-2, min(3, slider6 + (song_mod_oct - 3)));
    );
    build_chord_midi(bar_root, bar_qual, slider5, _use_oct);
    step_notes_count > 0 ? (
      (_sdv <= 1 ? P_MSTEP[cur_step] : P_MTICK[cur_step*16 + cur_sub]) ? apply_step_mods(cur_step);
      _sv = P_VEL[cur_step]; _sv <= 0 ? _sv = 100;
      _ni = 0; loop(step_notes_count, STEP_VELS[_ni] = max(1, min(127, floor(STEP_VELS[_ni] * _sv / 100))); _ni += 1);
      // Song mode velocity override (0=off, 1-127=target velocity)
      _song_mode_eff && song_cur_seq >= 0 && song_mod_vel > 0 ? (
        _ni = 0; loop(step_notes_count,
          STEP_VELS[_ni] = max(1, min(127, floor(STEP_VELS[_ni] * song_mod_vel / 100)));
          _ni += 1;
        );
      );
      // Song mode arp: pick one note per sub-beat instead of firing all
      _song_mode_eff && song_cur_seq >= 0 && song_mod_arp > 0 && step_notes_count > 1 ? (
        // Sort notes ascending for arp ordering
        _an = step_notes_count;
        _ai = 0; loop(_an - 1,
          _aj = 0; loop(_an - 1 - _ai,
            STEP_NOTES[_aj] > STEP_NOTES[_aj+1] ? (
              _tmp = STEP_NOTES[_aj]; STEP_NOTES[_aj] = STEP_NOTES[_aj+1]; STEP_NOTES[_aj+1] = _tmp;
              _tmp = STEP_VELS[_aj]; STEP_VELS[_aj] = STEP_VELS[_aj+1]; STEP_VELS[_aj+1] = _tmp;
            );
            _aj += 1;
          );
          _ai += 1;
        );
        // Pick note index based on arp mode and current sub-beat
        song_mod_arp == 1 ? (  // UP
          _arp_idx = cur_sub % _an;
        ) : song_mod_arp == 2 ? (  // DOWN
          _arp_idx = (_an - 1) - (cur_sub % _an);
        ) : song_mod_arp == 3 ? (  // UP-DOWN
          _arp_cycle = _an * 2 - 2;  // e.g. 4 notes = 6-step cycle: 0,1,2,3,2,1
          _arp_cycle < 1 ? _arp_cycle = 1;
          _arp_pos = cur_sub % _arp_cycle;
          _arp_pos < _an ? _arp_idx = _arp_pos : _arp_idx = _arp_cycle - _arp_pos;
        ) : (  // RANDOM (4)
          _arp_idx = floor(rand(_an));
        );
        _arp_idx = max(0, min(_an - 1, _arp_idx));
        // Replace chord with single note
        STEP_NOTES[0] = STEP_NOTES[_arp_idx];
        STEP_VELS[0] = STEP_VELS[_arp_idx];
        step_notes_count = 1;
      );
      fire_all_notes();
    );
  );
  step_changed ? conn_dirty = 1;
);
last_step = cur_step;
last_sub = cur_sub;

// Recompute connections if dirty
conn_dirty ? (
  // Map shows connections FROM the previous step
  _eb = max(0, slider7 - 1);
  _prev_step = _eb > 0 ? _eb - 1 : 0;
  CHORD_FILLED[_prev_step] ? (
    _mr = CHORD_SLOTS[_prev_step * 2];
    _mq = CHORD_SLOTS[_prev_step * 2 + 1];
    compute_connections(_mr, _mq);
  ) : (
    compute_connections(slider1, slider2 == 0 ? 0 : 1);
  );
  conn_dirty = 0;
);

// Harmony bus — single chord + full progression broadcast
gmem[HARMONY_BUS] += 1;
_eb = max(0, slider7 - 1);
gmem[HARMONY_BUS + 1] = CHORD_SLOTS[_eb * 2];
gmem[HARMONY_BUS + 2] = CHORD_SLOTS[_eb * 2 + 1];
gmem[HARMONY_BUS + 3] = cur_step;
gmem[HARMONY_BUS + 4] = slider3;
gmem[HARMONY_BUS + 5] = slider1;
gmem[HARMONY_BUS + 6] = slider2;
gmem[HARMONY_BUS + 7] = slider4;
gmem[HARMONY_BUS + 8] = transport_playing;
// Full chord state broadcast (via P_* so it works in all modes)
gmem[HARMONY_BUS + 10] = P_NSTEPS;
_bci = 0; loop(32,
  gmem[HARMONY_BUS + 11 + _bci]  = P_FILLED[_bci] ? P_SLOTS[_bci * 2] : 255;
  gmem[HARMONY_BUS + 43 + _bci]  = P_FILLED[_bci] ? P_SLOTS[_bci * 2 + 1] : 255;
  _bci += 1;
);
// Song mode state
gmem[HARMONY_BUS + 80] = song_mode;
gmem[HARMONY_BUS + 81] = _song_mode_eff && song_cur_seq >= 0 ? song_cur_part_idx : -1;
gmem[HARMONY_BUS + 82] = song_mod_key;
gmem[HARMONY_BUS + 83] = song_mod_mode;

// Preview chord (triggered from @gfx click) — always uses working copy
preview_chord_dirty ? (
  all_notes_off();
  build_chord_midi(preview_root, preview_qual, slider5, slider6);
  _pv_step = max(0, slider7 - 1);
  // Force P_* to working copy so apply_step_mods reads the right mods
  P_SLOTS=CHORD_SLOTS; P_MSTEP=CHORD_MOD_STEP; P_MTICK=CHORD_MOD_TICK;
  P_MSUS=CHORD_MOD_SUS; P_MADD9=CHORD_MOD_ADD9; P_MADD7=CHORD_MOD_ADD7;
  P_MINV=CHORD_MOD_INV; P_MDOM7=CHORD_MOD_DOM7; P_MADD6=CHORD_MOD_ADD6;
  CHORD_MOD_STEP[_pv_step] ? apply_step_mods(_pv_step);
  _pv = CHORD_VEL[_pv_step]; _pv <= 0 ? _pv = 100;
  _ni = 0; loop(step_notes_count, STEP_VELS[_ni] = max(1, min(127, floor(STEP_VELS[_ni] * _pv / 100))); _ni += 1);
  fire_all_notes();
  preview_chord_dirty = 0;
  preview_ticks = floor(srate * 0.6);
);
preview_ticks > 0 ? (
  preview_ticks -= samplesblock;
  preview_ticks <= 0 ? (
    preview_ticks = 0;
    !transport_playing ? all_notes_off();
  );
);

// MIDI passthrough
while(midirecv(offset, msg1, msg2, msg3)) (
  midisend(offset, msg1, msg2, msg3);
);

// ============================================================================
//  @SAMPLE — MIDI only, no audio processing
// ============================================================================
@sample
spl0 = spl0;
spl1 = spl1;

// ============================================================================
//  @GFX — Harmony Map Interface
// ============================================================================
@gfx 750 580

gfx_ext_retina > 0 ? gfx_ext_retina = 1;
char = gfx_getchar();


// Push undo snapshot on any fresh click (before state changes)
((mouse_cap & 1) && !(last_cap & 1)) || ((mouse_cap & 2) && !(last_cap & 2)) ? undo_push();
// Also push on Delete key or scroll wheel
char == 6579564 || (mouse_wheel != 0 && mouse_y >= timeline_y && mouse_y < timeline_y + timeline_h) ? undo_push();

// Snapshot @block state for this frame (prevent mid-frame race with audio thread)
_gfx_song_cur_seq  = song_cur_seq;
_gfx_song_cur_src  = song_cur_src;
_gfx_song_mod_arp  = song_mod_arp;
_gfx_song_mod_oct  = song_mod_oct;
_gfx_song_mod_key  = song_mod_key;
_gfx_song_mod_mode = song_mod_mode;
_gfx_song_mod_vel  = song_mod_vel;
_gfx_cur_step      = cur_step;
_gfx_cur_sub       = cur_sub;
_gfx_transport      = transport_playing;
_gfx_current_pat   = current_pat;
_gfx_arr_cur_pat   = arr_cur_pat;
_gfx_arr_seq_ok    = arr_seq_ok;

S = gfx_w / 750;
S < 0.5 ? S = 0.5;

F_TITLE = max(10, floor(22 * S));
F_LABEL = max(8, floor(12 * S));
F_SMALL = max(7, floor(11 * S));
F_TINY  = max(7, floor(10 * S));
F_CHORD = max(9, floor(14 * S));

COL_BG_R = 0.05; COL_BG_G = 0.05; COL_BG_B = 0.07;
COL_PANEL_R = 0.08; COL_PANEL_G = 0.08; COL_PANEL_B = 0.11;
COL_PANEL_HI_R = 0.12; COL_PANEL_HI_G = 0.12; COL_PANEL_HI_B = 0.16;
COL_BORDER_R = 0.20; COL_BORDER_G = 0.20; COL_BORDER_B = 0.25;
COL_TITLE_R = 0.95; COL_TITLE_G = 0.78; COL_TITLE_B = 0.35;
COL_SEC_R = 0.55; COL_SEC_G = 0.50; COL_SEC_B = 0.40;
COL_TEXT_R = 0.78; COL_TEXT_G = 0.78; COL_TEXT_B = 0.82;
COL_DIM_R = 0.38; COL_DIM_G = 0.38; COL_DIM_B = 0.42;
COL_ACCENT_R = 0.95; COL_ACCENT_G = 0.45; COL_ACCENT_B = 0.15;
COL_GREEN_R = 0.25; COL_GREEN_G = 0.80; COL_GREEN_B = 0.50;
COL_CYAN_R = 0.20; COL_CYAN_G = 0.60; COL_CYAN_B = 0.85;

margin = floor(8 * S);
gap = floor(6 * S);
hdr_h = floor(44 * S);

// ---- Background ----
gfx_a = 1;
gfx_r = COL_BG_R; gfx_g = COL_BG_G; gfx_b = COL_BG_B;
gfx_rect(0, 0, gfx_w, gfx_h);
gfx_r = 0.03; gfx_g = 0.03; gfx_b = 0.05;
gfx_rect(0, 0, gfx_w, hdr_h);
gfx_r = COL_TITLE_R * 0.6; gfx_g = COL_TITLE_G * 0.6; gfx_b = COL_TITLE_B * 0.6;
gfx_rect(0, hdr_h, gfx_w, max(1, floor(2 * S)));

// ---- Logo ----
gfx_getimgdim(0, logo_img_w, logo_img_h);
logo_img_w > 0 ? (
  logo_h = floor(32 * S);
  logo_w = floor(logo_h * (logo_img_w / logo_img_h));
  logo_x = floor(6 * S);
  logo_y = floor(((hdr_h - logo_h)) / 2);
  gfx_blit(0, 1, 0, 0, 0, logo_img_w, logo_img_h, logo_x, logo_y, logo_w, logo_h);
) : (logo_w = 0; logo_x = 0;);

// ---- Title ----
gfx_r = COL_TITLE_R; gfx_g = COL_TITLE_G; gfx_b = COL_TITLE_B;
gfx_setfont(1, "Arial", F_TITLE);
gfx_x = logo_x + logo_w + floor(8 * S); gfx_y = floor(10 * S);
gfx_drawstr("HARMONY MAP");

// ---- Role selector (right of title) ----
_role_w = floor(72 * S);
_role_h = floor(18 * S);
_role_x = gfx_x + floor(8 * S);
_role_y = floor(12 * S);
hm_role == 1 ? (gfx_r=0.50; gfx_g=0.25; gfx_b=0.10;) :
hm_role == 2 ? (gfx_r=0.15; gfx_g=0.30; gfx_b=0.50;) :
               (gfx_r=0.12; gfx_g=0.12; gfx_b=0.15;);
gfx_rect(_role_x, _role_y, _role_w, _role_h);
gfx_setfont(1, "Arial", F_SMALL);
hm_role == 1 ? (gfx_r=1.0; gfx_g=0.70; gfx_b=0.30; _cs="CONDUCTOR") :
hm_role == 2 ? (gfx_r=0.50; gfx_g=0.80; gfx_b=1.0; _cs="PLAYER") :
               (gfx_r=COL_DIM_R; gfx_g=COL_DIM_G; gfx_b=COL_DIM_B; _cs="STANDALONE");
gfx_measurestr(_cs, _tw, _th);
gfx_x = _role_x + floor((_role_w - _tw)/2); gfx_y = _role_y + floor((_role_h - _th)/2);
gfx_drawstr(_cs);
(mouse_cap & 1) && !(last_cap & 1) &&
  mouse_x >= _role_x && mouse_x < _role_x + _role_w &&
  mouse_y >= _role_y && mouse_y < _role_y + _role_h ? (
  hm_role = (hm_role + 1) % 3;
  hm_role == 1 ? conductor_seed_dirty = 1;  // becoming conductor, publish seed
  hm_role == 2 ? player_seeded = 0;         // becoming player, need fresh seed
);

// ---- Undo / Redo buttons (header, right of role selector) ----
_ub_w = floor(24 * S);
_ub_h = floor(18 * S);
_ub_x = _role_x + _role_w + floor(6 * S);
_ub_y = _role_y;
// Undo button
undo_count > 0 ? (gfx_r=0.20; gfx_g=0.20; gfx_b=0.30;) : (gfx_r=0.10; gfx_g=0.10; gfx_b=0.12;);
gfx_rect(_ub_x, _ub_y, _ub_w, _ub_h);
undo_count > 0 ? (gfx_r=0.65; gfx_g=0.65; gfx_b=0.85;) : (gfx_r=0.25; gfx_g=0.25; gfx_b=0.28;);
gfx_setfont(1, "Arial", F_SMALL);
gfx_measurestr("<", _tw, _th);
gfx_x = _ub_x + floor((_ub_w - _tw)/2); gfx_y = _ub_y + floor((_ub_h - _th)/2);
gfx_drawstr("<");
(mouse_cap & 1) && !(last_cap & 1) &&
  mouse_x >= _ub_x && mouse_x < _ub_x + _ub_w &&
  mouse_y >= _ub_y && mouse_y < _ub_y + _ub_h ? undo_pop();
// Redo button
_rb_x = _ub_x + _ub_w + floor(2 * S);
undo_redo_count > 0 ? (gfx_r=0.20; gfx_g=0.20; gfx_b=0.30;) : (gfx_r=0.10; gfx_g=0.10; gfx_b=0.12;);
gfx_rect(_rb_x, _ub_y, _ub_w, _ub_h);
undo_redo_count > 0 ? (gfx_r=0.65; gfx_g=0.65; gfx_b=0.85;) : (gfx_r=0.25; gfx_g=0.25; gfx_b=0.28;);
gfx_measurestr(">", _tw, _th);
gfx_x = _rb_x + floor((_ub_w - _tw)/2); gfx_y = _ub_y + floor((_ub_h - _th)/2);
gfx_drawstr(">");
(mouse_cap & 1) && !(last_cap & 1) &&
  mouse_x >= _rb_x && mouse_x < _rb_x + _ub_w &&
  mouse_y >= _ub_y && mouse_y < _ub_y + _ub_h ? (
  undo_redo_count > 0 ? (
    _ub = UNDO_BASE + undo_head * UNDO_SNAP_SIZE;
    undo_restore(_ub);
    undo_head = (undo_head + 1) % UNDO_MAX;
    undo_redo_count -= 1;
    undo_count += 1;
  );
);

// Key controls in header (interactive)
gfx_setfont(1, "Arial", F_SMALL);
_kc_y = floor(hdr_h / 2) - floor(10 * S);
_kc_h = floor(20 * S);
_kc_arrow_w = floor(18 * S);
_kc_note_w  = floor(34 * S);
_kc_mode_w  = floor(48 * S);
_kc_gap     = floor(4 * S);
_kc_right   = gfx_w - margin;
// layout right-to-left: [Maj/Min] [>] [note] [<] [Key:]
_mode_x = _kc_right - _kc_mode_w;
_arr_r_x = _mode_x - _kc_gap - _kc_arrow_w;
_note_x  = _arr_r_x - _kc_note_w;
_arr_l_x = _note_x - _kc_arrow_w;

// Draw < arrow
gfx_r = COL_PANEL_HI_R * 1.5; gfx_g = COL_PANEL_HI_G * 1.5; gfx_b = COL_PANEL_HI_B * 1.5;
gfx_rect(_arr_l_x, _kc_y, _kc_arrow_w, _kc_h);
gfx_r = COL_TEXT_R; gfx_g = COL_TEXT_G; gfx_b = COL_TEXT_B;
gfx_x = _arr_l_x + floor(5 * S); gfx_y = _kc_y + floor(4 * S);
gfx_drawstr("<");

// Draw note name
gfx_r = COL_PANEL_R; gfx_g = COL_PANEL_G; gfx_b = COL_PANEL_B;
gfx_rect(_note_x, _kc_y, _kc_note_w, _kc_h);
gfx_r = COL_TITLE_R; gfx_g = COL_TITLE_G; gfx_b = COL_TITLE_B;
_kr = slider1 % 12;
_kr==0?(_kn=#; _kn="C"):_kr==1?(_kn=#; _kn="C#"):_kr==2?(_kn=#; _kn="D"):_kr==3?(_kn=#; _kn="D#"):_kr==4?(_kn=#; _kn="E"):_kr==5?(_kn=#; _kn="F"):_kr==6?(_kn=#; _kn="F#"):_kr==7?(_kn=#; _kn="G"):_kr==8?(_kn=#; _kn="G#"):_kr==9?(_kn=#; _kn="A"):_kr==10?(_kn=#; _kn="A#"):(_kn=#; _kn="B");
gfx_measurestr(_kn, _kn_w, _kn_h);
gfx_x = _note_x + floor((_kc_note_w - _kn_w) / 2); gfx_y = _kc_y + floor(4 * S);
gfx_drawstr(_kn);

// Draw > arrow
gfx_r = COL_PANEL_HI_R * 1.5; gfx_g = COL_PANEL_HI_G * 1.5; gfx_b = COL_PANEL_HI_B * 1.5;
gfx_rect(_arr_r_x, _kc_y, _kc_arrow_w, _kc_h);
gfx_r = COL_TEXT_R; gfx_g = COL_TEXT_G; gfx_b = COL_TEXT_B;
gfx_x = _arr_r_x + floor(5 * S); gfx_y = _kc_y + floor(4 * S);
gfx_drawstr(">");

// Draw Maj/Min toggle
slider2 == 0 ? (
  gfx_r = 0.15; gfx_g = 0.25; gfx_b = 0.40;
) : (
  gfx_r = 0.30; gfx_g = 0.15; gfx_b = 0.35;
);
gfx_rect(_mode_x, _kc_y, _kc_mode_w, _kc_h);
gfx_r = COL_TEXT_R; gfx_g = COL_TEXT_G; gfx_b = COL_TEXT_B;
_km = #; slider2 == 0 ? _km = "Major" : _km = "Minor";
gfx_measurestr(_km, _km_w, _km_h);
gfx_x = _mode_x + floor((_kc_mode_w - _km_w) / 2); gfx_y = _kc_y + floor(4 * S);
gfx_drawstr(_km);

// "Key" label
gfx_r = COL_DIM_R; gfx_g = COL_DIM_G; gfx_b = COL_DIM_B;
gfx_x = _arr_l_x - floor(30 * S); gfx_y = _kc_y + floor(4 * S);
gfx_drawstr("Key");

// Octave controls (left of Key label)
_oc_val_w = floor(28 * S);
_oc_arr_w = floor(16 * S);
_oc_right = _arr_l_x - floor(38 * S);
_oc_val_x = _oc_right - _oc_val_w;
_oc_up_x  = _oc_val_x + _oc_val_w;
_oc_dn_x  = _oc_val_x - _oc_arr_w;

// [-] button
gfx_r = COL_PANEL_HI_R * 1.5; gfx_g = COL_PANEL_HI_G * 1.5; gfx_b = COL_PANEL_HI_B * 1.5;
gfx_rect(_oc_dn_x, _kc_y, _oc_arr_w, _kc_h);
gfx_r = COL_TEXT_R; gfx_g = COL_TEXT_G; gfx_b = COL_TEXT_B;
gfx_measurestr("-", _tw, _th);
gfx_x = _oc_dn_x + floor((_oc_arr_w - _tw)/2); gfx_y = _kc_y + floor(4*S);
gfx_drawstr("-");

// Octave value
gfx_r = COL_PANEL_R; gfx_g = COL_PANEL_G; gfx_b = COL_PANEL_B;
gfx_rect(_oc_val_x, _kc_y, _oc_val_w, _kc_h);
gfx_r = COL_TITLE_R; gfx_g = COL_TITLE_G; gfx_b = COL_TITLE_B;
_os = #; sprintf(_os, "%d", slider6);
gfx_measurestr(_os, _tw, _th);
gfx_x = _oc_val_x + floor((_oc_val_w - _tw)/2); gfx_y = _kc_y + floor(4*S);
gfx_drawstr(_os);

// [+] button
gfx_r = COL_PANEL_HI_R * 1.5; gfx_g = COL_PANEL_HI_G * 1.5; gfx_b = COL_PANEL_HI_B * 1.5;
gfx_rect(_oc_up_x, _kc_y, _oc_arr_w, _kc_h);
gfx_r = COL_TEXT_R; gfx_g = COL_TEXT_G; gfx_b = COL_TEXT_B;
gfx_measurestr("+", _tw, _th);
gfx_x = _oc_up_x + floor((_oc_arr_w - _tw)/2); gfx_y = _kc_y + floor(4*S);
gfx_drawstr("+");

// "Oct" label
gfx_r = COL_DIM_R; gfx_g = COL_DIM_G; gfx_b = COL_DIM_B;
gfx_x = _oc_dn_x - floor(28 * S); gfx_y = _kc_y + floor(4*S);
gfx_drawstr("Oct");

// Click handling
(mouse_cap & 1) && !(last_cap & 1) ? (
  // < arrow: root down — transpose working copy + all bank patterns
  mouse_x >= _arr_l_x && mouse_x < _arr_l_x + _kc_arrow_w &&
  mouse_y >= _kc_y && mouse_y < _kc_y + _kc_h ? (
    _old_key = slider1;
    slider1 = (slider1 + 11) % 12;
    _kd = (slider1 - _old_key + 12) % 12;
    _si = 0; loop(32, CHORD_FILLED[_si] ? CHORD_SLOTS[_si*2] = (CHORD_SLOTS[_si*2] + _kd) % 12; _si += 1;);
    _kp = 0; loop(num_pats,
      _kp != current_pat ? (
        _kb = PAT_BASE + _kp * PAT_SIZE;
        _ki = 0; loop(32, (_kb+PO_FILLED)[_ki] ? (_kb+PO_SLOTS)[_ki*2] = ((_kb+PO_SLOTS)[_ki*2] + _kd) % 12; _ki+=1);
      );
      _kp += 1;
    );
    sliderchange(slider1); conn_dirty = 1;
  );
  // > arrow: root up — transpose working copy + all bank patterns
  mouse_x >= _arr_r_x && mouse_x < _arr_r_x + _kc_arrow_w &&
  mouse_y >= _kc_y && mouse_y < _kc_y + _kc_h ? (
    _old_key = slider1;
    slider1 = (slider1 + 1) % 12;
    _kd = (slider1 - _old_key + 12) % 12;
    _si = 0; loop(32, CHORD_FILLED[_si] ? CHORD_SLOTS[_si*2] = (CHORD_SLOTS[_si*2] + _kd) % 12; _si += 1;);
    _kp = 0; loop(num_pats,
      _kp != current_pat ? (
        _kb = PAT_BASE + _kp * PAT_SIZE;
        _ki = 0; loop(32, (_kb+PO_FILLED)[_ki] ? (_kb+PO_SLOTS)[_ki*2] = ((_kb+PO_SLOTS)[_ki*2] + _kd) % 12; _ki+=1);
      );
      _kp += 1;
    );
    sliderchange(slider1); conn_dirty = 1;
  );
  // mode toggle — remap working copy + all bank patterns to new diatonic
  mouse_x >= _mode_x && mouse_x < _mode_x + _kc_mode_w &&
  mouse_y >= _kc_y && mouse_y < _kc_y + _kc_h ? (
    slider2 = slider2 == 0 ? 1 : 0;
    build_diatonic(slider1, slider2);
    // remap working copy
    _si = 0; loop(32,
      CHORD_FILLED[_si] ? (
        _sr = CHORD_SLOTS[_si*2]; _di = 0;
        loop(7, DIATONIC[_di*3] == _sr ? CHORD_SLOTS[_si*2+1] = DIATONIC[_di*3+1]; _di+=1);
      );
      _si += 1;
    );
    // remap all other bank patterns
    _kp = 0; loop(num_pats,
      _kp != current_pat ? (
        _kb = PAT_BASE + _kp * PAT_SIZE;
        _ki = 0; loop(32,
          (_kb+PO_FILLED)[_ki] ? (
            _sr = (_kb+PO_SLOTS)[_ki*2]; _di = 0;
            loop(7, DIATONIC[_di*3] == _sr ? (_kb+PO_SLOTS)[_ki*2+1] = DIATONIC[_di*3+1]; _di+=1);
          );
          _ki += 1;
        );
      );
      _kp += 1;
    );
    sliderchange(slider2); conn_dirty = 1;
  );
  // Octave [-] button
  mouse_x >= _oc_dn_x && mouse_x < _oc_dn_x + _oc_arr_w &&
  mouse_y >= _kc_y && mouse_y < _kc_y + _kc_h ? (
    slider6 = max(-2, slider6 - 1);
    sliderchange(slider6);
  );
  // Octave [+] button
  mouse_x >= _oc_up_x && mouse_x < _oc_up_x + _oc_arr_w &&
  mouse_y >= _kc_y && mouse_y < _kc_y + _kc_h ? (
    slider6 = min(3, slider6 + 1);
    sliderchange(slider6);
  );
);

// ============================================================================
//  PATTERN BAR — tabs for switching / adding patterns
// ============================================================================
patbar_h  = floor(26 * S);
patbar_y  = hdr_h + floor(4 * S);
_pb_tab_w = num_pats > 8 ? floor(28 * S) : floor(38 * S);
_pb_gap   = floor(2 * S);
_pb_x     = margin;

// Guard state
num_pats < 1 ? num_pats = 1;
current_pat < 0 ? current_pat = 0;
current_pat >= num_pats ? current_pat = num_pats - 1;

_pi = 0;
loop(num_pats,
  pat_set_color(_pi);
  _is_pat_active = (_pi == current_pat);
  gfx_a = _is_pat_active ? 0.85 : 0.35;
  gfx_rect(_pb_x, patbar_y, _pb_tab_w, patbar_h);
  // bright top edge on active tab
  _is_pat_active ? (
    pat_set_color(_pi);
    gfx_a = 1.0;
    gfx_rect(_pb_x, patbar_y, _pb_tab_w, max(1, floor(2*S)));
  );
  // label
  gfx_r = 1; gfx_g = 1; gfx_b = 1; gfx_a = _is_pat_active ? 1.0 : 0.65;
  gfx_setfont(1, "Arial", F_SMALL);
  _pl = #; sprintf(_pl, "P%d", _pi+1);
  gfx_measurestr(_pl, _plw, _plh);
  gfx_x = _pb_x + floor((_pb_tab_w - _plw)/2);
  gfx_y = patbar_y + floor((patbar_h - _plh)/2);
  gfx_drawstr(_pl);
  // click: switch pattern
  (mouse_cap & 1) && !(last_cap & 1) && !_is_pat_active &&
    mouse_x >= _pb_x && mouse_x < _pb_x + _pb_tab_w &&
    mouse_y >= patbar_y && mouse_y < patbar_y + patbar_h ? (
    pat_save(current_pat);
    current_pat = _pi;
    pat_load(current_pat);
    slider7 = 1; edit_override = 0;
  );
  _pb_x += _pb_tab_w + _pb_gap;
  _pi += 1;
);

// [+] New blank pattern
num_pats < 16 ? (
  gfx_r = 0.20; gfx_g = 0.22; gfx_b = 0.20; gfx_a = 1;
  gfx_rect(_pb_x, patbar_y, _pb_tab_w, patbar_h);
  gfx_r = COL_GREEN_R; gfx_g = COL_GREEN_G; gfx_b = COL_GREEN_B; gfx_a = 1;
  gfx_setfont(1, "Arial", F_LABEL);
  gfx_measurestr("+", _plw, _plh);
  gfx_x = _pb_x + floor((_pb_tab_w - _plw)/2); gfx_y = patbar_y + floor((patbar_h - _plh)/2);
  gfx_drawstr("+");
  (mouse_cap & 1) && !(last_cap & 1) &&
    mouse_x >= _pb_x && mouse_x < _pb_x + _pb_tab_w &&
    mouse_y >= patbar_y && mouse_y < patbar_y + patbar_h ? (
    pat_save(current_pat);
    pat_init(num_pats);
    current_pat = num_pats;
    num_pats += 1;
    pat_load(current_pat);
    slider7 = 1; edit_override = 0;
  );
  _pb_x += _pb_tab_w + _pb_gap;
);

// [SONG] mode toggle (right-aligned in pattern bar)
_song_btn_w = floor(48 * S);
_song_btn_x = gfx_w - margin - _song_btn_w;
song_mode ? (gfx_r=0.50; gfx_g=0.25; gfx_b=0.55;) : (gfx_r=0.15; gfx_g=0.12; gfx_b=0.18;);
gfx_a = 1; gfx_rect(_song_btn_x, patbar_y, _song_btn_w, patbar_h);
song_mode ? (gfx_r=0.85; gfx_g=0.50; gfx_b=0.95;) : (gfx_r=COL_DIM_R; gfx_g=COL_DIM_G; gfx_b=COL_DIM_B;);
gfx_setfont(1, "Arial", F_SMALL);
gfx_measurestr("SONG", _plw, _plh);
gfx_x = _song_btn_x + floor((_song_btn_w-_plw)/2); gfx_y = patbar_y + floor((patbar_h-_plh)/2);
gfx_drawstr("SONG");
(mouse_cap & 1) && !(last_cap & 1) &&
  mouse_x >= _song_btn_x && mouse_x < _song_btn_x + _song_btn_w &&
  mouse_y >= patbar_y && mouse_y < patbar_y + patbar_h ? (
  song_mode = song_mode ? 0 : 1;  // UI view toggle only — playback uses _song_mode_eff
  song_num_parts < 1 ? song_num_parts = 1;
);

// [Dup] Duplicate current pattern to new
num_pats < 16 ? (
  gfx_r = 0.20; gfx_g = 0.20; gfx_b = 0.25; gfx_a = 1;
  gfx_rect(_pb_x, patbar_y, _pb_tab_w, patbar_h);
  gfx_r = COL_CYAN_R; gfx_g = COL_CYAN_G; gfx_b = COL_CYAN_B; gfx_a = 1;
  gfx_setfont(1, "Arial", F_SMALL);
  gfx_measurestr("Dup", _plw, _plh);
  gfx_x = _pb_x + floor((_pb_tab_w - _plw)/2); gfx_y = patbar_y + floor((patbar_h - _plh)/2);
  gfx_drawstr("Dup");
  (mouse_cap & 1) && !(last_cap & 1) &&
    mouse_x >= _pb_x && mouse_x < _pb_x + _pb_tab_w &&
    mouse_y >= patbar_y && mouse_y < patbar_y + patbar_h ? (
    pat_save(current_pat);
    _dup_src = PAT_BASE + current_pat * PAT_SIZE;
    _dup_dst = PAT_BASE + num_pats * PAT_SIZE;
    _di = 0; loop(PAT_SIZE, _dup_dst[_di] = _dup_src[_di]; _di+=1);
    current_pat = num_pats;
    num_pats += 1;
    pat_load(current_pat);
    slider7 = 1; edit_override = 0;
  );
);

gfx_a = 1.0;

_is_player = (hm_role == 2);

// ============================================================================
//  TIMELINE — Variable-width steps with duration controls
// ============================================================================
timeline_y = patbar_y + patbar_h + floor(4 * S);
timeline_h = floor(52 * S);
num_steps = max(1, slider3);

// Compute total bar width units
_total_dur = 0;
_si = 0;
loop(num_steps,
  _dur = max(1, CHORD_BARS[_si]);
  _total_dur += _dur;
  _si += 1;
);
_total_dur = max(1, _total_dur);
_px_per_bar = (gfx_w - margin * 2 - floor(50 * S)) / _total_dur;  // leave room for [+] button

// Delete key: clear chord from selected step
char == 6579564 ? (
  _del_eb = max(0, slider7 - 1);
  CHORD_SLOTS[_del_eb * 2] = 0;
  CHORD_SLOTS[_del_eb * 2 + 1] = 0;
  CHORD_FILLED[_del_eb] = 0;
  conn_dirty = 1;
);

gfx_setfont(1, "Arial", F_SMALL);
_bx_acc = margin;
bi = 0;
loop(num_steps,
  _dur = max(1, CHORD_BARS[bi]);
  _cell_w = floor(_px_per_bar * _dur);
  _cell_w = max(floor(30 * S), _cell_w);
  bx = _bx_acc;
  by = timeline_y;
  _is_cur = (bi == _gfx_cur_step && _gfx_transport);
  _is_edit = (bi == (slider7 - 1));
  _has_chord = CHORD_FILLED[bi];

  // Background
  _is_cur ? (
    gfx_r = COL_ACCENT_R * 0.3; gfx_g = COL_ACCENT_G * 0.3; gfx_b = COL_ACCENT_B * 0.3;
  ) : _has_chord ? (
    gfx_r = COL_PANEL_HI_R; gfx_g = COL_PANEL_HI_G; gfx_b = COL_PANEL_HI_B;
  ) : (
    gfx_r = COL_PANEL_R; gfx_g = COL_PANEL_G; gfx_b = COL_PANEL_B;
  );
  gfx_rect(bx, by, _cell_w - 2, timeline_h);

  // Drag: source highlight
  drag_src == bi && (mouse_cap & 1) ? (
    gfx_r = COL_ACCENT_R * 0.3; gfx_g = COL_ACCENT_G * 0.15; gfx_b = 0; gfx_a = 0.4;
    gfx_rect(bx, by, _cell_w - 2, timeline_h); gfx_a = 1;
  );
  // Drag: destination highlight
  drag_src >= 0 && drag_src != bi && drag_dst == bi && (mouse_cap & 1) ? (
    gfx_r = 0.10; gfx_g = 0.40; gfx_b = 0.12; gfx_a = 0.35;
    gfx_rect(bx, by, _cell_w - 2, timeline_h); gfx_a = 1;
    gfx_r = 0.25; gfx_g = 0.85; gfx_b = 0.35;
    gfx_rect(bx, by, _cell_w - 2, 2);
    gfx_rect(bx, by + timeline_h - 2, _cell_w - 2, 2);
    gfx_rect(bx, by, 2, timeline_h);
    gfx_rect(bx + _cell_w - 4, by, 2, timeline_h);
  );

  // Green mod tint
  CHORD_MOD_STEP[bi] ? (
    gfx_r = 0.10; gfx_g = 0.35; gfx_b = 0.12; gfx_a = 0.3;
    gfx_rect(bx, by, _cell_w - 2, timeline_h);
    gfx_a = 1;
  );

  // Edit highlight border
  _is_edit ? (
    gfx_r = COL_ACCENT_R; gfx_g = COL_ACCENT_G; gfx_b = COL_ACCENT_B;
    gfx_rect(bx, by, _cell_w - 2, 2);
    gfx_rect(bx, by + timeline_h - 2, _cell_w - 2, 2);
    gfx_rect(bx, by, 2, timeline_h);
    gfx_rect(bx + _cell_w - 4, by, 2, timeline_h);
  );

  // Step number + M mod button + duration
  gfx_setfont(1, "Arial", F_TINY);
  gfx_x = bx + floor(3 * S); gfx_y = by + floor(2 * S);
  gfx_r = COL_DIM_R; gfx_g = COL_DIM_G; gfx_b = COL_DIM_B;
  gfx_drawnumber(bi + 1, 0);
  // M mod button (right after step number)
  _mbx = gfx_x + floor(2*S); _mby = by + floor(1*S);
  _mbw = floor(10*S); _mbh = floor(10*S);
  CHORD_MOD_STEP[bi] ? (gfx_r = 0.15; gfx_g = 0.50; gfx_b = 0.20;) : (gfx_r = 0.10; gfx_g = 0.10; gfx_b = 0.13;);
  gfx_rect(_mbx, _mby, _mbw, _mbh);
  CHORD_MOD_STEP[bi] ? (gfx_r = 0.40; gfx_g = 1.00; gfx_b = 0.50;) : (gfx_r = 0.22; gfx_g = 0.22; gfx_b = 0.27;);
  gfx_measurestr("M", _tw, _th);
  gfx_x = _mbx + (_mbw - _tw)/2; gfx_y = _mby + (_mbh - _th)/2;
  gfx_drawstr("M");
  (mouse_cap & 1) && !(last_cap & 1) &&
    mouse_x >= _mbx && mouse_x < _mbx + _mbw &&
    mouse_y >= _mby && mouse_y < _mby + _mbh ? (
    CHORD_MOD_STEP[bi] = 1 - CHORD_MOD_STEP[bi];
  );
  // Duration indicator (top-right)
  gfx_setfont(1, "Arial", F_TINY);
  gfx_x = bx + _cell_w - floor(30 * S); gfx_y = by + floor(2 * S);
  gfx_r = COL_DIM_R * 0.7; gfx_g = COL_DIM_G * 0.7; gfx_b = COL_DIM_B * 0.7;
  gfx_drawnumber(_dur, 0);
  gfx_drawstr("b");

  // Subdivision pattern (bottom) — clickable ticks
  _sdv = max(1, CHORD_SUBDIV[bi]);
  _sdv < 1 ? _sdv = 1;
  // Initialize pattern to all-on only if subdivision was JUST set (not every frame)
  // CHORD_PATTERN stays as-is once set by scroll wheel handler

  _tick_y = by + timeline_h - floor(12 * S);
  _tick_h = floor(10 * S);
  _sdv > 1 ? (
    // Find which tick was ctrl+clicked
    _clicked_tick = -1;
    (mouse_cap & 1) && !(last_cap & 1) && (mouse_cap & 4) &&
      mouse_y >= _tick_y && mouse_y < _tick_y + _tick_h &&
      mouse_x >= bx && mouse_x < bx + _cell_w ? (
      _rel_x = mouse_x - bx - 2;
      _rel_x >= 0 ? (
        _clicked_tick = floor(_rel_x * _sdv / max(1, _cell_w - 4));
        _clicked_tick = max(0, min(_sdv - 1, _clicked_tick));
      );
    );

    // Toggle: flip 0↔1
    _clicked_tick >= 0 ? (
      CHORD_PATTERN[bi*16 + _clicked_tick] = 1 - CHORD_PATTERN[bi*16 + _clicked_tick];
    );

    // Shift+click tick: toggle mod flag
    (mouse_cap & 1) && !(last_cap & 1) && (mouse_cap & 8) &&
      mouse_y >= _tick_y && mouse_y < _tick_y + _tick_h &&
      mouse_x >= bx && mouse_x < bx + _cell_w ? (
      _rel_x = mouse_x - bx - 2;
      _rel_x >= 0 ? (
        _stk = floor(_rel_x * _sdv / max(1, _cell_w - 4));
        _stk = max(0, min(_sdv - 1, _stk));
        CHORD_MOD_TICK[bi*16 + _stk] = 1 - CHORD_MOD_TICK[bi*16 + _stk];
      );
    );

    // Draw ticks
    _tk = 0;
    loop(_sdv,
      _tick_w = max(floor(4 * S), floor((_cell_w - 6) / _sdv - 1));
      _tx = bx + 2 + floor((_cell_w - 4) * _tk / _sdv);
      _bit_on = CHORD_PATTERN[bi*16 + _tk];

      _bit_on ? (
        CHORD_MOD_TICK[bi*16 + _tk] ? (
          gfx_r = 0.25; gfx_g = 0.80; gfx_b = 0.35;
        ) : (
          gfx_r = COL_CYAN_R; gfx_g = COL_CYAN_G; gfx_b = COL_CYAN_B;
        );
      ) : (
        CHORD_MOD_TICK[bi*16 + _tk] ? (
          gfx_r = 0.05; gfx_g = 0.18; gfx_b = 0.07;
        ) : (
          gfx_r = 0.10; gfx_g = 0.10; gfx_b = 0.14;
        );
      );
      gfx_rect(_tx, _tick_y, _tick_w, _tick_h);

      gfx_r = COL_BORDER_R; gfx_g = COL_BORDER_G; gfx_b = COL_BORDER_B;
      gfx_rect(_tx, _tick_y, _tick_w, 1);
      gfx_rect(_tx, _tick_y + _tick_h - 1, _tick_w, 1);

      bi == _gfx_cur_step && _tk == _gfx_cur_sub && _gfx_transport ? (
        gfx_r = 1; gfx_g = 1; gfx_b = 1; gfx_a = 0.3;
        gfx_rect(_tx, _tick_y, _tick_w, _tick_h);
        gfx_a = 1;
      );

      _tk += 1;
    );
  ) : (
    gfx_x = bx + floor(3 * S); gfx_y = _tick_y + floor(1 * S);
    gfx_r = COL_DIM_R * 0.4; gfx_g = COL_DIM_G * 0.4; gfx_b = COL_DIM_B * 0.4;
    gfx_setfont(1, "Arial", F_TINY);
    gfx_drawstr("hold");
  );

  // Chord name
  _has_chord ? (
    _cr = CHORD_SLOTS[bi * 2];
    _cq = CHORD_SLOTS[bi * 2 + 1];
    gfx_x = bx + floor(3 * S); gfx_y = by + floor(14 * S);
    _cq == 0 || _cq == 2 || _cq == 4 || _cq == 9 || _cq == 14 ? (
      gfx_r = 0.90; gfx_g = 0.50; gfx_b = 0.55;
    ) : _cq == 1 || _cq == 3 || _cq == 8 || _cq == 12 ? (
      gfx_r = 0.35; gfx_g = 0.55; gfx_b = 0.85;
    ) : _cq == 5 || _cq == 7 ? (
      gfx_r = 0.65; gfx_g = 0.40; gfx_b = 0.75;
    ) : (
      gfx_r = 0.90; gfx_g = 0.80; gfx_b = 0.30;
    );
    gfx_setfont(1, "Arial", F_CHORD);
    _cr==0?gfx_drawstr("C"):_cr==1?gfx_drawstr("C#"):_cr==2?gfx_drawstr("D"):_cr==3?gfx_drawstr("Eb"):_cr==4?gfx_drawstr("E"):_cr==5?gfx_drawstr("F"):_cr==6?gfx_drawstr("F#"):_cr==7?gfx_drawstr("G"):_cr==8?gfx_drawstr("Ab"):_cr==9?gfx_drawstr("A"):_cr==10?gfx_drawstr("Bb"):gfx_drawstr("B");
    _cq==0?0:_cq==1?gfx_drawstr("m"):_cq==2?gfx_drawstr("M7"):_cq==3?gfx_drawstr("m7"):_cq==4?gfx_drawstr("7"):_cq==5?gfx_drawstr("dim"):_cq==6?gfx_drawstr("+"):_cq==7?gfx_drawstr("o7"):gfx_drawstr("m7");
  ) : (
    gfx_x = bx + floor(3 * S); gfx_y = by + floor(16 * S);
    gfx_r = COL_DIM_R * 0.5; gfx_g = COL_DIM_G * 0.5; gfx_b = COL_DIM_B * 0.5;
    gfx_setfont(1, "Arial", F_CHORD);
    gfx_drawstr("--");
  );

  // Shift+left-click (sdv=1): toggle step mod flag
  _sdv <= 1 && (mouse_cap & 1) && !(last_cap & 1) && (mouse_cap & 8) &&
    mouse_x >= bx && mouse_x < bx + _cell_w - 2 &&
    mouse_y >= by && mouse_y < by + timeline_h ? (
    CHORD_MOD_STEP[bi] = 1 - CHORD_MOD_STEP[bi];
  );

  // Left-click (no ctrl): select step — but not if clicking ticks
  (mouse_cap & 1) && !(last_cap & 1) && !(mouse_cap & 4) &&
    mouse_x >= bx && mouse_x < bx + _cell_w - 2 &&
    mouse_y >= by && mouse_y < by + timeline_h ? (
    slider7 = bi + 1;
    edit_override = 1;
    conn_dirty = 1;
  );

  // Right-click (no ctrl): open velocity editor
  (mouse_cap & 2) && !(last_cap & 2) && !(mouse_cap & 4) &&
    mouse_x >= bx && mouse_x < bx + _cell_w - 2 &&
    mouse_y >= by && mouse_y < by + timeline_h ? (
    vel_edit_open = 1;
    vel_edit_step = bi;
    vel_edit_x = min(mouse_x, gfx_w - 55);
    vel_edit_y = max(0, min(mouse_y - 70, gfx_h - 145));
    vel_edit_dragging = 0;
  );

  // Ctrl+right-click: DELETE step (blocked for players)
  !_is_player && (mouse_cap & 2) && !(last_cap & 2) && (mouse_cap & 4) &&
    mouse_x >= bx && mouse_x < bx + _cell_w - 2 &&
    mouse_y >= by && mouse_y < by + timeline_h &&
    num_steps > 1 ? (
    // Shift all steps after bi up by one
    _si = bi;
    loop(num_steps - bi - 1,
      CHORD_SLOTS[_si*2] = CHORD_SLOTS[(_si+1)*2];
      CHORD_SLOTS[_si*2+1] = CHORD_SLOTS[(_si+1)*2+1];
      CHORD_FILLED[_si] = CHORD_FILLED[_si+1];
      CHORD_BARS[_si] = CHORD_BARS[_si+1];
      CHORD_SUBDIV[_si] = CHORD_SUBDIV[_si+1];
      CHORD_VEL[_si] = CHORD_VEL[_si+1];
      CHORD_MOD_STEP[_si] = CHORD_MOD_STEP[_si+1];
      CHORD_MOD_SUS[_si]  = CHORD_MOD_SUS[_si+1];
      CHORD_MOD_ADD9[_si] = CHORD_MOD_ADD9[_si+1];
      CHORD_MOD_ADD7[_si] = CHORD_MOD_ADD7[_si+1];
      CHORD_MOD_DOM7[_si] = CHORD_MOD_DOM7[_si+1];
      CHORD_MOD_ADD6[_si] = CHORD_MOD_ADD6[_si+1];
      CHORD_MOD_INV[_si]  = CHORD_MOD_INV[_si+1];
      _ti = 0;
      loop(16,
        CHORD_PATTERN[_si*16+_ti] = CHORD_PATTERN[(_si+1)*16+_ti];
        CHORD_MOD_TICK[_si*16+_ti] = CHORD_MOD_TICK[(_si+1)*16+_ti];
        _ti += 1;
      );
      _si += 1;
    );
    // Clear the last slot
    CHORD_SLOTS[_si*2] = 0;
    CHORD_SLOTS[_si*2+1] = 0;
    CHORD_FILLED[_si] = 0;
    CHORD_BARS[_si] = 0;
    CHORD_SUBDIV[_si] = 0;
    CHORD_MOD_STEP[_si] = 0;
    CHORD_MOD_SUS[_si]  = 0;
    CHORD_MOD_ADD9[_si] = 0;
    CHORD_MOD_ADD7[_si] = 0;
    CHORD_MOD_DOM7[_si] = 0;
    CHORD_MOD_ADD6[_si] = 0;
    CHORD_MOD_INV[_si]  = 0;
    _ti = 0;
    loop(16, CHORD_PATTERN[_si*16+_ti] = 0; CHORD_MOD_TICK[_si*16+_ti] = 0; _ti += 1);
    slider3 -= 1;
    slider7 > slider3 ? slider7 = slider3;
    conn_dirty = 1;
  );

  // Mouse wheel: top half = duration (blocked for players), bottom half = subdivision (all can edit)
  mouse_wheel != 0 &&
    mouse_x >= bx && mouse_x < bx + _cell_w - 2 &&
    mouse_y >= by && mouse_y < by + timeline_h ? (
    mouse_y < by + timeline_h / 2 ? (
      // Top half: adjust bar duration (conductor/standalone only)
      !_is_player ? (
        mouse_wheel > 0 ? (
          CHORD_BARS[bi] = min(8, max(1, CHORD_BARS[bi]) + 1);
        ) : (
          CHORD_BARS[bi] = max(1, CHORD_BARS[bi] - 1);
        );
      );
    ) : (
      // Bottom half: adjust subdivision (everyone can edit)
      _sdv = max(1, CHORD_SUBDIV[bi]);
      mouse_wheel > 0 ? (
        _sdv == 1 ? _sdv = 2 : _sdv == 2 ? _sdv = 4 : _sdv == 4 ? _sdv = 8 : _sdv == 8 ? _sdv = 16 : _sdv = 16;
      ) : (
        _sdv == 16 ? _sdv = 8 : _sdv == 8 ? _sdv = 4 : _sdv == 4 ? _sdv = 2 : _sdv = 1;
      );
      CHORD_SUBDIV[bi] = _sdv;
      // Reset pattern to all-on when subdivision changes
      _ri = 0;
      loop(16, CHORD_PATTERN[bi*16 + _ri] = _ri < _sdv ? 1 : 0; _ri += 1);
    );
    mouse_wheel = 0;
  );

  // Start drag (plain left-click, no modifier)
  (mouse_cap & 1) && !(last_cap & 1) && !(mouse_cap & 4) && !(mouse_cap & 8) &&
    mouse_x >= bx && mouse_x < bx + _cell_w - 2 &&
    mouse_y >= by && mouse_y < by + timeline_h ? (
    drag_src = bi; drag_dst = bi;
  );
  // Track destination while dragging
  (mouse_cap & 1) && drag_src >= 0 &&
    mouse_x >= bx && mouse_x < bx + _cell_w - 2 &&
    mouse_y >= by && mouse_y < by + timeline_h ? (
    drag_dst = bi;
  );
  // Copy on release over a different cell
  !(mouse_cap & 1) && (last_cap & 1) && drag_src >= 0 && drag_src != bi &&
    mouse_x >= bx && mouse_x < bx + _cell_w - 2 &&
    mouse_y >= by && mouse_y < by + timeline_h ? (
    CHORD_SLOTS[bi*2]   = CHORD_SLOTS[drag_src*2];
    CHORD_SLOTS[bi*2+1] = CHORD_SLOTS[drag_src*2+1];
    CHORD_FILLED[bi]    = CHORD_FILLED[drag_src];
    CHORD_BARS[bi]      = CHORD_BARS[drag_src];
    CHORD_SUBDIV[bi]    = CHORD_SUBDIV[drag_src];
    CHORD_VEL[bi]       = CHORD_VEL[drag_src];
    CHORD_MOD_STEP[bi]  = CHORD_MOD_STEP[drag_src];
    CHORD_MOD_SUS[bi]   = CHORD_MOD_SUS[drag_src];
    CHORD_MOD_ADD9[bi]  = CHORD_MOD_ADD9[drag_src];
    CHORD_MOD_ADD7[bi]  = CHORD_MOD_ADD7[drag_src];
    CHORD_MOD_DOM7[bi]  = CHORD_MOD_DOM7[drag_src];
    CHORD_MOD_ADD6[bi]  = CHORD_MOD_ADD6[drag_src];
    CHORD_MOD_INV[bi]   = CHORD_MOD_INV[drag_src];
    _ti = 0;
    loop(16,
      CHORD_PATTERN[bi*16+_ti]  = CHORD_PATTERN[drag_src*16+_ti];
      CHORD_MOD_TICK[bi*16+_ti] = CHORD_MOD_TICK[drag_src*16+_ti];
      _ti += 1;
    );
    conn_dirty = 1;
    drag_src = -1; drag_dst = -1;
  );

  _bx_acc += _cell_w;
  bi += 1;
);

// Reset drag state when mouse released outside any timeline cell
!(mouse_cap & 1) && (last_cap & 1) && drag_src >= 0 ? (drag_src = -1; drag_dst = -1;);

// [+] Add step button (hidden for players)
_btn_w = floor(24 * S);
_add_x = _bx_acc + floor(4 * S);
!_is_player ? (
gfx_r = COL_GREEN_R * 0.3; gfx_g = COL_GREEN_G * 0.3; gfx_b = COL_GREEN_B * 0.3;
gfx_rect(_add_x, timeline_y, _btn_w, timeline_h);
gfx_r = COL_GREEN_R; gfx_g = COL_GREEN_G; gfx_b = COL_GREEN_B;
gfx_setfont(1, "Arial", max(12, floor(20 * S)));
gfx_x = _add_x + floor(6 * S); gfx_y = timeline_y + floor(12 * S);
gfx_drawstr("+");
);
!_is_player && (mouse_cap & 1) && !(last_cap & 1) &&
  mouse_x >= _add_x && mouse_x < _add_x + _btn_w &&
  mouse_y >= timeline_y && mouse_y < timeline_y + timeline_h ? (
  slider3 < 32 ? (
    slider3 += 1;
    CHORD_BARS[slider3 - 1] = 1;
    _ri = 0; loop(16, CHORD_PATTERN[(slider3-1)*16+_ri] = 1; _ri += 1);
    slider7 = slider3;
    edit_override = 1;
    conn_dirty = 1;
  );
);

// [-] Remove last step button (hidden for players)
_rem_x = _add_x + _btn_w + floor(2 * S);
!_is_player ? (
gfx_r = COL_ACCENT_R * 0.3; gfx_g = 0.1; gfx_b = 0.1;
gfx_rect(_rem_x, timeline_y, _btn_w, timeline_h);
gfx_r = COL_ACCENT_R; gfx_g = 0.3; gfx_b = 0.3;
gfx_setfont(1, "Arial", max(12, floor(20 * S)));
gfx_x = _rem_x + floor(7 * S); gfx_y = timeline_y + floor(12 * S);
gfx_drawstr("-");
);
!_is_player && (mouse_cap & 1) && !(last_cap & 1) &&
  mouse_x >= _rem_x && mouse_x < _rem_x + _btn_w &&
  mouse_y >= timeline_y && mouse_y < timeline_y + timeline_h ? (
  slider3 > 1 ? (
    // Clear the last step
    _li = slider3 - 1;
    CHORD_SLOTS[_li*2] = 0;
    CHORD_SLOTS[_li*2+1] = 0;
    CHORD_FILLED[_li] = 0;
    CHORD_BARS[_li] = 0;
    CHORD_SUBDIV[_li] = 0;
    CHORD_MOD_STEP[_li] = 0;
    CHORD_MOD_SUS[_li]  = 0;
    CHORD_MOD_ADD9[_li] = 0;
    CHORD_MOD_ADD7[_li] = 0;
    CHORD_MOD_DOM7[_li] = 0;
    CHORD_MOD_ADD6[_li] = 0;
    CHORD_MOD_INV[_li]  = 0;
    _ri = 0; loop(16, CHORD_PATTERN[_li*16+_ri] = 0; CHORD_MOD_TICK[_li*16+_ri] = 0; _ri += 1);
    slider3 -= 1;
    slider7 > slider3 ? slider7 = slider3;
    conn_dirty = 1;
  );
);

// ============================================================================
//  VELOCITY EDITOR POPUP
// ============================================================================
vel_edit_open ? (
  _ve_vel = CHORD_VEL[vel_edit_step]; _ve_vel <= 0 ? _ve_vel = 100;

  // Background + border
  gfx_r = 0.10; gfx_g = 0.10; gfx_b = 0.14; gfx_a = 0.95;
  gfx_rect(vel_edit_x, vel_edit_y, 50, 140);
  gfx_a = 1;
  gfx_r = COL_BORDER_R; gfx_g = COL_BORDER_G; gfx_b = COL_BORDER_B;
  gfx_rect(vel_edit_x, vel_edit_y, 50, 1);
  gfx_rect(vel_edit_x, vel_edit_y + 139, 50, 1);
  gfx_rect(vel_edit_x, vel_edit_y, 1, 140);
  gfx_rect(vel_edit_x + 49, vel_edit_y, 1, 140);

  // Numeric label
  gfx_setfont(1, "Arial", F_SMALL);
  gfx_r = COL_TEXT_R; gfx_g = COL_TEXT_G; gfx_b = COL_TEXT_B;
  gfx_x = vel_edit_x + 5; gfx_y = vel_edit_y + 4;
  gfx_drawstr("v:");
  gfx_drawnumber(_ve_vel, 0);

  // Vertical slider
  _vs_x = vel_edit_x + 10;
  _vs_y = vel_edit_y + 22;
  _vs_w = 30;
  _vs_h = 110;

  gfx_r = 0.15; gfx_g = 0.15; gfx_b = 0.20;
  gfx_rect(_vs_x, _vs_y, _vs_w, _vs_h);

  // Fill bar (bottom-up)
  _fill_h = floor(_vs_h * _ve_vel / 127);
  gfx_r = COL_CYAN_R; gfx_g = COL_CYAN_G; gfx_b = COL_CYAN_B;
  gfx_rect(_vs_x, _vs_y + _vs_h - _fill_h, _vs_w, _fill_h);

  // Drag interaction
  mouse_cap & 1 ? (
    mouse_x >= _vs_x - 5 && mouse_x < _vs_x + _vs_w + 5 &&
    mouse_y >= _vs_y - 5 && mouse_y < _vs_y + _vs_h + 5 ? (
      vel_edit_dragging = 1;
    );
    vel_edit_dragging ? (
      _new_vel = floor((_vs_y + _vs_h - mouse_y) / _vs_h * 127 + 0.5);
      CHORD_VEL[vel_edit_step] = max(1, min(127, _new_vel));
    );
  ) : (
    vel_edit_dragging = 0;
  );

  // Close on left-click outside popup
  mouse_cap & 1 && !(last_cap & 1) && !vel_edit_dragging ? (
    !(mouse_x >= vel_edit_x && mouse_x < vel_edit_x + 50 &&
      mouse_y >= vel_edit_y && mouse_y < vel_edit_y + 140) ? (
      vel_edit_open = 0;
    );
  );

  // Close on right-click outside timeline
  mouse_cap & 2 && !(last_cap & 2) ? (
    !(mouse_y >= timeline_y && mouse_y < timeline_y + timeline_h) ? (
      vel_edit_open = 0;
    );
  );
);


// ============================================================================
//  HARMONY MAP — Fixed circle of fifths, always visible, connections overlay
// ============================================================================
mod_panel_h = floor(28 * S);
mod_panel_y = timeline_y + timeline_h + floor(4 * S);
map_y = mod_panel_y + mod_panel_h + floor(4 * S);

// ---- Mod Panel ----
gfx_r = COL_PANEL_R; gfx_g = COL_PANEL_G; gfx_b = COL_PANEL_B;
gfx_rect(margin, mod_panel_y, gfx_w - margin*2, mod_panel_h);

_mbtn_y = mod_panel_y + floor(4*S);
_mbtn_h = mod_panel_h - floor(8*S);

// Per-step mod controls for currently selected step
_eb_mod = max(0, slider7 - 1);
_mbx2 = margin + floor(4*S);
_mod_btn_w = floor(36*S);

// "Step N:" label
gfx_setfont(1, "Arial", F_TINY);
gfx_r = COL_DIM_R; gfx_g = COL_DIM_G; gfx_b = COL_DIM_B;
gfx_x = _mbx2; gfx_y = _mbtn_y + floor(3*S);
gfx_drawstr("Step "); gfx_drawnumber(_eb_mod + 1, 0); gfx_drawstr(":");
gfx_measurestr("Step 99:", _tw, _th);
_mbx2 += _tw + floor(6*S);

// SUS button
CHORD_MOD_SUS[_eb_mod] ? (gfx_r = 0.15; gfx_g = 0.40; gfx_b = 0.60;) : (gfx_r = 0.12; gfx_g = 0.12; gfx_b = 0.15;);
gfx_rect(_mbx2, _mbtn_y, _mod_btn_w, _mbtn_h);
CHORD_MOD_SUS[_eb_mod] ? (gfx_r = 0.50; gfx_g = 0.85; gfx_b = 1.00;) : (gfx_r = COL_DIM_R; gfx_g = COL_DIM_G; gfx_b = COL_DIM_B;);
gfx_setfont(1, "Arial", F_SMALL); gfx_measurestr("SUS", _tw, _th);
gfx_x = _mbx2 + (_mod_btn_w - _tw)/2; gfx_y = _mbtn_y + (_mbtn_h - _th)/2; gfx_drawstr("SUS");
(mouse_cap & 1) && !(last_cap & 1) &&
  mouse_x >= _mbx2 && mouse_x < _mbx2 + _mod_btn_w &&
  mouse_y >= _mbtn_y && mouse_y < _mbtn_y + _mbtn_h ? CHORD_MOD_SUS[_eb_mod] = 1 - CHORD_MOD_SUS[_eb_mod];
_mbx2 += _mod_btn_w + floor(4*S);

// 9th button
CHORD_MOD_ADD9[_eb_mod] ? (gfx_r = 0.15; gfx_g = 0.40; gfx_b = 0.60;) : (gfx_r = 0.12; gfx_g = 0.12; gfx_b = 0.15;);
gfx_rect(_mbx2, _mbtn_y, _mod_btn_w, _mbtn_h);
CHORD_MOD_ADD9[_eb_mod] ? (gfx_r = 0.50; gfx_g = 0.85; gfx_b = 1.00;) : (gfx_r = COL_DIM_R; gfx_g = COL_DIM_G; gfx_b = COL_DIM_B;);
gfx_measurestr("9th", _tw, _th);
gfx_x = _mbx2 + (_mod_btn_w - _tw)/2; gfx_y = _mbtn_y + (_mbtn_h - _th)/2; gfx_drawstr("9th");
(mouse_cap & 1) && !(last_cap & 1) &&
  mouse_x >= _mbx2 && mouse_x < _mbx2 + _mod_btn_w &&
  mouse_y >= _mbtn_y && mouse_y < _mbtn_y + _mbtn_h ? CHORD_MOD_ADD9[_eb_mod] = 1 - CHORD_MOD_ADD9[_eb_mod];
_mbx2 += _mod_btn_w + floor(4*S);

// 7th button
CHORD_MOD_ADD7[_eb_mod] ? (gfx_r = 0.15; gfx_g = 0.40; gfx_b = 0.60;) : (gfx_r = 0.12; gfx_g = 0.12; gfx_b = 0.15;);
gfx_rect(_mbx2, _mbtn_y, _mod_btn_w, _mbtn_h);
CHORD_MOD_ADD7[_eb_mod] ? (gfx_r = 0.50; gfx_g = 0.85; gfx_b = 1.00;) : (gfx_r = COL_DIM_R; gfx_g = COL_DIM_G; gfx_b = COL_DIM_B;);
gfx_measurestr("7th", _tw, _th);
gfx_x = _mbx2 + (_mod_btn_w - _tw)/2; gfx_y = _mbtn_y + (_mbtn_h - _th)/2; gfx_drawstr("7th");
(mouse_cap & 1) && !(last_cap & 1) &&
  mouse_x >= _mbx2 && mouse_x < _mbx2 + _mod_btn_w &&
  mouse_y >= _mbtn_y && mouse_y < _mbtn_y + _mbtn_h ? CHORD_MOD_ADD7[_eb_mod] = 1 - CHORD_MOD_ADD7[_eb_mod];
_mbx2 += _mod_btn_w + floor(4*S);

// b7 button (dominant/flat 7th)
CHORD_MOD_DOM7[_eb_mod] ? (gfx_r = 0.15; gfx_g = 0.40; gfx_b = 0.60;) : (gfx_r = 0.12; gfx_g = 0.12; gfx_b = 0.15;);
gfx_rect(_mbx2, _mbtn_y, _mod_btn_w, _mbtn_h);
CHORD_MOD_DOM7[_eb_mod] ? (gfx_r = 0.50; gfx_g = 0.85; gfx_b = 1.00;) : (gfx_r = COL_DIM_R; gfx_g = COL_DIM_G; gfx_b = COL_DIM_B;);
gfx_setfont(1, "Arial", F_SMALL); gfx_measurestr("b7", _tw, _th);
gfx_x = _mbx2 + (_mod_btn_w - _tw)/2; gfx_y = _mbtn_y + (_mbtn_h - _th)/2; gfx_drawstr("b7");
(mouse_cap & 1) && !(last_cap & 1) &&
  mouse_x >= _mbx2 && mouse_x < _mbx2 + _mod_btn_w &&
  mouse_y >= _mbtn_y && mouse_y < _mbtn_y + _mbtn_h ? CHORD_MOD_DOM7[_eb_mod] = 1 - CHORD_MOD_DOM7[_eb_mod];
_mbx2 += _mod_btn_w + floor(4*S);

// 6th button
CHORD_MOD_ADD6[_eb_mod] ? (gfx_r = 0.15; gfx_g = 0.40; gfx_b = 0.60;) : (gfx_r = 0.12; gfx_g = 0.12; gfx_b = 0.15;);
gfx_rect(_mbx2, _mbtn_y, _mod_btn_w, _mbtn_h);
CHORD_MOD_ADD6[_eb_mod] ? (gfx_r = 0.50; gfx_g = 0.85; gfx_b = 1.00;) : (gfx_r = COL_DIM_R; gfx_g = COL_DIM_G; gfx_b = COL_DIM_B;);
gfx_setfont(1, "Arial", F_SMALL); gfx_measurestr("6th", _tw, _th);
gfx_x = _mbx2 + (_mod_btn_w - _tw)/2; gfx_y = _mbtn_y + (_mbtn_h - _th)/2; gfx_drawstr("6th");
(mouse_cap & 1) && !(last_cap & 1) &&
  mouse_x >= _mbx2 && mouse_x < _mbx2 + _mod_btn_w &&
  mouse_y >= _mbtn_y && mouse_y < _mbtn_y + _mbtn_h ? CHORD_MOD_ADD6[_eb_mod] = 1 - CHORD_MOD_ADD6[_eb_mod];
_mbx2 += _mod_btn_w + floor(4*S);

// INV button (cycles 1→2→3→4→5→1)
_inv_val = CHORD_MOD_INV[_eb_mod]; _inv_val <= 0 ? _inv_val = 1;
_inv_btn_w = floor(52*S);
_inv_val > 1 ? (gfx_r = 0.15; gfx_g = 0.40; gfx_b = 0.60;) : (gfx_r = 0.12; gfx_g = 0.12; gfx_b = 0.15;);
gfx_rect(_mbx2, _mbtn_y, _inv_btn_w, _mbtn_h);
_inv_val > 1 ? (gfx_r = 0.50; gfx_g = 0.85; gfx_b = 1.00;) : (gfx_r = COL_DIM_R; gfx_g = COL_DIM_G; gfx_b = COL_DIM_B;);
gfx_x = _mbx2 + floor(4*S); gfx_y = _mbtn_y + (_mbtn_h - _th)/2;
gfx_drawstr("INV:"); gfx_drawnumber(_inv_val, 0);
(mouse_cap & 1) && !(last_cap & 1) &&
  mouse_x >= _mbx2 && mouse_x < _mbx2 + _inv_btn_w &&
  mouse_y >= _mbtn_y && mouse_y < _mbtn_y + _mbtn_h ? (
  CHORD_MOD_INV[_eb_mod] = _inv_val % 5 + 1;
);

song_mode ? (
// ============================================================================
//  SONG MODE UI — Parts Editor + Song Sequence
// ============================================================================
_sg_y = map_y;
_sg_w = gfx_w - margin * 2;

// Pre-paint entire song mode area to prevent stale pixel flashing
gfx_r = COL_BG_R; gfx_g = COL_BG_G; gfx_b = COL_BG_B; gfx_a = 1;
gfx_rect(0, _sg_y, gfx_w, gfx_h - _sg_y);

// Player banner + interaction lockout
_is_player ? (
  gfx_setfont(1, "Arial", F_LABEL);
  gfx_r = 0.50; gfx_g = 0.80; gfx_b = 1.0;
  gfx_x = margin; gfx_y = _sg_y + floor(2*S);
  conductor_found_id > 0 ? gfx_drawstr("FOLLOWING CONDUCTOR — song structure is locked") : gfx_drawstr("PLAYER MODE — waiting for conductor...");
  // Suppress all mouse clicks in song mode panel for players
  _save_mcap = mouse_cap; _save_lcap = last_cap; _save_mwheel = mouse_wheel;
  mouse_cap = 0; last_cap = 0; mouse_wheel = 0;
);

// ---- PARTS EDITOR ----
_sg_row_h = floor(22 * S);
_sg_hdr_h = floor(18 * S);
_sg_parts_h = _sg_hdr_h + song_num_parts * _sg_row_h + floor(26 * S);  // header + rows + buttons

// Column widths
_sg_num_w   = floor(22 * S);    // #
_sg_cat_w   = floor(68 * S);    // Category
_sg_pnum_w  = floor(28 * S);    // Num
_sg_pat_w   = floor(42 * S);    // Pattern
_sg_rep_w   = floor(38 * S);    // Repeats
_sg_key_w   = floor(36 * S);    // Mod key
_sg_mode_w  = floor(38 * S);    // Mod mode
_sg_vel_w   = floor(36 * S);    // Mod vel
_sg_arp_w   = floor(36 * S);    // Arp mode
_sg_oct_w   = floor(36 * S);    // Octave
_sg_col_gap = floor(2 * S);

// Header row
gfx_setfont(1, "Arial", F_TINY);
gfx_r = COL_DIM_R; gfx_g = COL_DIM_G; gfx_b = COL_DIM_B;
_hx = margin;
gfx_x = _hx; gfx_y = _sg_y + floor(3*S); gfx_drawstr("#"); _hx += _sg_num_w;
gfx_x = _hx; gfx_drawstr("Type"); _hx += _sg_cat_w + _sg_col_gap;
gfx_x = _hx; gfx_drawstr("N"); _hx += _sg_pnum_w + _sg_col_gap;
gfx_x = _hx; gfx_drawstr("Pattern"); _hx += _sg_pat_w + _sg_col_gap;
gfx_x = _hx; gfx_drawstr("Rep"); _hx += _sg_rep_w + _sg_col_gap;
gfx_x = _hx; gfx_drawstr("Key"); _hx += _sg_key_w + _sg_col_gap;
gfx_x = _hx; gfx_drawstr("Mode"); _hx += _sg_mode_w + _sg_col_gap;
gfx_x = _hx; gfx_drawstr("Vol"); _hx += _sg_vel_w + _sg_col_gap;
gfx_x = _hx; gfx_drawstr("Arp"); _hx += _sg_arp_w + _sg_col_gap;
gfx_x = _hx; gfx_drawstr("Oct");

// Part rows
_spi = 0;
loop(song_num_parts,
  _spy = _sg_y + _sg_hdr_h + _spi * _sg_row_h;
  _spb = _spi * SONG_PART_SIZE;
  _sp_cat  = SONG_PARTS[_spb + 0];
  _sp_num  = max(1, SONG_PARTS[_spb + 1]);
  _sp_pat  = SONG_PARTS[_spb + 2];
  _sp_rep  = max(1, SONG_PARTS[_spb + 3]);
  _sp_mkey = SONG_PARTS[_spb + 4];
  _sp_mmod = SONG_PARTS[_spb + 5];
  _sp_mvel = SONG_PARTS[_spb + 6];
  _sp_arp  = SONG_PARTS[_spb + 7];
  _sp_oct  = SONG_PART_OCT[_spi];

  // Row background (highlight selected)
  _spi == song_sel_part ? (
    gfx_r = 0.15; gfx_g = 0.12; gfx_b = 0.25;
  ) : (
    gfx_r = COL_PANEL_R; gfx_g = COL_PANEL_G; gfx_b = COL_PANEL_B;
  );
  gfx_a = 1;
  gfx_rect(margin, _spy, _sg_w, _sg_row_h - 1);

  // Click row to select for sequencing
  (mouse_cap & 1) && !(last_cap & 1) &&
    mouse_x >= margin && mouse_x < margin + _sg_w &&
    mouse_y >= _spy && mouse_y < _spy + _sg_row_h ? (
    song_sel_part = _spi;
  );

  gfx_setfont(1, "Arial", F_SMALL);
  _rx = margin;

  // # column
  gfx_r = COL_DIM_R; gfx_g = COL_DIM_G; gfx_b = COL_DIM_B;
  gfx_x = _rx + floor(4*S); gfx_y = _spy + floor(4*S);
  gfx_drawnumber(_spi + 1, 0);
  _rx += _sg_num_w;

  // Category (clickable cycling button)
  _sp_cat == 0 ? (gfx_r=0.20; gfx_g=0.35; gfx_b=0.55;) :  // Verse: blue
  _sp_cat == 1 ? (gfx_r=0.50; gfx_g=0.25; gfx_b=0.20;) :  // Chorus: red
  _sp_cat == 2 ? (gfx_r=0.40; gfx_g=0.30; gfx_b=0.50;) :  // Bridge: purple
  _sp_cat == 3 ? (gfx_r=0.20; gfx_g=0.45; gfx_b=0.25;) :  // Intro: green
                 (gfx_r=0.45; gfx_g=0.35; gfx_b=0.15;);    // Outro: gold
  gfx_rect(_rx, _spy + 1, _sg_cat_w, _sg_row_h - 3);
  gfx_r = 1; gfx_g = 1; gfx_b = 1;
  _sp_cat==0?(_cs="Verse"):_sp_cat==1?(_cs="Chorus"):_sp_cat==2?(_cs="Bridge"):_sp_cat==3?(_cs="Intro"):(_cs="Outro");
  gfx_measurestr(_cs, _tw, _th);
  gfx_x = _rx + floor((_sg_cat_w - _tw)/2); gfx_y = _spy + floor((_sg_row_h - _th)/2);
  gfx_drawstr(_cs);
  (mouse_cap & 1) && !(last_cap & 1) &&
    mouse_x >= _rx && mouse_x < _rx + _sg_cat_w &&
    mouse_y >= _spy && mouse_y < _spy + _sg_row_h ? (
    SONG_PARTS[_spb + 0] = (_sp_cat + 1) % 5;
  );
  (mouse_cap & 2) && !(last_cap & 2) &&
    mouse_x >= _rx && mouse_x < _rx + _sg_cat_w &&
    mouse_y >= _spy && mouse_y < _spy + _sg_row_h ? (
    SONG_PARTS[_spb + 0] = (_sp_cat + 4) % 5;
  );
  _rx += _sg_cat_w + _sg_col_gap;

  // Number (click to cycle 1-8)
  gfx_r = 0.12; gfx_g = 0.12; gfx_b = 0.16;
  gfx_rect(_rx, _spy + 1, _sg_pnum_w, _sg_row_h - 3);
  gfx_r = COL_TEXT_R; gfx_g = COL_TEXT_G; gfx_b = COL_TEXT_B;
  gfx_x = _rx + floor(10*S); gfx_y = _spy + floor(4*S);
  gfx_drawnumber(_sp_num, 0);
  (mouse_cap & 1) && !(last_cap & 1) &&
    mouse_x >= _rx && mouse_x < _rx + _sg_pnum_w &&
    mouse_y >= _spy && mouse_y < _spy + _sg_row_h ? (
    SONG_PARTS[_spb + 1] = _sp_num % 8 + 1;
  );
  (mouse_cap & 2) && !(last_cap & 2) &&
    mouse_x >= _rx && mouse_x < _rx + _sg_pnum_w &&
    mouse_y >= _spy && mouse_y < _spy + _sg_row_h ? (
    SONG_PARTS[_spb + 1] = (_sp_num - 2 + 8) % 8 + 1;
  );
  _rx += _sg_pnum_w + _sg_col_gap;

  // Pattern (click to cycle P1-P16, colored)
  pat_set_color(_sp_pat);
  gfx_r = gfx_r * 0.5; gfx_g = gfx_g * 0.5; gfx_b = gfx_b * 0.5;
  gfx_rect(_rx, _spy + 1, _sg_pat_w, _sg_row_h - 3);
  pat_set_color(_sp_pat);
  _pl = #; sprintf(_pl, "P%d", _sp_pat + 1);
  gfx_measurestr(_pl, _tw, _th);
  gfx_x = _rx + floor((_sg_pat_w - _tw)/2); gfx_y = _spy + floor((_sg_row_h - _th)/2);
  gfx_drawstr(_pl);
  (mouse_cap & 1) && !(last_cap & 1) &&
    mouse_x >= _rx && mouse_x < _rx + _sg_pat_w &&
    mouse_y >= _spy && mouse_y < _spy + _sg_row_h ? (
    SONG_PARTS[_spb + 2] = (_sp_pat + 1) % num_pats;
  );
  (mouse_cap & 2) && !(last_cap & 2) &&
    mouse_x >= _rx && mouse_x < _rx + _sg_pat_w &&
    mouse_y >= _spy && mouse_y < _spy + _sg_row_h ? (
    SONG_PARTS[_spb + 2] = (_sp_pat - 1 + num_pats) % num_pats;
  );
  _rx += _sg_pat_w + _sg_col_gap;

  // Repeats (click to cycle 1-16)
  gfx_r = 0.12; gfx_g = 0.12; gfx_b = 0.16;
  gfx_rect(_rx, _spy + 1, _sg_rep_w, _sg_row_h - 3);
  gfx_r = COL_TEXT_R; gfx_g = COL_TEXT_G; gfx_b = COL_TEXT_B;
  _pl = #; sprintf(_pl, "x%d", _sp_rep);
  gfx_measurestr(_pl, _tw, _th);
  gfx_x = _rx + floor((_sg_rep_w - _tw)/2); gfx_y = _spy + floor((_sg_row_h - _th)/2);
  gfx_drawstr(_pl);
  (mouse_cap & 1) && !(last_cap & 1) &&
    mouse_x >= _rx && mouse_x < _rx + _sg_rep_w &&
    mouse_y >= _spy && mouse_y < _spy + _sg_row_h ? (
    SONG_PARTS[_spb + 3] = _sp_rep % 16 + 1;
  );
  (mouse_cap & 2) && !(last_cap & 2) &&
    mouse_x >= _rx && mouse_x < _rx + _sg_rep_w &&
    mouse_y >= _spy && mouse_y < _spy + _sg_row_h ? (
    SONG_PARTS[_spb + 3] = (_sp_rep - 2 + 16) % 16 + 1;
  );
  _rx += _sg_rep_w + _sg_col_gap;

  // Mod Key (0=OFF, 1-12=C..B)
  _sp_mkey > 0 ? (gfx_r=0.35; gfx_g=0.20; gfx_b=0.50;) : (gfx_r=0.10; gfx_g=0.10; gfx_b=0.13;);
  gfx_rect(_rx, _spy + 1, _sg_key_w, _sg_row_h - 3);
  _sp_mkey > 0 ? (gfx_r=0.85; gfx_g=0.60; gfx_b=1.0;) : (gfx_r=COL_DIM_R*0.6; gfx_g=COL_DIM_G*0.6; gfx_b=COL_DIM_B*0.6;);
  _sp_mkey == 0 ? (_cs = "--") :
  _sp_mkey == 1 ? (_cs = "C") : _sp_mkey == 2 ? (_cs = "C#") : _sp_mkey == 3 ? (_cs = "D") :
  _sp_mkey == 4 ? (_cs = "Eb") : _sp_mkey == 5 ? (_cs = "E") : _sp_mkey == 6 ? (_cs = "F") :
  _sp_mkey == 7 ? (_cs = "F#") : _sp_mkey == 8 ? (_cs = "G") : _sp_mkey == 9 ? (_cs = "Ab") :
  _sp_mkey == 10 ? (_cs = "A") : _sp_mkey == 11 ? (_cs = "Bb") : (_cs = "B");
  gfx_measurestr(_cs, _tw, _th);
  gfx_x = _rx + floor((_sg_key_w - _tw)/2); gfx_y = _spy + floor((_sg_row_h - _th)/2);
  gfx_drawstr(_cs);
  (mouse_cap & 1) && !(last_cap & 1) &&
    mouse_x >= _rx && mouse_x < _rx + _sg_key_w &&
    mouse_y >= _spy && mouse_y < _spy + _sg_row_h ? (
    SONG_PARTS[_spb + 4] = (_sp_mkey + 1) % 13;
  );
  (mouse_cap & 2) && !(last_cap & 2) &&
    mouse_x >= _rx && mouse_x < _rx + _sg_key_w &&
    mouse_y >= _spy && mouse_y < _spy + _sg_row_h ? (
    SONG_PARTS[_spb + 4] = (_sp_mkey + 12) % 13;
  );
  _rx += _sg_key_w + _sg_col_gap;

  // Mod Mode (0=inherit, 1=MAJ, 2=MIN)
  _sp_mmod == 1 ? (gfx_r=0.15; gfx_g=0.25; gfx_b=0.45;) :
  _sp_mmod == 2 ? (gfx_r=0.35; gfx_g=0.15; gfx_b=0.35;) :
                  (gfx_r=0.10; gfx_g=0.10; gfx_b=0.13;);
  gfx_rect(_rx, _spy + 1, _sg_mode_w, _sg_row_h - 3);
  _sp_mmod == 1 ? (gfx_r=0.50; gfx_g=0.70; gfx_b=1.0; _cs="MAJ") :
  _sp_mmod == 2 ? (gfx_r=0.80; gfx_g=0.50; gfx_b=0.85; _cs="MIN") :
                  (gfx_r=COL_DIM_R*0.6; gfx_g=COL_DIM_G*0.6; gfx_b=COL_DIM_B*0.6; _cs="--");
  gfx_measurestr(_cs, _tw, _th);
  gfx_x = _rx + floor((_sg_mode_w - _tw)/2); gfx_y = _spy + floor((_sg_row_h - _th)/2);
  gfx_drawstr(_cs);
  (mouse_cap & 1) && !(last_cap & 1) &&
    mouse_x >= _rx && mouse_x < _rx + _sg_mode_w &&
    mouse_y >= _spy && mouse_y < _spy + _sg_row_h ? (
    SONG_PARTS[_spb + 5] = (_sp_mmod + 1) % 3;
  );
  _rx += _sg_mode_w + _sg_col_gap;

  // Mod Velocity (0=off, 1-127=target velocity)
  _sp_mvel > 0 ? (
    _sp_mvel <= 50 ? (gfx_r=0.12; gfx_g=0.20; gfx_b=0.30;) :
    _sp_mvel <= 90 ? (gfx_r=0.25; gfx_g=0.20; gfx_b=0.15;) :
                     (gfx_r=0.40; gfx_g=0.15; gfx_b=0.10;);
  ) : (gfx_r=0.10; gfx_g=0.10; gfx_b=0.13;);
  gfx_rect(_rx, _spy + 1, _sg_vel_w, _sg_row_h - 3);
  _sp_mvel > 0 ? (
    gfx_r=0.80; gfx_g=0.70; gfx_b=0.90;
    _cs = #; sprintf(_cs, "%d", _sp_mvel);
  ) : (
    gfx_r=COL_DIM_R*0.6; gfx_g=COL_DIM_G*0.6; gfx_b=COL_DIM_B*0.6; _cs="--";
  );
  gfx_measurestr(_cs, _tw, _th);
  gfx_x = _rx + floor((_sg_vel_w - _tw)/2); gfx_y = _spy + floor((_sg_row_h - _th)/2);
  gfx_drawstr(_cs);
  // Left-click: cycle presets (off → 40 → 80 → 120 → off)
  (mouse_cap & 1) && !(last_cap & 1) &&
    mouse_x >= _rx && mouse_x < _rx + _sg_vel_w &&
    mouse_y >= _spy && mouse_y < _spy + _sg_row_h ? (
    _sp_mvel == 0 ? SONG_PARTS[_spb + 6] = 40 :
    _sp_mvel <= 40 ? SONG_PARTS[_spb + 6] = 80 :
    _sp_mvel <= 80 ? SONG_PARTS[_spb + 6] = 120 :
    SONG_PARTS[_spb + 6] = 0;
  );
  // Right-click-drag: adjust velocity directly (drag up = louder, down = quieter)
  (mouse_cap & 2) && !(last_cap & 2) &&
    mouse_x >= _rx && mouse_x < _rx + _sg_vel_w &&
    mouse_y >= _spy && mouse_y < _spy + _sg_row_h ? (
    svel_drag_part = _spi;
    svel_drag_start_y = mouse_y;
    svel_drag_start_val = _sp_mvel > 0 ? _sp_mvel : 100;
  );
  (mouse_cap & 2) && svel_drag_part == _spi ? (
    _drag_delta = floor((svel_drag_start_y - mouse_y) * 1.5);
    SONG_PARTS[_spb + 6] = max(0, min(127, svel_drag_start_val + _drag_delta));
  );
  _rx += _sg_vel_w + _sg_col_gap;

  // Arp Mode (0=OFF, 1=UP, 2=DOWN, 3=U/D, 4=RND)
  _sp_arp > 0 ? (gfx_r=0.40; gfx_g=0.20; gfx_b=0.50;) : (gfx_r=0.10; gfx_g=0.10; gfx_b=0.13;);
  gfx_rect(_rx, _spy + 1, _sg_arp_w, _sg_row_h - 3);
  _sp_arp == 1 ? (gfx_r=0.80; gfx_g=0.55; gfx_b=1.0; _cs="UP") :
  _sp_arp == 2 ? (gfx_r=0.80; gfx_g=0.55; gfx_b=1.0; _cs="DN") :
  _sp_arp == 3 ? (gfx_r=0.80; gfx_g=0.55; gfx_b=1.0; _cs="U/D") :
  _sp_arp == 4 ? (gfx_r=0.80; gfx_g=0.55; gfx_b=1.0; _cs="RND") :
                 (gfx_r=COL_DIM_R*0.6; gfx_g=COL_DIM_G*0.6; gfx_b=COL_DIM_B*0.6; _cs="--");
  gfx_measurestr(_cs, _tw, _th);
  gfx_x = _rx + floor((_sg_arp_w - _tw)/2); gfx_y = _spy + floor((_sg_row_h - _th)/2);
  gfx_drawstr(_cs);
  (mouse_cap & 1) && !(last_cap & 1) &&
    mouse_x >= _rx && mouse_x < _rx + _sg_arp_w &&
    mouse_y >= _spy && mouse_y < _spy + _sg_row_h ? (
    SONG_PARTS[_spb + 7] = (_sp_arp + 1) % 5;
  );
  (mouse_cap & 2) && !(last_cap & 2) &&
    mouse_x >= _rx && mouse_x < _rx + _sg_arp_w &&
    mouse_y >= _spy && mouse_y < _spy + _sg_row_h ? (
    SONG_PARTS[_spb + 7] = (_sp_arp + 4) % 5;
  );
  _rx += _sg_arp_w + _sg_col_gap;

  // Octave Override (0=inherit, 1=-2, 2=-1, 3=0, 4=+1, 5=+2, 6=+3)
  _sp_oct > 0 ? (gfx_r=0.20; gfx_g=0.35; gfx_b=0.45;) : (gfx_r=0.10; gfx_g=0.10; gfx_b=0.13;);
  gfx_rect(_rx, _spy + 1, _sg_oct_w, _sg_row_h - 3);
  _sp_oct == 0 ? (_cs="--") :
  _sp_oct == 1 ? (_cs="-2") : _sp_oct == 2 ? (_cs="-1") : _sp_oct == 3 ? (_cs="0") :
  _sp_oct == 4 ? (_cs="+1") : _sp_oct == 5 ? (_cs="+2") : (_cs="+3");
  _sp_oct > 0 ? (gfx_r=0.50; gfx_g=0.80; gfx_b=0.95;) : (gfx_r=COL_DIM_R*0.6; gfx_g=COL_DIM_G*0.6; gfx_b=COL_DIM_B*0.6;);
  gfx_measurestr(_cs, _tw, _th);
  gfx_x = _rx + floor((_sg_oct_w - _tw)/2); gfx_y = _spy + floor((_sg_row_h - _th)/2);
  gfx_drawstr(_cs);
  (mouse_cap & 1) && !(last_cap & 1) &&
    mouse_x >= _rx && mouse_x < _rx + _sg_oct_w &&
    mouse_y >= _spy && mouse_y < _spy + _sg_row_h ? (
    SONG_PART_OCT[_spi] = (_sp_oct + 1) % 7;
  );
  (mouse_cap & 2) && !(last_cap & 2) &&
    mouse_x >= _rx && mouse_x < _rx + _sg_oct_w &&
    mouse_y >= _spy && mouse_y < _spy + _sg_row_h ? (
    SONG_PART_OCT[_spi] = (_sp_oct + 6) % 7;
  );

  _spi += 1;
);
// Reset velocity drag when right mouse released
!(mouse_cap & 2) && (last_cap & 2) && svel_drag_part >= 0 ? svel_drag_part = -1;

// [+ Part] [- Part] buttons
_spbtn_y = _sg_y + _sg_hdr_h + song_num_parts * _sg_row_h + floor(4 * S);
_spbtn_w = floor(58 * S); _spbtn_h = floor(20 * S);
_spbtn_x = margin;

// [+ Part]
gfx_r=0.12; gfx_g=0.22; gfx_b=0.12; gfx_a=1; gfx_rect(_spbtn_x, _spbtn_y, _spbtn_w, _spbtn_h);
gfx_r=COL_GREEN_R; gfx_g=COL_GREEN_G; gfx_b=COL_GREEN_B;
gfx_setfont(1, "Arial", F_SMALL);
gfx_measurestr("+ Part", _tw, _th);
gfx_x=_spbtn_x+floor((_spbtn_w-_tw)/2); gfx_y=_spbtn_y+floor((_spbtn_h-_th)/2); gfx_drawstr("+ Part");
(mouse_cap&1) && !(last_cap&1) &&
  mouse_x>=_spbtn_x && mouse_x<_spbtn_x+_spbtn_w &&
  mouse_y>=_spbtn_y && mouse_y<_spbtn_y+_spbtn_h ? (
  song_num_parts < MAX_SONG_PARTS ? (
    _npb = song_num_parts * SONG_PART_SIZE;
    SONG_PARTS[_npb + 0] = 0;   // Verse
    SONG_PARTS[_npb + 1] = 1;   // num 1
    SONG_PARTS[_npb + 2] = 0;   // pattern 0
    SONG_PARTS[_npb + 3] = 1;   // repeat 1
    SONG_PARTS[_npb + 4] = 0;   // no modulation
    SONG_PARTS[_npb + 5] = 0;   // inherit mode
    SONG_PARTS[_npb + 6] = 0;   // normal velocity
    song_num_parts += 1;
  );
);
_spbtn_x += _spbtn_w + floor(4*S);

// [- Part]
gfx_r=0.22; gfx_g=0.10; gfx_b=0.10; gfx_a=1; gfx_rect(_spbtn_x, _spbtn_y, _spbtn_w, _spbtn_h);
gfx_r=COL_ACCENT_R; gfx_g=0.4; gfx_b=0.4;
gfx_measurestr("- Part", _tw, _th);
gfx_x=_spbtn_x+floor((_spbtn_w-_tw)/2); gfx_y=_spbtn_y+floor((_spbtn_h-_th)/2); gfx_drawstr("- Part");
(mouse_cap&1) && !(last_cap&1) &&
  mouse_x>=_spbtn_x && mouse_x<_spbtn_x+_spbtn_w &&
  mouse_y>=_spbtn_y && mouse_y<_spbtn_y+_spbtn_h ? (
  song_num_parts > 1 ? (
    song_num_parts -= 1;
    song_sel_part >= song_num_parts ? song_sel_part = song_num_parts - 1;
    // Remove references from sequence
    _sqi = song_seq_len - 1;
    while(_sqi >= 0) (
      SONG_SEQ[_sqi] >= song_num_parts ? (
        // shift remaining down
        _sj = _sqi;
        loop(song_seq_len - _sqi - 1, SONG_SEQ[_sj] = SONG_SEQ[_sj+1]; _sj += 1);
        song_seq_len -= 1;
      );
      _sqi -= 1;
    );
  );
);

// ---- SONG SEQUENCE STRIP ----
_seq_strip_y = _spbtn_y + _spbtn_h + floor(12 * S);

// Section label
gfx_setfont(1, "Arial", F_LABEL);
gfx_r = COL_SEC_R; gfx_g = COL_SEC_G; gfx_b = COL_SEC_B;
gfx_x = margin; gfx_y = _seq_strip_y;
gfx_drawstr("SONG SEQUENCE");

_seq_strip_y += floor(18 * S);
_seq_block_h = floor(36 * S);
_seq_block_w = floor(72 * S);
_seq_gap = floor(3 * S);
_seq_blocks_per_row = max(1, floor((gfx_w - margin * 2) / (_seq_block_w + _seq_gap)));

// Draw sequence blocks
_sqi = 0;
loop(song_seq_len,
  _sq_row = floor(_sqi / _seq_blocks_per_row);
  _sq_col = _sqi - _sq_row * _seq_blocks_per_row;
  _sqx = margin + _sq_col * (_seq_block_w + _seq_gap);
  _sqy = _seq_strip_y + _sq_row * (_seq_block_h + _seq_gap);

  _sq_part = SONG_SEQ[_sqi];
  _sq_part < song_num_parts ? (
    _sqpb = _sq_part * SONG_PART_SIZE;
    _sqcat = SONG_PARTS[_sqpb + 0];
    _sqpnum = max(1, SONG_PARTS[_sqpb + 1]);

    // Background color by category
    _is_playing_seq = _gfx_transport && _gfx_song_cur_src >= 0 && _sqi == _gfx_song_cur_src;
    _is_playing_seq ? (
      gfx_r = 0.15; gfx_g = 0.55; gfx_b = 0.25;
    ) : (
      _sqcat==0 ? (gfx_r=0.15; gfx_g=0.25; gfx_b=0.40;) :
      _sqcat==1 ? (gfx_r=0.38; gfx_g=0.18; gfx_b=0.15;) :
      _sqcat==2 ? (gfx_r=0.30; gfx_g=0.22; gfx_b=0.38;) :
      _sqcat==3 ? (gfx_r=0.15; gfx_g=0.35; gfx_b=0.18;) :
                  (gfx_r=0.35; gfx_g=0.28; gfx_b=0.10;);
    );
    gfx_a = 1;
    gfx_rect(_sqx, _sqy, _seq_block_w, _seq_block_h);

    // Drag source highlight (amber tint)
    seq_drag_src == _sqi && (mouse_cap & 1) ? (
      gfx_r = COL_ACCENT_R * 0.3; gfx_g = COL_ACCENT_G * 0.15; gfx_b = 0; gfx_a = 0.4;
      gfx_rect(_sqx, _sqy, _seq_block_w, _seq_block_h); gfx_a = 1;
    );
    // Drag destination highlight (green border)
    seq_drag_src >= 0 && seq_drag_src != _sqi && seq_drag_dst == _sqi && (mouse_cap & 1) ? (
      gfx_r = 0.25; gfx_g = 0.85; gfx_b = 0.35; gfx_a = 0.6;
      gfx_rect(_sqx, _sqy, _seq_block_w, 2);
      gfx_rect(_sqx, _sqy + _seq_block_h - 2, _seq_block_w, 2);
      gfx_rect(_sqx, _sqy, 2, _seq_block_h);
      gfx_rect(_sqx + _seq_block_w - 2, _sqy, 2, _seq_block_h);
      gfx_a = 1;
    );

    // Playing highlight top edge
    _is_playing_seq ? (
      gfx_r=0.30; gfx_g=1.0; gfx_b=0.50;
      gfx_rect(_sqx, _sqy, _seq_block_w, max(2, floor(3*S)));
    );

    // Label: "Verse 1" etc
    gfx_setfont(1, "Arial", F_SMALL);
    gfx_r = 1; gfx_g = 1; gfx_b = 1;
    _sqcat==0?(_cs="Vrs"):_sqcat==1?(_cs="Cho"):_sqcat==2?(_cs="Brg"):_sqcat==3?(_cs="Int"):(_cs="Out");
    _pl = #; sprintf(_pl, "%s %d", _cs, _sqpnum);
    gfx_measurestr(_pl, _tw, _th);
    gfx_x = _sqx + floor((_seq_block_w - _tw)/2); gfx_y = _sqy + floor(4*S);
    gfx_drawstr(_pl);

    // Pattern label below
    gfx_setfont(1, "Arial", F_TINY);
    _sqpat = SONG_PARTS[_sqpb + 2];
    pat_set_color(_sqpat);
    _pl = #; sprintf(_pl, "P%d", _sqpat + 1);
    gfx_measurestr(_pl, _tw, _th);
    gfx_x = _sqx + floor((_seq_block_w - _tw)/2); gfx_y = _sqy + floor(18*S);
    gfx_drawstr(_pl);

    // --- Interaction ---
    _in_block = mouse_x >= _sqx && mouse_x < _sqx + _seq_block_w &&
                mouse_y >= _sqy && mouse_y < _sqy + _seq_block_h;

    // Left-click: start drag OR cycle part (resolved on release)
    (mouse_cap & 1) && !(last_cap & 1) && _in_block ? (
      seq_drag_src = _sqi; seq_drag_dst = _sqi;
    );
    // Track drag destination while dragging
    (mouse_cap & 1) && seq_drag_src >= 0 && _in_block ? (
      seq_drag_dst = _sqi;
    );
    // Release: if same position = cycle part, if different = reorder
    !(mouse_cap & 1) && (last_cap & 1) && seq_drag_src >= 0 && _in_block ? (
      seq_drag_src == _sqi && seq_drag_src == seq_drag_dst ? (
        // Click (no drag): cycle part assignment (L-click = next, use scroll for prev)
        SONG_SEQ[_sqi] = (SONG_SEQ[_sqi] + 1) % song_num_parts;
      ) : seq_drag_src != _sqi ? (
        // Drag completed: move seq_drag_src to position _sqi
        _moved_val = SONG_SEQ[seq_drag_src];
        seq_drag_src < _sqi ? (
          // Dragged right: shift left
          _sj = seq_drag_src;
          loop(_sqi - seq_drag_src, SONG_SEQ[_sj] = SONG_SEQ[_sj+1]; _sj += 1);
          SONG_SEQ[_sqi] = _moved_val;
        ) : (
          // Dragged left: shift right
          _sj = seq_drag_src;
          while(_sj > _sqi) ( SONG_SEQ[_sj] = SONG_SEQ[_sj-1]; _sj -= 1; );
          SONG_SEQ[_sqi] = _moved_val;
        );
        seq_drag_src = -1; seq_drag_dst = -1;
      );
    );

    // Right-click to remove from sequence
    (mouse_cap & 2) && !(last_cap & 2) && _in_block ? (
      _sj = _sqi;
      loop(song_seq_len - _sqi - 1, SONG_SEQ[_sj] = SONG_SEQ[_sj+1]; _sj += 1);
      song_seq_len -= 1;
    );
  );

  _sqi += 1;
);
// Reset drag state when mouse released outside any block
!(mouse_cap & 1) && (last_cap & 1) && seq_drag_src >= 0 ? (seq_drag_src = -1; seq_drag_dst = -1;);

// [+ SEQ] button — append selected part to sequence
_seq_add_x = margin + (song_seq_len < _seq_blocks_per_row ? song_seq_len : (song_seq_len % _seq_blocks_per_row)) * (_seq_block_w + _seq_gap);
_seq_add_row = floor(song_seq_len / _seq_blocks_per_row);
_seq_add_y = _seq_strip_y + _seq_add_row * (_seq_block_h + _seq_gap);
gfx_r=0.12; gfx_g=0.22; gfx_b=0.12; gfx_a=1;
gfx_rect(_seq_add_x, _seq_add_y, _seq_block_w, _seq_block_h);
gfx_r=COL_GREEN_R; gfx_g=COL_GREEN_G; gfx_b=COL_GREEN_B;
gfx_setfont(1, "Arial", F_LABEL);
gfx_measurestr("+ SEQ", _tw, _th);
gfx_x = _seq_add_x + floor((_seq_block_w - _tw)/2); gfx_y = _seq_add_y + floor((_seq_block_h - _th)/2);
gfx_drawstr("+ SEQ");
(mouse_cap&1) && !(last_cap&1) &&
  mouse_x >= _seq_add_x && mouse_x < _seq_add_x + _seq_block_w &&
  mouse_y >= _seq_add_y && mouse_y < _seq_add_y + _seq_block_h ? (
  song_seq_len < MAX_SONG_SEQ && song_num_parts > 0 ? (
    SONG_SEQ[song_seq_len] = max(0, min(song_sel_part, song_num_parts - 1));
    song_seq_len += 1;
  );
);

// Status line
gfx_setfont(1, "Arial", F_SMALL);
_ss_y = gfx_h - floor(50 * S);
gfx_x = margin; gfx_y = _ss_y;
gfx_r = COL_DIM_R; gfx_g = COL_DIM_G; gfx_b = COL_DIM_B;
gfx_drawstr("Parts: "); gfx_drawnumber(song_num_parts, 0);
gfx_drawstr("  Seq: "); gfx_drawnumber(song_seq_len, 0);
gfx_drawstr("  |  ");
_gfx_transport ? gfx_drawstr("PLAYING") : gfx_drawstr("STOPPED");
_gfx_song_cur_seq >= 0 && _gfx_transport ? (
  gfx_drawstr("  |  Pos: "); gfx_drawnumber(_gfx_song_cur_seq + 1, 0);
  gfx_drawstr("/"); gfx_drawnumber(song_seq_len, 0);
);

// Hint
gfx_x = margin; gfx_y = _ss_y + floor(14 * S);
_is_player ? gfx_drawstr("Player mode: song structure controlled by conductor.") :
gfx_drawstr("Parts: L/R-click to cycle.  Seq: click=cycle part, drag=reorder, R-click=remove.");

// Restore mouse state after player lockout
_is_player ? (mouse_cap = _save_mcap; last_cap = _save_lcap; mouse_wheel = _save_mwheel;);

) : (
// ============================================================================
//  HARMONY MAP (map mode)
// ============================================================================
// Pre-paint map area
gfx_r = COL_BG_R; gfx_g = COL_BG_G; gfx_b = COL_BG_B; gfx_a = 1;
gfx_rect(0, map_y, gfx_w, gfx_h - map_y);

map_h = gfx_h - map_y - floor(100 * S);
map_cx = gfx_w / 2;
map_cy = map_y + map_h / 2;
r_maj = floor(min(gfx_w * 0.5, map_h * 0.5) * 0.75);  // outer ring: major chords
r_dim = floor(r_maj * 0.83);                             // dim chord ring
r_aug = floor(r_maj * 0.74);                             // aug chord ring
r_min = floor(r_maj * 0.65);                             // inner ring: minor chords
bubble_r = floor(16 * S);
bubble_r_sm = floor(12 * S);  // smaller bubble for dim/aug

// Circle of fifths order (semitones from C): C G D A E B F# Db Ab Eb Bb F
// Index 0-11 maps to position on the circle
// cof_semi[i] = semitone value at position i in the circle of fifths
_eb = max(0, slider7 - 1);
_prev_bar = _eb > 0 ? _eb - 1 : 0;
_has_prev = CHORD_FILLED[_prev_bar];
_prev_root = CHORD_SLOTS[_prev_bar * 2];
_prev_qual = CHORD_SLOTS[_prev_bar * 2 + 1];

// ---- Draw progression path (persistent line connecting assigned chords) ----
gfx_r = COL_ACCENT_R; gfx_g = COL_ACCENT_G; gfx_b = COL_ACCENT_B; gfx_a = 0.8;
_path_prev_x = -1; _path_prev_y = -1;
_path_i = 0;
loop(num_steps,
  CHORD_FILLED[_path_i] ? (
    _pr = CHORD_SLOTS[_path_i * 2];
    _pq = CHORD_SLOTS[_path_i * 2 + 1];
    // Find circle-of-fifths position for this root
    _ppos = 0;
    _pk = 0; loop(12, (_pk * 7) % 12 == _pr ? _ppos = _pk; _pk += 1);
    _pang = -$pi/2 + _ppos * 2 * $pi / 12;
    _pq == 0 ? _prad = r_maj : _pq == 5 ? _prad = r_dim : _pq == 6 ? _prad = r_aug : _prad = r_min;
    _ppx = map_cx + cos(_pang) * _prad;
    _ppy = map_cy + sin(_pang) * _prad;

    // Draw line from previous chord to this one
    _path_prev_x >= 0 ? (
      gfx_line(_path_prev_x, _path_prev_y, _ppx, _ppy);
    );

    // Draw bar number at midpoint
    _path_prev_x >= 0 ? (
      _mx = (_path_prev_x + _ppx) / 2;
      _my = (_path_prev_y + _ppy) / 2;
      gfx_setfont(1, "Arial", F_TINY);
      gfx_r = COL_ACCENT_R; gfx_g = COL_ACCENT_G; gfx_b = COL_ACCENT_B;
      gfx_x = _mx - floor(3 * S); gfx_y = _my - floor(5 * S);
      gfx_drawnumber(_path_i + 1, 0);
    );

    // Draw a dot at each chord position
    gfx_r = COL_ACCENT_R; gfx_g = COL_ACCENT_G; gfx_b = COL_ACCENT_B;
    gfx_circle(_ppx, _ppy, floor(3 * S), 1);

    _path_prev_x = _ppx;
    _path_prev_y = _ppy;
  );
  _path_i += 1;
);
gfx_a = 1;

// Draw all 12 major chords (outer ring) + 12 minor chords (inner ring)
// Fixed positions: circle of fifths
gfx_setfont(1, "Arial", F_CHORD);
ni = 0;
loop(12,
  // Circle of fifths: each step is +7 semitones
  _semi = (ni * 7) % 12;
  _angle = -$pi/2 + ni * 2 * $pi / 12;

  // === MAJOR CHORD (outer ring) ===
  _bx_maj = map_cx + cos(_angle) * r_maj;
  _by_maj = map_cy + sin(_angle) * r_maj;

  // Check if diatonic
  _is_diatonic = 0;
  _di = 0;
  loop(7,
    DIATONIC[_di*3] == _semi && DIATONIC[_di*3+1] == 0 ? _is_diatonic = 1;
    _di += 1;
  );

  // Check if connected from previous chord
  _is_connected = 0;
  _conn_type = 0;
  _has_prev ? (
    _ci = 0;
    loop(conn_count,
      CONN_MAP[_ci*3] == _semi && CONN_MAP[_ci*3+1] == 0 ? (
        _is_connected = 1;
        _conn_type = CONN_MAP[_ci*3+2];
      );
      _ci += 1;
    );
  );

  // Check if this chord is assigned to current edit bar
  _is_current = CHORD_FILLED[_eb] && CHORD_SLOTS[_eb*2] == _semi && CHORD_SLOTS[_eb*2+1] == 0;

  // Connection line from prev chord position to this chord
  _is_connected ? (
    // Find prev chord position
    _prev_semi = _prev_root;
    _prev_pos = 0;
    _pi = 0; loop(12, (_pi * 7) % 12 == _prev_semi ? _prev_pos = _pi; _pi += 1);
    _prev_angle = -$pi/2 + _prev_pos * 2 * $pi / 12;
    _prev_qual == 0 ? _prev_rad = r_maj : _prev_rad = r_min;
    _px = map_cx + cos(_prev_angle) * _prev_rad;
    _py = map_cy + sin(_prev_angle) * _prev_rad;

    _conn_type == 3 ? (gfx_r = 0.9; gfx_g = 0.75; gfx_b = 0.2; gfx_a = 0.7;)
    : _conn_type == 4 ? (gfx_r = 0.9; gfx_g = 0.5; gfx_b = 0.1; gfx_a = 0.7;)
    : _conn_type == 5 ? (gfx_r = 0.6; gfx_g = 0.3; gfx_b = 0.7; gfx_a = 0.5;)
    : _conn_type == 6 ? (gfx_r = 0.3; gfx_g = 0.7; gfx_b = 0.4; gfx_a = 0.5;)
    : (gfx_r = 0.4; gfx_g = 0.4; gfx_b = 0.5; gfx_a = 0.4;);
    gfx_line(_px, _py, _bx_maj, _by_maj);
    gfx_a = 1;
  );

  // Bubble
  _is_current ? (
    gfx_r = COL_ACCENT_R; gfx_g = COL_ACCENT_G; gfx_b = COL_ACCENT_B;
    gfx_circle(_bx_maj, _by_maj, bubble_r + 3, 1);
  );
  _is_diatonic ? (
    gfx_r = 0.90; gfx_g = 0.50; gfx_b = 0.55;
  ) : _is_connected ? (
    gfx_r = 0.70; gfx_g = 0.40; gfx_b = 0.45;
  ) : (
    gfx_r = 0.25; gfx_g = 0.18; gfx_b = 0.20;
  );
  gfx_circle(_bx_maj, _by_maj, bubble_r, 1);

  // Label
  _is_diatonic || _is_connected ? (gfx_r = 1; gfx_g = 1; gfx_b = 1;) : (gfx_r = 0.4; gfx_g = 0.4; gfx_b = 0.4;);
  _semi==0?(_cs="C"):_semi==1?(_cs="C#"):_semi==2?(_cs="D"):_semi==3?(_cs="Eb"):_semi==4?(_cs="E"):_semi==5?(_cs="F"):_semi==6?(_cs="F#"):_semi==7?(_cs="G"):_semi==8?(_cs="Ab"):_semi==9?(_cs="A"):_semi==10?(_cs="Bb"):(_cs="B");
  gfx_measurestr(_cs, _tw, _th);
  gfx_x = _bx_maj - _tw/2; gfx_y = _by_maj - _th/2;
  gfx_drawstr(_cs);

  // Click major chord
  (mouse_cap & 1) && !(last_cap & 1) ? (
    _dx = mouse_x - _bx_maj; _dy = mouse_y - _by_maj;
    (_dx*_dx + _dy*_dy) < (bubble_r+4)*(bubble_r+4) ? (
      CHORD_SLOTS[_eb * 2] = _semi;
      CHORD_SLOTS[_eb * 2 + 1] = 0;
      CHORD_FILLED[_eb] = 1;
      conn_dirty = 1;
      preview_root = _semi; preview_qual = 0; preview_chord_dirty = 1;
    );
  );

  // === MINOR CHORD (inner ring) ===
  _bx_min = map_cx + cos(_angle) * r_min;
  _by_min = map_cy + sin(_angle) * r_min;

  // Check if diatonic minor
  _is_diatonic_m = 0;
  _di = 0;
  loop(7,
    DIATONIC[_di*3] == _semi && DIATONIC[_di*3+1] == 1 ? _is_diatonic_m = 1;
    _di += 1;
  );

  // Check if connected
  _is_connected_m = 0;
  _conn_type_m = 0;
  _has_prev ? (
    _ci = 0;
    loop(conn_count,
      CONN_MAP[_ci*3] == _semi && CONN_MAP[_ci*3+1] == 1 ? (
        _is_connected_m = 1;
        _conn_type_m = CONN_MAP[_ci*3+2];
      );
      _ci += 1;
    );
  );

  _is_current_m = CHORD_FILLED[_eb] && CHORD_SLOTS[_eb*2] == _semi && CHORD_SLOTS[_eb*2+1] == 1;

  // Connection line
  _is_connected_m && _has_prev ? (
    _prev_semi = _prev_root;
    _prev_pos = 0;
    _pi = 0; loop(12, (_pi * 7) % 12 == _prev_semi ? _prev_pos = _pi; _pi += 1);
    _prev_angle = -$pi/2 + _prev_pos * 2 * $pi / 12;
    _prev_qual == 0 ? _prev_rad = r_maj : _prev_rad = r_min;
    _px = map_cx + cos(_prev_angle) * _prev_rad;
    _py = map_cy + sin(_prev_angle) * _prev_rad;
    _conn_type_m == 3 ? (gfx_r = 0.9; gfx_g = 0.75; gfx_b = 0.2; gfx_a = 0.7;)
    : _conn_type_m == 5 ? (gfx_r = 0.6; gfx_g = 0.3; gfx_b = 0.7; gfx_a = 0.5;)
    : _conn_type_m == 6 ? (gfx_r = 0.3; gfx_g = 0.7; gfx_b = 0.4; gfx_a = 0.5;)
    : (gfx_r = 0.4; gfx_g = 0.4; gfx_b = 0.5; gfx_a = 0.4;);
    gfx_line(_px, _py, _bx_min, _by_min);
    gfx_a = 1;
  );

  // Bubble
  _is_current_m ? (
    gfx_r = COL_ACCENT_R; gfx_g = COL_ACCENT_G; gfx_b = COL_ACCENT_B;
    gfx_circle(_bx_min, _by_min, bubble_r + 3, 1);
  );
  _is_diatonic_m ? (
    gfx_r = 0.35; gfx_g = 0.55; gfx_b = 0.85;
  ) : _is_connected_m ? (
    gfx_r = 0.25; gfx_g = 0.40; gfx_b = 0.65;
  ) : (
    gfx_r = 0.12; gfx_g = 0.15; gfx_b = 0.22;
  );
  gfx_circle(_bx_min, _by_min, bubble_r, 1);

  // Label
  _is_diatonic_m || _is_connected_m ? (gfx_r = 1; gfx_g = 1; gfx_b = 1;) : (gfx_r = 0.35; gfx_g = 0.35; gfx_b = 0.4;);
  _semi==0?(_cs="Cm"):_semi==1?(_cs="C#m"):_semi==2?(_cs="Dm"):_semi==3?(_cs="Ebm"):_semi==4?(_cs="Em"):_semi==5?(_cs="Fm"):_semi==6?(_cs="F#m"):_semi==7?(_cs="Gm"):_semi==8?(_cs="Abm"):_semi==9?(_cs="Am"):_semi==10?(_cs="Bbm"):(_cs="Bm");
  gfx_measurestr(_cs, _tw, _th);
  gfx_x = _bx_min - _tw/2; gfx_y = _by_min - _th/2;
  gfx_drawstr(_cs);

  // Click minor chord
  (mouse_cap & 1) && !(last_cap & 1) ? (
    _dx = mouse_x - _bx_min; _dy = mouse_y - _by_min;
    (_dx*_dx + _dy*_dy) < (bubble_r+4)*(bubble_r+4) ? (
      CHORD_SLOTS[_eb * 2] = _semi;
      CHORD_SLOTS[_eb * 2 + 1] = 1;
      CHORD_FILLED[_eb] = 1;
      conn_dirty = 1;
      preview_root = _semi; preview_qual = 1; preview_chord_dirty = 1;
    );
  );

  // === DIM chord (dim ring) — only drawn when connected or current ===
  _bx_dim = map_cx + cos(_angle) * r_dim;
  _by_dim = map_cy + sin(_angle) * r_dim;
  _is_connected_dim = 0; _conn_type_dim = 0;
  _has_prev ? (
    _ci = 0;
    loop(conn_count,
      CONN_MAP[_ci*3] == _semi && CONN_MAP[_ci*3+1] == 5 ? (
        _is_connected_dim = 1; _conn_type_dim = CONN_MAP[_ci*3+2];
      );
      _ci += 1;
    );
  );
  _is_current_dim = CHORD_FILLED[_eb] && CHORD_SLOTS[_eb*2] == _semi && CHORD_SLOTS[_eb*2+1] == 5;
  _is_connected_dim || _is_current_dim ? (
    _is_connected_dim && _has_prev ? (
      _prev_pos = 0; _pi = 0; loop(12, (_pi*7)%12 == _prev_root ? _prev_pos = _pi; _pi += 1);
      _prev_angle = -$pi/2 + _prev_pos * 2 * $pi / 12;
      _prev_qual == 0 ? _prev_rad = r_maj : _prev_qual == 5 ? _prev_rad = r_dim : _prev_qual == 6 ? _prev_rad = r_aug : _prev_rad = r_min;
      _px = map_cx + cos(_prev_angle) * _prev_rad; _py = map_cy + sin(_prev_angle) * _prev_rad;
      gfx_r = 0.6; gfx_g = 0.3; gfx_b = 0.7; gfx_a = 0.6;
      gfx_line(_px, _py, _bx_dim, _by_dim); gfx_a = 1;
    );
    _is_current_dim ? (
      gfx_r = COL_ACCENT_R; gfx_g = COL_ACCENT_G; gfx_b = COL_ACCENT_B;
      gfx_circle(_bx_dim, _by_dim, bubble_r_sm + 3, 1);
    );
    gfx_r = 0.50; gfx_g = 0.25; gfx_b = 0.60;
    gfx_circle(_bx_dim, _by_dim, bubble_r_sm, 1);
    gfx_r = 1; gfx_g = 1; gfx_b = 1;
    gfx_setfont(1, "Arial", F_TINY);
    _semi==0?(_cs="C°"):_semi==1?(_cs="C#°"):_semi==2?(_cs="D°"):_semi==3?(_cs="Eb°"):_semi==4?(_cs="E°"):_semi==5?(_cs="F°"):_semi==6?(_cs="F#°"):_semi==7?(_cs="G°"):_semi==8?(_cs="Ab°"):_semi==9?(_cs="A°"):_semi==10?(_cs="Bb°"):(_cs="B°");
    gfx_measurestr(_cs, _tw, _th); gfx_x = _bx_dim - _tw/2; gfx_y = _by_dim - _th/2;
    gfx_drawstr(_cs);
    (mouse_cap & 1) && !(last_cap & 1) ? (
      _dx = mouse_x - _bx_dim; _dy = mouse_y - _by_dim;
      (_dx*_dx + _dy*_dy) < (bubble_r_sm+4)*(bubble_r_sm+4) ? (
        CHORD_SLOTS[_eb*2] = _semi; CHORD_SLOTS[_eb*2+1] = 5;
        CHORD_FILLED[_eb] = 1; conn_dirty = 1;
        preview_root = _semi; preview_qual = 5; preview_chord_dirty = 1;
      );
    );
  );

  // === AUG chord (aug ring) — only drawn when connected or current ===
  _bx_aug = map_cx + cos(_angle) * r_aug;
  _by_aug = map_cy + sin(_angle) * r_aug;
  _is_connected_aug = 0; _conn_type_aug = 0;
  _has_prev ? (
    _ci = 0;
    loop(conn_count,
      CONN_MAP[_ci*3] == _semi && CONN_MAP[_ci*3+1] == 6 ? (
        _is_connected_aug = 1; _conn_type_aug = CONN_MAP[_ci*3+2];
      );
      _ci += 1;
    );
  );
  _is_current_aug = CHORD_FILLED[_eb] && CHORD_SLOTS[_eb*2] == _semi && CHORD_SLOTS[_eb*2+1] == 6;
  _is_connected_aug || _is_current_aug ? (
    _is_connected_aug && _has_prev ? (
      _prev_pos = 0; _pi = 0; loop(12, (_pi*7)%12 == _prev_root ? _prev_pos = _pi; _pi += 1);
      _prev_angle = -$pi/2 + _prev_pos * 2 * $pi / 12;
      _prev_qual == 0 ? _prev_rad = r_maj : _prev_qual == 5 ? _prev_rad = r_dim : _prev_qual == 6 ? _prev_rad = r_aug : _prev_rad = r_min;
      _px = map_cx + cos(_prev_angle) * _prev_rad; _py = map_cy + sin(_prev_angle) * _prev_rad;
      gfx_r = 0.3; gfx_g = 0.7; gfx_b = 0.4; gfx_a = 0.6;
      gfx_line(_px, _py, _bx_aug, _by_aug); gfx_a = 1;
    );
    _is_current_aug ? (
      gfx_r = COL_ACCENT_R; gfx_g = COL_ACCENT_G; gfx_b = COL_ACCENT_B;
      gfx_circle(_bx_aug, _by_aug, bubble_r_sm + 3, 1);
    );
    gfx_r = 0.20; gfx_g = 0.50; gfx_b = 0.28;
    gfx_circle(_bx_aug, _by_aug, bubble_r_sm, 1);
    gfx_r = 1; gfx_g = 1; gfx_b = 1;
    gfx_setfont(1, "Arial", F_TINY);
    _semi==0?(_cs="C+"):_semi==1?(_cs="C#+"):_semi==2?(_cs="D+"):_semi==3?(_cs="Eb+"):_semi==4?(_cs="E+"):_semi==5?(_cs="F+"):_semi==6?(_cs="F#+"):_semi==7?(_cs="G+"):_semi==8?(_cs="Ab+"):_semi==9?(_cs="A+"):_semi==10?(_cs="Bb+"):(_cs="B+");
    gfx_measurestr(_cs, _tw, _th); gfx_x = _bx_aug - _tw/2; gfx_y = _by_aug - _th/2;
    gfx_drawstr(_cs);
    (mouse_cap & 1) && !(last_cap & 1) ? (
      _dx = mouse_x - _bx_aug; _dy = mouse_y - _by_aug;
      (_dx*_dx + _dy*_dy) < (bubble_r_sm+4)*(bubble_r_sm+4) ? (
        CHORD_SLOTS[_eb*2] = _semi; CHORD_SLOTS[_eb*2+1] = 6;
        CHORD_FILLED[_eb] = 1; conn_dirty = 1;
        preview_root = _semi; preview_qual = 6; preview_chord_dirty = 1;
      );
    );
  );

  ni += 1;
);

// "From" indicator in center
_has_prev ? (
  gfx_setfont(1, "Arial", F_SMALL);
  gfx_r = COL_DIM_R; gfx_g = COL_DIM_G; gfx_b = COL_DIM_B;
  gfx_measurestr("from:", _tw, _th);
  gfx_x = map_cx - _tw/2; gfx_y = map_cy - floor(12 * S);
  gfx_drawstr("from:");
  gfx_r = COL_ACCENT_R; gfx_g = COL_ACCENT_G; gfx_b = COL_ACCENT_B;
  _prev_root==0?(_cs="C"):_prev_root==1?(_cs="C#"):_prev_root==2?(_cs="D"):_prev_root==3?(_cs="Eb"):_prev_root==4?(_cs="E"):_prev_root==5?(_cs="F"):_prev_root==6?(_cs="F#"):_prev_root==7?(_cs="G"):_prev_root==8?(_cs="Ab"):_prev_root==9?(_cs="A"):_prev_root==10?(_cs="Bb"):(_cs="B");
  gfx_measurestr(_cs, _tw, _th);
  _min_w = 0;
  _prev_qual == 1 ? (gfx_measurestr("m", _min_w, _min_h));
  gfx_x = map_cx - (_tw + _min_w)/2; gfx_y = map_cy + floor(2 * S);
  gfx_drawstr(_cs);
  _prev_qual == 1 ? gfx_drawstr("m");
);

// Status line
gfx_setfont(1, "Arial", F_SMALL);
gfx_x = margin; gfx_y = gfx_h - floor(90 * S);
gfx_r = COL_DIM_R; gfx_g = COL_DIM_G; gfx_b = COL_DIM_B;
gfx_drawstr("Step ");
gfx_drawnumber(slider7, 0);
gfx_drawstr("/");
gfx_drawnumber(slider3, 0);
gfx_drawstr("  (");
gfx_drawnumber(total_bars_sum, 0);
gfx_drawstr(" bars)");
gfx_drawstr("  |  ");
_gfx_transport ? gfx_drawstr("PLAYING") : gfx_drawstr("STOPPED");
gfx_drawstr("  |  Connections: ");
gfx_drawnumber(conn_count, 0);

// Controls hint
gfx_x = margin; gfx_y = gfx_h - floor(76 * S);
gfx_drawstr("Click = assign. Del = clear. Scroll top/bot = bars/subdiv. Ctrl+click = toggle tick. [+] = add step.");

// Legend
gfx_setfont(1, "Arial", F_TINY);
_leg_y = gfx_h - floor(62 * S);
_leg_x = margin;
_leg_sw = floor(10 * S);  // swatch width
_leg_sh = floor(6 * S);   // swatch height
_leg_sy = _leg_y + floor(2 * S);
_leg_gap = floor(4 * S);

// Helper: draw swatch + label, advances _leg_x
// Diatonic
gfx_r = 0.4; gfx_g = 0.4; gfx_b = 0.5; gfx_a = 0.7;
gfx_rect(_leg_x, _leg_sy, _leg_sw, _leg_sh); gfx_a = 1;
gfx_r = COL_DIM_R; gfx_g = COL_DIM_G; gfx_b = COL_DIM_B;
gfx_x = _leg_x + _leg_sw + _leg_gap; gfx_y = _leg_y; gfx_drawstr("Diatonic");
gfx_measurestr("Diatonic", _lw, _lh); _leg_x += _leg_sw + _leg_gap + _lw + floor(12 * S);

// Dominant
gfx_r = 0.9; gfx_g = 0.75; gfx_b = 0.2; gfx_a = 0.7;
gfx_rect(_leg_x, _leg_sy, _leg_sw, _leg_sh); gfx_a = 1;
gfx_r = COL_DIM_R; gfx_g = COL_DIM_G; gfx_b = COL_DIM_B;
gfx_x = _leg_x + _leg_sw + _leg_gap; gfx_y = _leg_y; gfx_drawstr("Dominant");
gfx_measurestr("Dominant", _lw, _lh); _leg_x += _leg_sw + _leg_gap + _lw + floor(12 * S);

// Tritone sub
gfx_r = 0.9; gfx_g = 0.5; gfx_b = 0.1; gfx_a = 0.7;
gfx_rect(_leg_x, _leg_sy, _leg_sw, _leg_sh); gfx_a = 1;
gfx_r = COL_DIM_R; gfx_g = COL_DIM_G; gfx_b = COL_DIM_B;
gfx_x = _leg_x + _leg_sw + _leg_gap; gfx_y = _leg_y; gfx_drawstr("Tritone sub");
gfx_measurestr("Tritone sub", _lw, _lh); _leg_x += _leg_sw + _leg_gap + _lw + floor(12 * S);

// Dim bridge
gfx_r = 0.6; gfx_g = 0.3; gfx_b = 0.7; gfx_a = 0.7;
gfx_rect(_leg_x, _leg_sy, _leg_sw, _leg_sh); gfx_a = 1;
gfx_r = COL_DIM_R; gfx_g = COL_DIM_G; gfx_b = COL_DIM_B;
gfx_x = _leg_x + _leg_sw + _leg_gap; gfx_y = _leg_y; gfx_drawstr("Dim bridge");
gfx_measurestr("Dim bridge", _lw, _lh); _leg_x += _leg_sw + _leg_gap + _lw + floor(12 * S);

// Aug bridge
gfx_r = 0.3; gfx_g = 0.7; gfx_b = 0.4; gfx_a = 0.7;
gfx_rect(_leg_x, _leg_sy, _leg_sw, _leg_sh); gfx_a = 1;
gfx_r = COL_DIM_R; gfx_g = COL_DIM_G; gfx_b = COL_DIM_B;
gfx_x = _leg_x + _leg_sw + _leg_gap; gfx_y = _leg_y; gfx_drawstr("Aug bridge");
gfx_measurestr("Aug bridge", _lw, _lh); _leg_x += _leg_sw + _leg_gap + _lw + floor(12 * S);

// Progression path
gfx_r = COL_ACCENT_R; gfx_g = COL_ACCENT_G; gfx_b = COL_ACCENT_B;
gfx_rect(_leg_x, _leg_sy, _leg_sw, _leg_sh);
gfx_r = COL_DIM_R; gfx_g = COL_DIM_G; gfx_b = COL_DIM_B;
gfx_x = _leg_x + _leg_sw + _leg_gap; gfx_y = _leg_y; gfx_drawstr("Path");

); // end song_mode ? (...) : (...)

// Instance Manager
bc_panel_y = bc.lms_bc_gfx(S, last_cap);

last_cap = mouse_cap;

// ============================================================================
//  @SERIALIZE
// ============================================================================
@serialize
file_var(0, bc.bc_following);
file_var(0, bc.bc_my_id);
file_var(0, current_pat);
file_var(0, num_pats);
num_pats < 1 ? num_pats = 1;
current_pat = max(0, min(current_pat, num_pats - 1));
// Sync bank[current_pat] from working copy before bank is written (no-op effect on load)
pat_save(current_pat);
i = 0; loop(8 * PAT_SIZE, file_var(0, PAT_BASE[i]); i += 1);
i = 0;
loop(64,
  file_var(0, CHORD_SLOTS[i]);
  i += 1;
);
i = 0;
loop(32,
  file_var(0, CHORD_FILLED[i]);
  i += 1;
);
i = 0;
loop(32,
  file_var(0, CHORD_BARS[i]);
  i += 1;
);
i = 0;
loop(32,
  file_var(0, CHORD_SUBDIV[i]);
  i += 1;
);
i = 0;
loop(512,
  file_var(0, CHORD_PATTERN[i]);
  i += 1;
);
i = 0;
loop(32,
  file_var(0, CHORD_VEL[i]);
  i += 1;
);
i = 0; loop(32, file_var(0, CHORD_MOD_STEP[i]); i += 1);
i = 0; loop(512, file_var(0, CHORD_MOD_TICK[i]); i += 1);
i = 0; loop(32, file_var(0, CHORD_MOD_SUS[i]); i += 1);
i = 0; loop(32, file_var(0, CHORD_MOD_ADD9[i]); i += 1);
i = 0; loop(32, file_var(0, CHORD_MOD_ADD7[i]); i += 1);
i = 0; loop(32, file_var(0, CHORD_MOD_DOM7[i]); i += 1);
i = 0; loop(32, file_var(0, CHORD_MOD_ADD6[i]); i += 1);
i = 0; loop(32, file_var(0, CHORD_MOD_INV[i]); i += 1);
file_var(0, edit_override);
// Reconcile: after loading working copy, sync bank[current_pat] so it's current
pat_save(current_pat);
file_var(0, arr_mode);  // kept for backward compat — always force off
file_var(0, arr_ncols);
arr_mode = 0;
i = 0; loop(MAX_ARR_COLS * 8, file_var(0, ARR_BASE[i]); i += 1);
// Extra 8 patterns (8-15) — appended for backward compat with old presets
i = 0; loop(8 * PAT_SIZE, file_var(0, (PAT_BASE + 8 * PAT_SIZE)[i]); i += 1);
// Song mode data
file_var(0, song_mode);
file_var(0, song_num_parts);
file_var(0, song_seq_len);
file_var(0, song_sel_part);
i = 0; loop(MAX_SONG_PARTS * SONG_PART_SIZE, file_var(0, SONG_PARTS[i]); i += 1);
i = 0; loop(MAX_SONG_SEQ, file_var(0, SONG_SEQ[i]); i += 1);
// Song part octave overrides (appended for backward compat)
i = 0; loop(MAX_SONG_PARTS, file_var(0, SONG_PART_OCT[i]); i += 1);
// Conductor/Player role
file_var(0, hm_role);
file_var(0, player_seeded);
file_var(0, conductor_seed_gen);
