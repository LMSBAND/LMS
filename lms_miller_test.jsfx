desc:LMS - Miller Cap Test (Single Chain)
//tags: test amp guitar
//author: LMS
import lms_core.jsfx-inc
options:gmem=DrumBanger

slider1:0<-24,24,0.1>Input Level (dB)
slider2:50<0,100,0.1>Gain (%)
slider3:0<0,1,1{Off,On}>Dynamic Miller LP
slider4:0<-24,24,0.1>Output Level (dB)
slider5:50<0,100,1>Input Stage (%)
slider6:50<0,100,1>PSU Sag (%)
slider7:0<0,1,1{Off,On}>Log to Console

@init

function tanh_approx(x) local(e2x) ( x > 10 ? 1 : x < -10 ? -1 : ( e2x = exp(2*x); (e2x-1)/(e2x+1); ); );

function bq_init() ( this.b0=1; this.b1=0; this.b2=0; this.a1=0; this.a2=0; this.x1=0; this.x2=0; this.y1=0; this.y2=0; );

function bq_set_lp(freq, q) local(w0, cs, sn, alpha, a0_inv) ( w0=2*$pi*freq/srate; cs=cos(w0); sn=sin(w0); alpha=sn/(2*q); a0_inv=1/(1+alpha); this.b0=(1-cs)/2*a0_inv; this.b1=(1-cs)*a0_inv; this.b2=(1-cs)/2*a0_inv; this.a1=-2*cs*a0_inv; this.a2=(1-alpha)*a0_inv; );

function bq_set_hp(freq, q) local(w0, cs, sn, alpha, a0_inv) ( w0=2*$pi*freq/srate; cs=cos(w0); sn=sin(w0); alpha=sn/(2*q); a0_inv=1/(1+alpha); this.b0=(1+cs)/2*a0_inv; this.b1=-(1+cs)*a0_inv; this.b2=(1+cs)/2*a0_inv; this.a1=-2*cs*a0_inv; this.a2=(1-alpha)*a0_inv; );

function bq_set_peak(freq, gain_db, q) local(a, w0, alpha, a0_inv) ( a=10^(gain_db/20); w0=2*$pi*freq/srate; alpha=sin(w0)/(2*q); a0_inv=1/(1+alpha/a); this.b0=(1+alpha*a)*a0_inv; this.b1=(-2*cos(w0))*a0_inv; this.b2=(1-alpha*a)*a0_inv; this.a1=this.b1; this.a2=(1-alpha/a)*a0_inv; );

function bq_set_hshelf(freq, gain_db, q) local(a, w0, sn, cs, alpha, a0_inv) ( a=10^(gain_db/40); w0=2*$pi*freq/srate; sn=sin(w0); cs=cos(w0); alpha=sn/(2*q); a0_inv=1/((a+1)-(a-1)*cs+2*sqrt(a)*alpha); this.b0=a*((a+1)+(a-1)*cs+2*sqrt(a)*alpha)*a0_inv; this.b1=-2*a*((a-1)+(a+1)*cs)*a0_inv; this.b2=a*((a+1)+(a-1)*cs-2*sqrt(a)*alpha)*a0_inv; this.a1=2*((a-1)-(a+1)*cs)*a0_inv; this.a2=((a+1)-(a-1)*cs-2*sqrt(a)*alpha)*a0_inv; );

function bq_proc(x) local(o) ( o=this.b0*x + this.b1*this.x1 + this.b2*this.x2 - this.a1*this.y1 - this.a2*this.y2; this.x2=this.x1; this.x1=x; this.y2=this.y1; this.y1=o; o; );

function dc_init() ( this.xp=0; this.yp=0; this.r=1-(20/srate); );
function dc_proc(x) ( this.yp=x-this.xp+this.r*this.yp; this.xp=x; this.yp; );

// === INPUT STAGE MODEL ===
// Models what happens when a guitar pickup hits a 12AX7 grid
function input_stage_init() (
  // Grid leak bias shift (coupling cap charges on peaks, shifts bias)
  this.cap_charge = 0.0;
  this.cap_charge_rate = exp(-1/(srate * 0.0005));  // 0.5ms attack - cap charges fast
  this.cap_drain_rate = exp(-1/(srate * 0.030));     // 30ms drain - RC discharge through grid leak
  // Input loading LP (pickup impedance + miller cap at input = ~4kHz rolloff)
  this.input_lp.bq_init();
  this.input_lp.bq_set_lp(4500, 0.6);
  // Cathode bypass - frequency dependent gain (lows get ~+3dB more than highs)
  this.cathode_shelf.bq_init();
  this.cathode_shelf.bq_set_hshelf(800, -2.5, 0.5);
  // Peak envelope for grid conduction detection
  this.peak_env = 0;
  this.peak_att = exp(-1/(srate * 0.0002));  // 0.2ms - near instant peak grab
  this.peak_rel = exp(-1/(srate * 0.050));    // 50ms release
);

function input_stage_proc(x, intensity) local(loaded, dry, bias_shift, biased, grid_thresh, conducted) (
  // 1. Input loading - pickup sees tube input capacitance
  //    At 0% intensity: bypass filter (dry signal). At 100%: full LP.
  loaded = this.input_lp.bq_proc(x);
  loaded = x + intensity * (loaded - x);

  // 2. Grid leak bias shift - coupling cap charges on positive peaks
  //    intensity scales how much charge accumulates (0.15 * intensity)
  loaded > 0.1 ? (
    this.cap_charge = this.cap_charge_rate * this.cap_charge + (1-this.cap_charge_rate) * loaded * 0.15 * intensity;
  ) : (
    this.cap_charge = this.cap_drain_rate * this.cap_charge;
  );
  bias_shift = this.cap_charge;
  biased = loaded - bias_shift;

  // 3. Soft grid conduction - positive peaks get gently squashed
  //    intensity lowers the threshold (easier to conduct) and increases squash amount
  //    At 0%: threshold=1.0 (basically never conducts). At 100%: threshold=0.15 (very reactive)
  grid_thresh = 1.0 - intensity * 0.85;
  biased > grid_thresh ? (
    conducted = grid_thresh + tanh_approx((biased - grid_thresh) * (1.0 + intensity * 3.0)) * (0.05 + intensity * 0.15);
  ) : (
    conducted = biased;
  );

  // 4. Cathode bypass EQ - lows get slightly more gain than highs
  //    Blend dry/wet based on intensity
  dry = conducted;
  conducted = this.cathode_shelf.bq_proc(conducted);
  conducted = dry + intensity * (conducted - dry);

  // Track peak for logging
  abs(x) > this.peak_env ? (
    this.peak_env = this.peak_att * this.peak_env + (1-this.peak_att) * abs(x);
  ) : (
    this.peak_env = this.peak_rel * this.peak_env + (1-this.peak_rel) * abs(x);
  );

  conducted;
);

// === PSU SAG MODEL ===
// Champ has a tiny rectifier + filter caps. Draw current = voltage drops.
function psu_init() (
  this.voltage = 1.0;          // normalized B+ (1.0 = full rail)
  this.att = exp(-1/(srate * 0.001));   // 1ms droop - fast sag on attack
  this.rel = exp(-1/(srate * 0.080));   // 80ms recovery - caps slowly recharge
  this.droop_amount = 0.0;     // how much we're sagging right now
);

function psu_proc(signal_level, sag_depth) local(draw) (
  // Current draw proportional to signal squared (power = V^2/R)
  draw = signal_level * signal_level;
  // Envelope follow the draw
  draw > this.droop_amount ? (
    this.droop_amount = this.att * this.droop_amount + (1-this.att) * draw;
  ) : (
    this.droop_amount = this.rel * this.droop_amount + (1-this.rel) * draw;
  );
  // Voltage = full rail minus droop, scaled by sag_depth
  // sag_depth 0 = no sag, 1 = full Champ-style sag (up to 25% droop)
  this.voltage = 1.0 - this.droop_amount * 0.25 * sag_depth;
  this.voltage = max(0.6, min(1.0, this.voltage));
  this.voltage;
);

// === 4-BAND HARMONIC DENSITY TRACKER ===
function hd_init() (
  this.f_lo.bq_init(); this.f_lo.bq_set_lp(250,0.7);
  this.f_mid_lo.bq_init(); this.f_mid_lo.bq_set_lp(2000,0.7);
  this.f_mid_hi.bq_init(); this.f_mid_hi.bq_set_hp(250,0.7);
  this.f_hi.bq_init(); this.f_hi.bq_set_hp(2000,0.7);
  this.f_air.bq_init(); this.f_air.bq_set_hp(5000,0.7);
  this.env_lo=0; this.env_mid=0; this.env_hi=0; this.env_air=0; this.env_total=0;
  this.att=exp(-1/(srate*0.002)); this.rel=exp(-1/(srate*0.080));
  this.density=1.0; this.mid_density=0.0; this.hi_density=0.0; this.air_density=0.0;
  this.smooth=exp(-1/(srate*0.030));
);

function hd_proc(x) local(lo, mid, hi, air, abs_lo, abs_mid, abs_hi, abs_air, abs_total, raw, raw_mid, raw_hi, raw_air) (
  lo=this.f_lo.bq_proc(x);
  mid=this.f_mid_hi.bq_proc(this.f_mid_lo.bq_proc(x));
  hi=this.f_hi.bq_proc(x);
  air=this.f_air.bq_proc(x);
  abs_lo=abs(lo); abs_mid=abs(mid); abs_hi=abs(hi); abs_air=abs(air); abs_total=abs(x);
  abs_lo > this.env_lo ? ( this.env_lo=this.att*this.env_lo+(1-this.att)*abs_lo; ) : ( this.env_lo=this.rel*this.env_lo+(1-this.rel)*abs_lo; );
  abs_mid > this.env_mid ? ( this.env_mid=this.att*this.env_mid+(1-this.att)*abs_mid; ) : ( this.env_mid=this.rel*this.env_mid+(1-this.rel)*abs_mid; );
  abs_hi > this.env_hi ? ( this.env_hi=this.att*this.env_hi+(1-this.att)*abs_hi; ) : ( this.env_hi=this.rel*this.env_hi+(1-this.rel)*abs_hi; );
  abs_air > this.env_air ? ( this.env_air=this.att*this.env_air+(1-this.att)*abs_air; ) : ( this.env_air=this.rel*this.env_air+(1-this.rel)*abs_air; );
  abs_total > this.env_total ? ( this.env_total=this.att*this.env_total+(1-this.att)*abs_total; ) : ( this.env_total=this.rel*this.env_total+(1-this.rel)*abs_total; );
  this.env_lo > 0.0001 ? ( raw=this.env_total/this.env_lo; raw=min(2.5,max(1.0,raw)); ) : ( raw=1.0; );
  this.env_total > 0.0001 ? (
    raw_mid=this.env_mid/this.env_total; raw_mid=min(1.0,max(0.0,raw_mid));
    raw_hi=this.env_hi/this.env_total; raw_hi=min(1.0,max(0.0,raw_hi));
    raw_air=this.env_air/this.env_total; raw_air=min(1.0,max(0.0,raw_air));
  ) : ( raw_mid=0.0; raw_hi=0.0; raw_air=0.0; );
  this.density=this.smooth*this.density+(1-this.smooth)*raw;
  this.mid_density=this.smooth*this.mid_density+(1-this.smooth)*raw_mid;
  this.hi_density=this.smooth*this.hi_density+(1-this.smooth)*raw_hi;
  this.air_density=this.smooth*this.air_density+(1-this.smooth)*raw_air;
);

// === INIT INSTANCES ===
psu.psu_init();
inp.input_stage_init();
interstage_lp.bq_init();
interstage_lp.bq_set_lp(8000, 0.6);
air_shelf.bq_init();
air_shelf.bq_set_hshelf(5000, 0.0, 0.7);
dc_out.dc_init();
hd.hd_init();
last_lp_freq = 8000;
last_lp_q = 0.6;
last_air_cut = 0.0;
s2_drive_base = 3.5;
gain = 0;
in_level = 1;
out_level = 1;
miller_on = 0;
input_intensity = 0.5;
sag_depth = 0.5;
log_on = 0;
log_counter = 0;
log_interval = 0;

cab1.bq_init(); cab1.bq_set_hp(100, 0.50);
cab2.bq_init(); cab2.bq_set_peak(700, 2.0, 1.2);
cab3.bq_init(); cab3.bq_set_peak(1600, -3.0, 0.8);
cab4.bq_init(); cab4.bq_set_peak(3000, 4.0, 1.5);
cab5.bq_init(); cab5.bq_set_lp(5500, 0.60);

@slider
in_level = 10 ^ (slider1 / 20);
gain = slider2 / 100;
miller_on = slider3;
out_level = 10 ^ (slider4 / 20);
input_intensity = slider5 / 100;
sag_depth = slider6 / 100;
log_on = slider7;
log_on == 1 ? ( log_interval = (srate * 0.25)|0; log_counter = 0; );

@sample
mono = (spl0 + spl1) * 0.5 * in_level;

// === INPUT STAGE (before any gain staging) ===
input_intensity > 0.0 ? (
  mono = inp.input_stage_proc(mono, input_intensity);
);

s1_in = mono * (1.0 + gain * 5.0);
s1_in >= 0 ? (
  s1_out = tanh_approx(s1_in * 1.1) * 0.85;
) : (
  s1_out = tanh_approx(s1_in * 0.9);
);

miller_on == 1 ? (
  hd.hd_proc(s1_out);
  // Band 1 (low density) -> LP cutoff
  lp_freq = 8000 - (hd.density - 1.0) * 500;
  lp_freq = max(7000, min(8500, lp_freq));
  // Band 3 (hi density) -> LP Q
  lp_q = 0.6 + hd.hi_density * 0.35;
  lp_q = max(0.6, min(0.95, lp_q));
  abs(lp_freq - last_lp_freq) > 30 || abs(lp_q - last_lp_q) > 0.02 ? (
    interstage_lp.bq_set_lp(lp_freq, lp_q);
    last_lp_freq = lp_freq;
    last_lp_q = lp_q;
  );
  // Band 2 (mid density) -> stage 2 drive
  s2_drive = s2_drive_base + hd.mid_density * 1.5;
  // Band 4 (air density) -> high shelf cut after stage 2
  air_cut = -hd.air_density * 3.0;
  air_cut = max(-3.0, min(0.0, air_cut));
  abs(air_cut - last_air_cut) > 0.1 ? (
    air_shelf.bq_set_hshelf(5000, air_cut, 0.7);
    last_air_cut = air_cut;
  );
) : (
  s2_drive = s2_drive_base;
);

s1_filtered = interstage_lp.bq_proc(s1_out);

// PSU sag - track output power, droop the rail voltage
bplus = psu.psu_proc(abs(s1_out), sag_depth);

s2_in = s1_filtered * (1.0 + gain * s2_drive);
s2_in >= 0 ? (
  s2_out = tanh_approx(s2_in * 1.5) * 0.6 * bplus;
) : (
  s2_out = tanh_approx(s2_in * 0.8) * 0.9 * bplus;
);

out = dc_out.dc_proc(s2_out);
miller_on == 1 ? ( out = air_shelf.bq_proc(out); );

out = cab1.bq_proc(out);
out = cab2.bq_proc(out);
out = cab3.bq_proc(out);
out = cab4.bq_proc(out);
out = cab5.bq_proc(out);

out *= out_level;
spl0 = out;
spl1 = out;

// === LOGGING (gmem broadcast - read from any other JSFX or ReaScript) ===
log_on == 1 ? (
  log_counter += 1;
  log_counter >= log_interval ? (
    log_counter = 0;
    // gmem[0..19] = our log data (offset from DrumBagger space)
    gmem[50000] = inp.peak_env;          // input peak level
    gmem[50001] = inp.cap_charge;         // grid bias shift amount
    gmem[50002] = hd.density;             // harmonic density (lo band)
    gmem[50003] = hd.mid_density;         // mid band fraction
    gmem[50004] = hd.hi_density;          // hi band fraction
    gmem[50005] = hd.air_density;         // air band fraction
    gmem[50006] = last_lp_freq;           // current miller LP freq
    gmem[50007] = last_lp_q;              // current miller LP Q
    gmem[50008] = s2_drive;               // current stage 2 drive
    gmem[50009] = last_air_cut;           // current air shelf dB
    gmem[50010] = abs(s1_in);             // stage 1 input level
    gmem[50011] = abs(s1_out);            // stage 1 output level
    gmem[50012] = abs(s2_out);            // stage 2 output level
    gmem[50013] = abs(out);               // final output level
    gmem[50014] = input_intensity;         // input stage intensity 0-1
    gmem[50015] = miller_on;              // miller on/off
    gmem[50016] = psu.voltage;            // current B+ voltage (1.0=full)
    gmem[50017] = sag_depth;              // sag depth setting
  );
);

@gfx 400 220
log_on == 1 ? (
  gfx_set(1,1,1);
  gfx_x=10; gfx_y=10;
  gfx_drawstr("=== MILLER TEST MONITOR ===");
  gfx_x=10; gfx_y=30;
  gfx_drawstr("Input Peak: "); gfx_drawnumber(gmem[50000], 4);
  gfx_drawstr("  Bias Shift: "); gfx_drawnumber(gmem[50001], 4);
  gfx_x=10; gfx_y=50;
  gfx_drawstr("Density Lo: "); gfx_drawnumber(gmem[50002], 3);
  gfx_drawstr("  Mid: "); gfx_drawnumber(gmem[50003], 3);
  gfx_drawstr("  Hi: "); gfx_drawnumber(gmem[50004], 3);
  gfx_drawstr("  Air: "); gfx_drawnumber(gmem[50005], 3);
  gfx_x=10; gfx_y=70;
  gfx_drawstr("Miller LP: "); gfx_drawnumber(gmem[50006], 0);
  gfx_drawstr(" Hz  Q: "); gfx_drawnumber(gmem[50007], 3);
  gfx_x=10; gfx_y=90;
  gfx_drawstr("S2 Drive: "); gfx_drawnumber(gmem[50008], 2);
  gfx_drawstr("  Air Cut: "); gfx_drawnumber(gmem[50009], 1);
  gfx_drawstr(" dB");
  gfx_x=10; gfx_y=120;
  gfx_set(0.5,1,0.5);
  gfx_drawstr("Levels - S1in: "); gfx_drawnumber(gmem[50010], 3);
  gfx_drawstr("  S1out: "); gfx_drawnumber(gmem[50011], 3);
  gfx_drawstr("  S2out: "); gfx_drawnumber(gmem[50012], 3);
  gfx_drawstr("  Final: "); gfx_drawnumber(gmem[50013], 3);
  gfx_x=10; gfx_y=150;
  gfx_set(1,1,0);
  gfx_drawstr("INPUT STAGE: "); gfx_drawnumber(input_intensity * 100, 0); gfx_drawstr("%");
  gfx_drawstr("  ");
  miller_on == 1 ? gfx_drawstr("MILLER: ON") : gfx_drawstr("MILLER: OFF");
  gfx_x=10; gfx_y=170;
  gfx_set(1,0.6,0.3);
  gfx_drawstr("B+ Voltage: "); gfx_drawnumber(gmem[50016] * 100, 1); gfx_drawstr("%");
  gfx_drawstr("  Sag: "); gfx_drawnumber(sag_depth * 100, 0); gfx_drawstr("%");
);
