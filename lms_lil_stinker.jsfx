p[38]=0; p[39]=0; p[40]=2; p[41]=0; p[42]=0;

// Preset 3: Thick Lead — saw+tri, med drive, glide
p = PRESET_DATA + 3 * PRESET_STRIDE;
p[0]=0; p[1]=0; p[2]=0; p[3]=100; p[4]=50;
p[5]=2; p[6]=0; p[7]=7; p[8]=70; p[9]=50;
