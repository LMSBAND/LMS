: slider41 == 68 ? gfx_drawstr("DX ROADS")
: slider41 == 69 ? gfx_drawstr("POLY BRASS")
: slider41 == 70 ? gfx_drawstr("RND BASS")
: slider41 == 71 ? gfx_drawstr("RND LEAD")
: slider41 == 72 ? gfx_drawstr("RND ALL")
: gfx_drawstr("RND FX");

// Preset click — category-filtered browsing
(mouse_cap & 1) && !(last_cap & 1) &&
  mouse_x >= floor(320 * S) && mouse_x < floor(520 * S) &&
  mouse_y >= floor(14 * S) && mouse_y < floor(34 * S) ? (
  browse_cat == 0 ? (
    slider41 = (slider41 + 1) % 74;
  ) : (
    // Find next preset in category
    next_p = slider41;
    found_next = 0;
    scan_i = 0;
    while (scan_i < 74 && !found_next) (
      next_p = (next_p + 1) % 74;
      next_p < 70 ? (
        PRESET_CAT[next_p] == browse_cat ? found_next = 1;
      );
      scan_i += 1;
    );
    found_next ? slider41 = next_p;
  );
);
(mouse_cap & 2) && !(last_cap & 2) &&
  mouse_x >= floor(320 * S) && mouse_x < floor(520 * S) &&
  mouse_y >= floor(14 * S) && mouse_y < floor(34 * S) ? (
  browse_cat == 0 ? (
    slider41 = slider41 - 1;
    slider41 < 0 ? slider41 = 73;
  ) : (
    // Find prev preset in category
    prev_p = slider41;
    found_prev = 0;
    scan_i = 0;
    while (scan_i < 74 && !found_prev) (
      prev_p = prev_p - 1;
      prev_p < 0 ? prev_p = 69;
      PRESET_CAT[prev_p] == browse_cat ? found_prev = 1;
      scan_i += 1;
    );
    found_prev ? slider41 = prev_p;
  );
);

// Note/vel display
gfx_setfont(1, "Arial", F_SMALL);
gfx_x = floor(320 * S); gfx_y = floor(34 * S);
gate ? (
  gfx_r = COL_GREEN_R; gfx_g = COL_GREEN_G; gfx_b = COL_GREEN_B;
  note_num = current_note % 12;
  note_num == 0 ? gfx_drawstr("C")
  : note_num == 1 ? gfx_drawstr("C#")
  : note_num == 2 ? gfx_drawstr("D")
  : note_num == 3 ? gfx_drawstr("D#")
  : note_num == 4 ? gfx_drawstr("E")
  : note_num == 5 ? gfx_drawstr("F")
  : note_num == 6 ? gfx_drawstr("F#")
  : note_num == 7 ? gfx_drawstr("G")
  : note_num == 8 ? gfx_drawstr("G#")
  : note_num == 9 ? gfx_drawstr("A")
  : note_num == 10 ? gfx_drawstr("A#")
  : gfx_drawstr("B");
  gfx_drawnumber(floor(current_note / 12) - 1, 0);
  gfx_drawstr("  vel ");
  gfx_drawnumber(floor(current_vel * 127), 0);
) : (
  gfx_r = COL_DIM_R; gfx_g = COL_DIM_G; gfx_b = COL_DIM_B;
  gfx_drawstr("--");
);

// Envelope meters
env_bar_y = floor(16 * S); env_bar_h = floor(6 * S); env_bar_w = floor(80 * S);
gfx_r = COL_DIM_R; gfx_g = COL_DIM_G; gfx_b = COL_DIM_B;
gfx_setfont(1, "Arial", F_TINY);
gfx_x = gfx_w - floor(280 * S); gfx_y = env_bar_y - floor(2 * S);
gfx_drawstr("AMP");
gfx_r = COL_BAR_BG_R; gfx_g = COL_BAR_BG_G; gfx_b = COL_BAR_BG_B;
gfx_rect(gfx_w - floor(252 * S), env_bar_y, env_bar_w, env_bar_h);
gfx_r = COL_GREEN_R; gfx_g = COL_GREEN_G; gfx_b = COL_GREEN_B;
gfx_rect(gfx_w - floor(252 * S), env_bar_y, amp_env_level * env_bar_w, env_bar_h);

gfx_r = COL_DIM_R; gfx_g = COL_DIM_G; gfx_b = COL_DIM_B;
gfx_x = gfx_w - floor(280 * S); gfx_y = env_bar_y + env_bar_h + floor(6 * S);
gfx_drawstr("FLT");
gfx_r = COL_BAR_BG_R; gfx_g = COL_BAR_BG_G; gfx_b = COL_BAR_BG_B;
gfx_rect(gfx_w - floor(252 * S), env_bar_y + env_bar_h + floor(6 * S), env_bar_w, env_bar_h);
gfx_r = COL_CYAN_R; gfx_g = COL_CYAN_G; gfx_b = COL_CYAN_B;
gfx_rect(gfx_w - floor(252 * S), env_bar_y + env_bar_h + floor(6 * S), filt_env_level * env_bar_w, env_bar_h);

// RANDOMIZE button
rand_btn_x = gfx_w - floor(145 * S); rand_btn_y = floor(10 * S); rand_btn_w = floor(130 * S); rand_btn_h = floor(34 * S);
rand_flash > 0 ? (
  flash_amt = rand_flash / 60;
  gfx_r = COL_GREEN_R * flash_amt; gfx_g = COL_GREEN_G * flash_amt; gfx_b = COL_GREEN_B * flash_amt;
  rand_flash -= 1;
) : (
  gfx_r = COL_ACCENT_R * 0.8; gfx_g = COL_ACCENT_G * 0.5; gfx_b = COL_ACCENT_B * 0.3;
);
gfx_rect(rand_btn_x, rand_btn_y, rand_btn_w, rand_btn_h);
gfx_r = COL_ACCENT_R; gfx_g = COL_ACCENT_G; gfx_b = COL_ACCENT_B;
gfx_rect(rand_btn_x, rand_btn_y, rand_btn_w, 2);
gfx_r = 1; gfx_g = 1; gfx_b = 1;
gfx_setfont(1, "Arial", max(8, floor(14 * S)));
gfx_x = rand_btn_x + floor(14 * S); gfx_y = rand_btn_y + floor(9 * S);
gfx_drawstr("RANDOMIZE!");

(mouse_cap & 1) && !(last_cap & 1) &&
  mouse_x >= rand_btn_x && mouse_x <= rand_btn_x + rand_btn_w &&
  mouse_y >= rand_btn_y && mouse_y <= rand_btn_y + rand_btn_h ? (
    slider43 = 1;
);

// Random Category selector
cat_x = rand_btn_x; cat_y = rand_btn_y + rand_btn_h + floor(4 * S);
gfx_r = COL_DIM_R; gfx_g = COL_DIM_G; gfx_b = COL_DIM_B;
gfx_setfont(1, "Arial", F_TINY);
gfx_x = cat_x; gfx_y = cat_y;
gfx_drawstr("CAT: ");
gfx_r = COL_ACCENT_R; gfx_g = COL_ACCENT_G; gfx_b = COL_ACCENT_B;
slider42 == 0 ? gfx_drawstr("ALL")
: slider42 == 1 ? gfx_drawstr("BASS")
: slider42 == 2 ? gfx_drawstr("LEAD")
: slider42 == 3 ? gfx_drawstr("PAD")
: slider42 == 4 ? gfx_drawstr("KEYS")
: slider42 == 5 ? gfx_drawstr("FX")
: gfx_drawstr("POLY");
(mouse_cap & 1) && !(last_cap & 1) &&
  mouse_x >= cat_x && mouse_x < cat_x + floor(80 * S) &&
  mouse_y >= cat_y && mouse_y < cat_y + floor(14 * S) ? (
  slider42 = (slider42 + 1) % 7;
  browse_cat = slider42;
);
(mouse_cap & 2) && !(last_cap & 2) &&
  mouse_x >= cat_x && mouse_x < cat_x + floor(80 * S) &&
  mouse_y >= cat_y && mouse_y < cat_y + floor(14 * S) ? (
  slider42 = slider42 - 1;
  slider42 < 0 ? slider42 = 6;
  browse_cat = slider42;
);

// ============================================================================
//  ROW 1: OSCILLATORS | FILTER (+ env) | AMP + SCOPE
// ============================================================================
row1_h = floor(210 * S);
pad = floor(8 * S);

// ---- OSCILLATORS ----
osc_x = margin; osc_w = col_w;
draw_panel(osc_x, body_y, osc_w, row1_h, "OSCILLATORS");

cy = body_y + floor(28 * S);
inner_w = osc_w - pad * 2;

// OSC 1
gfx_r = COL_SEC_R; gfx_g = COL_SEC_G; gfx_b = COL_SEC_B;
gfx_setfont(1, "Arial", F_SMALL);
gfx_x = osc_x + pad; gfx_y = cy;
gfx_drawstr("OSC 1");

slider1 = draw_wave_sel(osc_x + pad + floor(50 * S), cy - floor(2 * S), floor(42 * S), floor(22 * S), slider1, 3);
slider4 = draw_bar(osc_x + pad + floor(100 * S), cy, inner_w - floor(100 * S), bar_h, slider4, 0, 100, "LEVEL", 1);
cy += bar_sp + floor(10 * S);

slider2 = draw_bar(osc_x + pad, cy, floor(inner_w/2) - floor(2 * S), bar_h, slider2, -24, 24, "TUNE", 1);
slider3 = draw_bar(osc_x + pad + floor(inner_w/2) + floor(2 * S), cy, floor(inner_w/2) - floor(2 * S), bar_h, slider3, -100, 100, "FINE", 1);
cy += bar_sp;

slider5 = draw_bar(osc_x + pad, cy, inner_w, bar_h, slider5, 0, 100, "PW", 1);
cy += bar_sp + floor(6 * S);

// Divider
gfx_r = COL_BORDER_R; gfx_g = COL_BORDER_G; gfx_b = COL_BORDER_B;
gfx_rect(osc_x + pad, cy - floor(3 * S), inner_w, 1);

// OSC 2
gfx_r = COL_SEC_R; gfx_g = COL_SEC_G; gfx_b = COL_SEC_B;
gfx_setfont(1, "Arial", F_SMALL);
gfx_x = osc_x + pad; gfx_y = cy;
gfx_drawstr("OSC 2");

slider6 = draw_wave_sel(osc_x + pad + floor(50 * S), cy - floor(2 * S), floor(42 * S), floor(22 * S), slider6, 3);
slider9 = draw_bar(osc_x + pad + floor(100 * S), cy, inner_w - floor(100 * S), bar_h, slider9, 0, 100, "LEVEL", 1);
cy += bar_sp + floor(10 * S);

slider7 = draw_bar(osc_x + pad, cy, floor(inner_w/2) - floor(2 * S), bar_h, slider7, -24, 24, "TUNE", 1);
slider8 = draw_bar(osc_x + pad + floor(inner_w/2) + floor(2 * S), cy, floor(inner_w/2) - floor(2 * S), bar_h, slider8, -100, 100, "FINE", 1);
cy += bar_sp;

slider10 = draw_bar(osc_x + pad, cy, inner_w, bar_h, slider10, 0, 100, "PW", 1);

// ---- FILTER ----
flt_x = osc_x + osc_w + gap;
flt_w = col_w;
draw_panel(flt_x, body_y, flt_w, row1_h, "FILTER");

cy = body_y + floor(28 * S);
inner_w = flt_w - pad * 2;

slider15 = draw_bar(flt_x + pad, cy, inner_w, bar_h, slider15, 20, 20000, "CUTOFF", 1);
cy += bar_sp;
slider16 = draw_bar(flt_x + pad, cy, inner_w, bar_h, slider16, 0, 100, "RESONANCE", 1);
cy += bar_sp;
slider17 = draw_bar(flt_x + pad, cy, inner_w, bar_h, slider17, 0, 100, "ENV AMT", 1);
cy += bar_sp;
slider18 = draw_bar(flt_x + pad, cy, inner_w, bar_h, slider18, 0, 100, "KBD TRK", 1);
cy += bar_sp;
slider19 = draw_bar(flt_x + pad, cy, inner_w, bar_h, slider19, 0, 100, "OVERLOAD", 1);
cy += bar_sp + floor(4 * S);

// Filter ADSR divider
gfx_r = COL_BORDER_R; gfx_g = COL_BORDER_G; gfx_b = COL_BORDER_B;
gfx_rect(flt_x + pad, cy - floor(3 * S), inner_w, 1);

gfx_r = COL_SEC_R; gfx_g = COL_SEC_G; gfx_b = COL_SEC_B;
gfx_setfont(1, "Arial", F_TINY);
gfx_x = flt_x + pad; gfx_y = cy;
gfx_drawstr("FILTER ENVELOPE");
cy += floor(16 * S);

slider20 = draw_bar(flt_x + pad, cy, floor(inner_w/2) - floor(2 * S), bar_h, slider20, 0, 2000, "A", 1);
slider21 = draw_bar(flt_x + pad + floor(inner_w/2) + floor(2 * S), cy, floor(inner_w/2) - floor(2 * S), bar_h, slider21, 0, 5000, "D", 1);
cy += bar_sp;
slider22 = draw_bar(flt_x + pad, cy, floor(inner_w/2) - floor(2 * S), bar_h, slider22, 0, 100, "S", 1);
slider23 = draw_bar(flt_x + pad + floor(inner_w/2) + floor(2 * S), cy, floor(inner_w/2) - floor(2 * S), bar_h, slider23, 0, 5000, "R", 1);

// ---- AMP + SCOPE ----
amp_x = flt_x + flt_w + gap;
amp_w = gfx_w - amp_x - margin;
draw_panel(amp_x, body_y, amp_w, row1_h, "AMP / OUTPUT");

cy = body_y + floor(28 * S);
inner_w = amp_w - pad * 2;

slider24 = draw_bar(amp_x + pad, cy, inner_w, bar_h, slider24, 0, 2000, "ATTACK", 1);
cy += bar_sp;
slider25 = draw_bar(amp_x + pad, cy, inner_w, bar_h, slider25, 0, 5000, "DECAY", 1);
cy += bar_sp;
slider26 = draw_bar(amp_x + pad, cy, inner_w, bar_h, slider26, 0, 100, "SUSTAIN", 1);
cy += bar_sp;
slider27 = draw_bar(amp_x + pad, cy, inner_w, bar_h, slider27, 0, 5000, "RELEASE", 1);
cy += bar_sp + floor(6 * S);

// Scope
scope_x = amp_x + pad;
scope_y = cy;
scope_w = inner_w;
scope_h = row1_h - (cy - body_y) - pad;

gfx_r = 0.03; gfx_g = 0.02; gfx_b = 0.01;
gfx_rect(scope_x, scope_y, scope_w, scope_h);
gfx_r = COL_BORDER_R * 0.5; gfx_g = COL_BORDER_G * 0.5; gfx_b = COL_BORDER_B * 0.5;
gfx_rect(scope_x, scope_y, scope_w, 1); gfx_rect(scope_x, scope_y+scope_h-1, scope_w, 1);
gfx_rect(scope_x, scope_y, 1, scope_h); gfx_rect(scope_x+scope_w-1, scope_y, 1, scope_h);

// Center line
gfx_r = 0.12; gfx_g = 0.10; gfx_b = 0.08;
gfx_rect(scope_x + 1, scope_y + floor(scope_h/2), scope_w - 2, 1);

// Waveform
gfx_r = COL_GREEN_R; gfx_g = COL_GREEN_G; gfx_b = COL_GREEN_B; gfx_a = 0.9;
scope_step = SCOPE_SIZE / scope_w;
i = 0;
loop(scope_w,
  idx = floor(i * scope_step);
  idx >= SCOPE_SIZE ? idx = SCOPE_SIZE - 1;
  sv = SCOPE_BUF[(scope_pos + idx) % SCOPE_SIZE];
  sy = scope_y + scope_h * 0.5 - sv * scope_h * 0.4;
  sy = max(scope_y + 1, min(scope_y + scope_h - 2, sy));
  i == 0 ? (
    gfx_x = scope_x + 1; gfx_y = sy;
  ) : (
    gfx_lineto(scope_x + i, sy);
  );
  i += 1;
);
gfx_a = 1;

// ============================================================================
//  ROW 2: SUB | MULTIDRIVE | LFO | PERFORM
// ============================================================================
row2_y = body_y + row1_h + gap;
row2_h = floor(148 * S);
col2_w = floor((gfx_w - margin * 2 - gap * 3) / 4);

// ---- SUB ----
sub_px = margin; sub_pw = col2_w;
draw_panel(sub_px, row2_y, sub_pw, row2_h, "SUB OSC");

cy = row2_y + floor(28 * S);
inner_w = sub_pw - pad * 2;

slider11 = draw_toggle(sub_px + pad, cy, slider11, "SUB OSC");
sub_on = slider11;
cy += floor(22 * S);

slider12 = draw_bar(sub_px + pad, cy, inner_w, bar_h, slider12, 0, 100, "SUB LVL", 1);

// ---- MULTIDRIVE ----
md_px = sub_px + sub_pw + gap;
md_pw = col2_w;
draw_panel(md_px, row2_y, md_pw, row2_h, "MULTIDRIVE");

cy = row2_y + floor(28 * S);
inner_w = md_pw - pad * 2;

// Drive character selector
md_char == 0 ? draw_mode_sel(md_px + pad, cy, "CHAR:", "WARM")
: md_char == 1 ? draw_mode_sel(md_px + pad, cy, "CHAR:", "GRIT")
: draw_mode_sel(md_px + pad, cy, "CHAR:", "GROWL");

(mouse_cap & 1) && !(last_cap & 1) &&
  mouse_x >= md_px + pad && mouse_x <= md_px + pad + floor(140 * S) &&
  mouse_y >= cy && mouse_y <= cy + floor(16 * S) ? (
    slider14 = (slider14 + 1) % 3;
    md_char = slider14;
);
cy += bar_sp;

slider13 = draw_bar(md_px + pad, cy, inner_w, bar_h, slider13, 0, 100, "DRIVE", 1);

// Drive activity indicator
cy += bar_sp + floor(4 * S);
md_amount > 0 ? (
  gfx_r = COL_ACCENT_R * md_amount; gfx_g = COL_ACCENT_G * md_amount * 0.5; gfx_b = 0;
  gfx_circle(md_px + pad + floor(inner_w / 2), cy + floor(4 * S), floor(6 * S), 1);
  gfx_r = COL_ACCENT_R; gfx_g = COL_ACCENT_G; gfx_b = COL_ACCENT_B;
  gfx_circle(md_px + pad + floor(inner_w / 2), cy + floor(4 * S), floor(6 * S), 0);
);

// ---- LFO ----
lfo_px = md_px + md_pw + gap;
lfo_pw = col2_w;
draw_panel(lfo_px, row2_y, lfo_pw, row2_h, "LFO");

cy = row2_y + floor(28 * S);
inner_w = lfo_pw - pad * 2;

// LFO shape
lfo_shape == 0 ? draw_mode_sel(lfo_px + pad, cy, "SHAPE:", "SINE")
: lfo_shape == 1 ? draw_mode_sel(lfo_px + pad, cy, "SHAPE:", "TRI")
: lfo_shape == 2 ? draw_mode_sel(lfo_px + pad, cy, "SHAPE:", "SAW")
: lfo_shape == 3 ? draw_mode_sel(lfo_px + pad, cy, "SHAPE:", "SQR")
: lfo_shape == 4 ? draw_mode_sel(lfo_px + pad, cy, "SHAPE:", "S&H")
: draw_mode_sel(lfo_px + pad, cy, "SHAPE:", "RND");

(mouse_cap & 1) && !(last_cap & 1) &&
  mouse_x >= lfo_px + pad && mouse_x <= lfo_px + pad + floor(140 * S) &&
  mouse_y >= cy && mouse_y <= cy + floor(16 * S) ? (
    slider28 = (slider28 + 1) % 6;
    lfo_shape = slider28;
);
// LFO Sync toggle
slider30 = draw_toggle(lfo_px + pad + inner_w - floor(60 * S), cy, slider30, "SYNC");
lfo_sync = slider30;
cy += bar_sp;

slider29 = draw_bar(lfo_px + pad, cy, inner_w, bar_h, slider29, 0.01, 50, "RATE", 1);
cy += bar_sp;
slider31 = draw_bar(lfo_px + pad, cy, floor(inner_w/2) - floor(2 * S), bar_h, slider31, 0, 100, ">PIT", 1);
slider32 = draw_bar(lfo_px + pad + floor(inner_w/2) + floor(2 * S), cy, floor(inner_w/2) - floor(2 * S), bar_h, slider32, 0, 100, ">FLT", 1);
cy += bar_sp;
slider33 = draw_bar(lfo_px + pad, cy, floor(inner_w/2) - floor(2 * S), bar_h, slider33, 0, 100, ">AMP", 1);
slider34 = draw_bar(lfo_px + pad + floor(inner_w/2) + floor(2 * S), cy, floor(inner_w/2) - floor(2 * S), bar_h, slider34, 0, 100, ">PWM", 1);

// LFO activity indicator
cy += bar_sp + floor(2 * S);
lfo_dot_cx = lfo_px + pad + floor(inner_w / 2);
lfo_dot_x = lfo_dot_cx + lfo_value * floor(inner_w / 2 - floor(6 * S));
gfx_r = COL_BORDER_R; gfx_g = COL_BORDER_G; gfx_b = COL_BORDER_B;
gfx_rect(lfo_px + pad, cy + floor(3 * S), inner_w, 1);
gfx_r = COL_GREEN_R; gfx_g = COL_GREEN_G; gfx_b = COL_GREEN_B;
gfx_circle(lfo_dot_x, cy + floor(3 * S), floor(4 * S), 1);

// ---- PERFORM ----
perf_px = lfo_px + lfo_pw + gap;
perf_pw = gfx_w - perf_px - margin;
draw_panel(perf_px, row2_y, perf_pw, row2_h, "PERFORM");

cy = row2_y + floor(28 * S);
inner_w = perf_pw - pad * 2;

// Voice mode toggle
slider44 = draw_toggle(perf_px + pad, cy, slider44, "POLY");
poly_mode = slider44;
cy += floor(22 * S);

slider36 = draw_toggle(perf_px + pad, cy, slider36, "GLIDE");
glide_on = slider36;
slider35 = draw_bar(perf_px + pad + floor(80 * S), cy, inner_w - floor(80 * S), bar_h, slider35, 0, 1000, "ms", 1);
cy += floor(24 * S);

slider37 = draw_bar(perf_px + pad, cy, inner_w, bar_h, slider37, 0, 100, "VEL > AMP", 1);
cy += bar_sp;
slider38 = draw_bar(perf_px + pad, cy, inner_w, bar_h, slider38, 0, 100, "VEL > FLT", 1);
cy += bar_sp;
slider39 = draw_bar(perf_px + pad, cy, inner_w, bar_h, slider39, -24, 24, "MASTER", 1);

// DrumBanger Pad selector
cy += bar_sp + floor(4 * S);
db_connected ? (
  gfx_r = COL_GREEN_R; gfx_g = COL_GREEN_G; gfx_b = COL_GREEN_B;
) : (
  gfx_r = COL_DIM_R * 0.6; gfx_g = COL_DIM_G * 0.6; gfx_b = COL_DIM_B * 0.6;
);
gfx_circle(perf_px + pad + floor(8 * S), cy + floor(4 * S), floor(4 * S), 1);
gfx_setfont(1, "Arial", F_TINY);
gfx_x = perf_px + pad + floor(18 * S); gfx_y = cy;
gfx_r = COL_DIM_R; gfx_g = COL_DIM_G; gfx_b = COL_DIM_B;
gfx_drawstr("DB: ");
gfx_r = COL_TEXT_R; gfx_g = COL_TEXT_G; gfx_b = COL_TEXT_B;
slider40 == 0 ? gfx_drawstr("MIDI")
: (
  gfx_drawstr("PAD ");
  gfx_drawnumber(slider40, 0);
);
(mouse_cap & 1) && !(last_cap & 1) &&
  mouse_x >= perf_px + pad && mouse_x < perf_px + pad + inner_w &&
  mouse_y >= cy && mouse_y < cy + floor(14 * S) ? (
  slider40 = (slider40 + 1) % 9;
);
(mouse_cap & 2) && !(last_cap & 2) &&
  mouse_x >= perf_px + pad && mouse_x < perf_px + pad + inner_w &&
  mouse_y >= cy && mouse_y < cy + floor(14 * S) ? (
  slider40 = slider40 - 1;
  slider40 < 0 ? slider40 = 8;
);

// ============================================================
// INSTANCE MANAGER PANEL
// ============================================================
bc_rows_per_page = 5;
bc_row_h = floor(14 * S);
bc_bar_h = floor(30 * S);
bc_btn_h = floor(20 * S);
bc_panel_h = bc_panel_expanded ? (bc_bar_h + bc_rows_per_page * bc_row_h + floor(18 * S)) : bc_bar_h;
bc_panel_y = gfx_h - bc_panel_h;

gfx_r = 0.04; gfx_g = 0.03; gfx_b = 0.02;
gfx_rect(0, bc_panel_y, gfx_w, bc_panel_h);
gfx_r = 0.15; gfx_g = 0.12; gfx_b = 0.08;
gfx_rect(0, bc_panel_y, gfx_w, 1);

gfx_setfont(1, "Arial", F_SMALL);
gfx_r = 0.95; gfx_g = 0.55; gfx_b = 0.15;
gfx_x = floor(8 * S); gfx_y = bc_panel_y + floor(8 * S);
bc_my_slot >= 0 ? (
  gfx_drawstr("I");
  gfx_drawnumber(bc_my_slot + 1, 0);
  gfx_drawstr("/");
  gfx_drawnumber(bc_instance_count, 0);
) : (
  gfx_drawstr("--");
);

// Follow status
bc_following > 0 ? (
  gfx_r = 0.2; gfx_g = 0.8; gfx_b = 0.3;
  gfx_drawstr("  Following: I");
  bc_fs = 0;
  loop(BC_MAX_INST,
    fsb = BC_MY_REGION + bc_fs * BC_SLOT_SIZE;
    gmem[fsb + 1] == bc_following ? (
      gfx_drawnumber(bc_fs + 1, 0);
      bc_fs = BC_MAX_INST;
    );
    bc_fs += 1;
  );
) : (
  gfx_r = 0.3; gfx_g = 0.3; gfx_b = 0.4;
  gfx_drawstr("  Following: --");
);

// EXPAND/COLLAPSE button
exp_x = gfx_w - floor(200 * S);
exp_y = bc_panel_y + floor(4 * S);
exp_w = floor(65 * S);
exp_h = floor(20 * S);
gfx_r = 0.12; gfx_g = 0.10; gfx_b = 0.08;
gfx_rect(exp_x, exp_y, exp_w, exp_h);
gfx_r = 0.5; gfx_g = 0.5; gfx_b = 0.6;
gfx_x = exp_x + floor(5 * S); gfx_y = exp_y + floor(4 * S);
bc_panel_expanded ? gfx_drawstr("COLLAPSE") : gfx_drawstr("EXPAND");
(mouse_cap & 1) && !(last_cap & 1) &&
  mouse_x >= exp_x && mouse_x < exp_x + exp_w &&
  mouse_y >= exp_y && mouse_y < exp_y + exp_h ? (
  bc_panel_expanded = !bc_panel_expanded;
  bc_steal_mode = 0;
);

// STEAL button
stl_x = gfx_w - floor(125 * S);
stl_y = bc_panel_y + floor(4 * S);
stl_w = floor(50 * S);
stl_h = floor(20 * S);
bc_steal_mode ? (
  gfx_r = 0.6; gfx_g = 0.2; gfx_b = 0.1;
) : (
  gfx_r = 0.2; gfx_g = 0.1; gfx_b = 0.1;
);
gfx_rect(stl_x, stl_y, stl_w, stl_h);
gfx_r = 0.9; gfx_g = 0.5; gfx_b = 0.2;
gfx_x = stl_x + floor(6 * S); gfx_y = stl_y + floor(4 * S);
gfx_drawstr("STEAL");
(mouse_cap & 1) && !(last_cap & 1) &&
  mouse_x >= stl_x && mouse_x < stl_x + stl_w &&
  mouse_y >= stl_y && mouse_y < stl_y + stl_h ? (
  bc_steal_mode = !bc_steal_mode;
  !bc_panel_expanded ? bc_panel_expanded = 1;
);

// UNFOLLOW button
bc_following > 0 ? (
  unf_x = gfx_w - floor(65 * S);
  unf_y = bc_panel_y + floor(4 * S);
  unf_w = floor(55 * S);
  unf_h = floor(20 * S);
  gfx_r = 0.1; gfx_g = 0.2; gfx_b = 0.1;
  gfx_rect(unf_x, unf_y, unf_w, unf_h);
  gfx_r = 0.5; gfx_g = 0.9; gfx_b = 0.5;
  gfx_x = unf_x + floor(4 * S); gfx_y = unf_y + floor(4 * S);
  gfx_drawstr("UNFLW");
  (mouse_cap & 1) && !(last_cap & 1) &&
    mouse_x >= unf_x && mouse_x < unf_x + unf_w &&
    mouse_y >= unf_y && mouse_y < unf_y + unf_h ? (
    bc_following = 0;
    bc_follow_slot = -1;
  );
);

// Expanded: instance list
bc_panel_expanded ? (
  row_y = bc_panel_y + bc_bar_h;
  row_h = bc_row_h;

  bc_my_page = bc_my_slot >= 0 ? floor(bc_my_slot / bc_rows_per_page) : 0;
  bc_page < 0 ? bc_page = 0;

  bc_active_slots = 0;
  bc_si = 0;
  loop(BC_MAX_INST,
    gmem[BC_MY_REGION + bc_si * BC_SLOT_SIZE + 1] > 0 ? bc_active_slots += 1;
    bc_si += 1;
  );
  bc_total_pages = max(1, ceil(bc_active_slots / bc_rows_per_page));
  bc_page >= bc_total_pages ? bc_page = bc_total_pages - 1;

  // Page nav
  pg_btn_w = floor(18 * S); pg_btn_h = floor(14 * S);
  pg_prev_x = floor(8 * S); pg_prev_y = bc_panel_y + bc_bar_h + bc_rows_per_page * row_h + floor(2 * S);
  bc_total_pages > 1 ? (
    gfx_r = 0.25; gfx_g = 0.25; gfx_b = 0.32;
    gfx_rect(pg_prev_x, pg_prev_y, pg_btn_w, pg_btn_h);
    gfx_r = 0.7; gfx_g = 0.7; gfx_b = 0.8;
    gfx_x = pg_prev_x + floor(4 * S); gfx_y = pg_prev_y + floor(2 * S);
    gfx_drawstr("<");
    (mouse_cap & 1) && !(last_cap & 1) &&
      mouse_x >= pg_prev_x && mouse_x < pg_prev_x + pg_btn_w &&
      mouse_y >= pg_prev_y && mouse_y < pg_prev_y + pg_btn_h ? (
      bc_page > 0 ? bc_page -= 1;
    );

    gfx_r = 0.25; gfx_g = 0.25; gfx_b = 0.32;
    gfx_rect(pg_prev_x + pg_btn_w + floor(2 * S), pg_prev_y, pg_btn_w, pg_btn_h);
    gfx_r = 0.7; gfx_g = 0.7; gfx_b = 0.8;
    gfx_x = pg_prev_x + pg_btn_w + floor(6 * S); gfx_y = pg_prev_y + floor(2 * S);
    gfx_drawstr(">");
    (mouse_cap & 1) && !(last_cap & 1) &&
      mouse_x >= pg_prev_x + pg_btn_w + floor(2 * S) && mouse_x < pg_prev_x + pg_btn_w * 2 + floor(2 * S) &&
      mouse_y >= pg_prev_y && mouse_y < pg_prev_y + pg_btn_h ? (
      bc_page < bc_total_pages - 1 ? bc_page += 1;
    );

    gfx_r = 0.4; gfx_g = 0.4; gfx_b = 0.5;
    gfx_x = pg_prev_x + pg_btn_w * 2 + floor(8 * S); gfx_y = pg_prev_y + floor(2 * S);
    gfx_drawnumber(bc_page + 1, 0);
    gfx_drawstr("/");
    gfx_drawnumber(bc_total_pages, 0);

    bc_page != bc_my_page ? (
      you_x = pg_prev_x + pg_btn_w * 2 + floor(40 * S);
      gfx_r = 0.15; gfx_g = 0.15; gfx_b = 0.20;
      gfx_rect(you_x, pg_prev_y, floor(30 * S), pg_btn_h);
      gfx_r = 0.95; gfx_g = 0.55; gfx_b = 0.15;
      gfx_x = you_x + floor(3 * S); gfx_y = pg_prev_y + floor(2 * S);
      gfx_drawstr("YOU");
      (mouse_cap & 1) && !(last_cap & 1) &&
        mouse_x >= you_x && mouse_x < you_x + floor(30 * S) &&
        mouse_y >= pg_prev_y && mouse_y < pg_prev_y + pg_btn_h ? (
        bc_page = bc_my_page;
      );
    );
  );

  // Draw rows
  bc_page_start = bc_page * bc_rows_per_page;
  bc_page_end = bc_page_start + bc_rows_per_page - 1;
  bc_visible = 0;
  bc_s = 0;
  loop(BC_MAX_INST,
    isb = BC_MY_REGION + bc_s * BC_SLOT_SIZE;
    isid = gmem[isb + 1];

    isid > 0 ? (
      bc_visible >= bc_page_start && bc_visible <= bc_page_end ? (
        draw_row_y = row_y + (bc_visible - bc_page_start) * row_h;

        mouse_y >= draw_row_y && mouse_y < draw_row_y + row_h &&
          mouse_x >= floor(8 * S) && mouse_x < gfx_w - floor(8 * S) &&
            bc_s != bc_my_slot ? (
          gfx_r = 0.10; gfx_g = 0.08; gfx_b = 0.06;
          gfx_rect(floor(4 * S), draw_row_y, gfx_w - floor(8 * S), row_h);
        );

        gfx_setfont(1, "Arial", F_TINY);
        bc_s == bc_my_slot ? (
          gfx_r = 0.95; gfx_g = 0.55; gfx_b = 0.15;
        ) : (
          gfx_r = 0.7; gfx_g = 0.7; gfx_b = 0.8;
        );
        gfx_x = floor(12 * S); gfx_y = draw_row_y + floor(1 * S);
        gfx_drawstr("I");
        gfx_drawnumber(bc_s + 1, 0);
        gfx_drawstr("  ");

        bc_s == bc_my_slot ? (
          gfx_drawstr("[YOU]");
        ) : (
          iwho = gmem[isb + 3];
          bc_has_follower = 0;
          bc_fsc = 0;
          loop(BC_MAX_INST,
            fsb2 = BC_MY_REGION + bc_fsc * BC_SLOT_SIZE;
            gmem[fsb2 + 1] > 0 && gmem[fsb2 + 3] == isid ? bc_has_follower = 1;
            bc_fsc += 1;
          );
          iwho > 0 ? (
            gfx_r = 0.4; gfx_g = 0.6; gfx_b = 0.9;
            gfx_drawstr("[FOLLOWER]");
          ) : bc_has_follower ? (
            gfx_r = 0.95; gfx_g = 0.78; gfx_b = 0.35;
            gfx_drawstr("[LEADER]");
          ) : (
            gfx_r = 0.38; gfx_g = 0.38; gfx_b = 0.45;
            gfx_drawstr("[UNASSIGNED]");
          );
          gfx_r = 0.35; gfx_g = 0.45; gfx_b = 0.35;
          bc_steal_mode ? (
            gfx_drawstr("  click: steal");
          ) : (
            gfx_drawstr("  click: follow");
          );
          (mouse_cap & 1) && !(last_cap & 1) &&
            mouse_y >= draw_row_y && mouse_y < draw_row_y + row_h &&
            mouse_x >= floor(8 * S) && mouse_x < gfx_w - floor(8 * S) ? (
            bc_steal_mode ? (
              bc_steal_target = isid;
              bc_steal_pending = 1;
              bc_steal_mode = 0;
            ) : (
              bc_can_follow = 1;
              bc_cursor = isid;
              bc_hops = 0;
              while(bc_cursor > 0 && bc_hops < BC_MAX_INST) (
                bc_cursor == bc_my_id ? (
                  bc_can_follow = 0;
                  bc_cursor = 0;
                ) : (
                  bc_next = 0;
                  bc_cs = 0;
                  loop(BC_MAX_INST,
                    csb = BC_MY_REGION + bc_cs * BC_SLOT_SIZE;
                    gmem[csb + 1] == bc_cursor ? (
                      bc_next = gmem[csb + 3];
                      bc_cs = BC_MAX_INST;
                    );
                    bc_cs += 1;
                  );
                  bc_cursor = bc_next;
                );
                bc_hops += 1;
              );
              bc_can_follow ? (
                bc_following = isid;
              );
            );
          );
        );
      );
      bc_visible += 1;
    );
    bc_s += 1;
  );
);

// Store mouse state
last_cap = mouse_cap;

@serialize
file_var(0, bc_following);
