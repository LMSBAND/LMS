desc:LMS Lil Stinker
//tags: synthesizer instrument analog
//author: LMS
filename:0,shakebot_logo.png

import lms_core.jsfx-inc

options:gmem=DrumBanger
options:maxmem=33554432

// ============================================================================
//  LMS LIL STINKER — Mono/Poly analog synth with Multidrive & ladder filter
//  Phatty-inspired: PolyBLEP oscillators, pre-filter Multidrive,
//  LP24 ladder, kbd tracking, filter overload, presets, DrumBanger
//  Switchable 8-voice polyphony with per-voice filters & envelopes
// ============================================================================

// ---------- OSC 1 ----------
slider1:0<0,3,1{Saw,Square,Triangle,Pulse}>-OSC 1 Wave
slider2:0<-24,24,1>-OSC 1 Tune (semi)
slider3:0<-100,100,1>-OSC 1 Fine (cents)
slider4:100<0,100,1>-OSC 1 Level
slider5:50<0,100,1>-OSC 1 Pulse Width (%)

// ---------- OSC 2 ----------
slider6:0<0,3,1{Saw,Square,Triangle,Pulse}>-OSC 2 Wave
slider7:0<-24,24,1>-OSC 2 Tune (semi)
slider8:7<-100,100,1>-OSC 2 Fine (cents)
slider9:80<0,100,1>-OSC 2 Level
slider10:50<0,100,1>-OSC 2 Pulse Width (%)

// ---------- SUB ----------
slider11:1<0,1,1{Off,On}>-Sub Osc
slider12:60<0,100,1>-Sub Level

// ---------- MULTIDRIVE ----------
slider13:0<0,100,1>-Multidrive Amount
slider14:0<0,2,1{Warm,Grit,Growl}>-Multidrive Character

// ---------- FILTER ----------
slider15:800<20,20000,1>-Filter Cutoff (Hz)
slider16:0<0,100,1>-Filter Resonance
slider17:50<0,100,1>-Filter Env Amount
slider18:0<0,100,1>-Filter Kbd Track (%)
slider19:0<0,100,1>-Filter Overload

// ---------- FILTER ENVELOPE ----------
slider20:5<0,2000,1>-Filter Attack (ms)
slider21:200<0,5000,1>-Filter Decay (ms)
slider22:30<0,100,1>-Filter Sustain
slider23:200<0,5000,1>-Filter Release (ms)

// ---------- AMP ENVELOPE ----------
slider24:2<0,2000,1>-Amp Attack (ms)
slider25:200<0,5000,1>-Amp Decay (ms)
slider26:70<0,100,1>-Amp Sustain
slider27:300<0,5000,1>-Amp Release (ms)

// ---------- LFO ----------
slider28:0<0,5,1{Sine,Triangle,Saw,Square,S&H,Random}>-LFO Shape
slider29:3.0<0.01,50,0.01>-LFO Rate (Hz)
slider30:0<0,1,1{Free,Sync}>-LFO Sync
slider31:0<0,100,1>-LFO > Pitch
slider32:0<0,100,1>-LFO > Filter
slider33:0<0,100,1>-LFO > Amp
slider34:0<0,100,1>-LFO > PWM

// ---------- PERFORMANCE ----------
slider35:0<0,1000,1>-Glide Time (ms)
slider36:0<0,1,1{Off,On}>-Glide
slider37:100<0,100,1>-Velocity > Amp
slider38:0<0,100,1>-Velocity > Filter

// ---------- MASTER ----------
slider39:0<-24,24,0.1>-Master Volume (dB)
slider40:0<0,8,1{MIDI Only,Pad 1,Pad 2,Pad 3,Pad 4,Pad 5,Pad 6,Pad 7,Pad 8}>-DrumBanger Pad
slider41:0<0,73,1{INIT,Fat Bass,Acid Squelch,Thick Lead,Sub Bass,Pluck,Bark,Brass Stab,Wobble,Deep Dub,Funky Clav,Reese Bass,PWM Sweep,Vintage Keys,Warm Pad,Squelch Bass,Growl Lead,Bright Lead,Synth Brass,Tremble,808 Bass,Slap Bass,Moog Bass,Rubber Bass,Dirty Bass,Funk Bass,Acid House,Organ Bass,Buzz Bass,Tape Bass,Screamer,Smooth Lead,Sync Lead,Portamento,Nasty Lead,Octave Lead,Vox Lead,Chip Lead,Whistle,Power Lead,Lush Pad,Glass Pad,Dark Pad,Shimmer,Choir,Ethereal,Analog Strings,Horror Pad,EP Clean,Harpsichord,Marimba,Steel Drum,Music Box,Vibes,Celeste,Laser Zap,Siren,Bubbles,Wind,Sci-Fi,Alarm,Thunder,Glitch,Poly Saw,Poly Keys,Juno Strings,Prophet,OB Strings,DX Roads,Poly Brass,Rnd Bass,Rnd Lead,Rnd All,Rnd FX}>-Preset
slider42:0<0,6,1{All,Bass,Lead,Pad,Keys,FX,Poly}>-Preset Category
slider43:0<0,1,1{-,RANDOMIZE!}>-Randomize!
slider44:0<0,1,1{Mono,Poly 8}>-Voice Mode

in_pin:none
out_pin:Left
out_pin:Right

@init
// ============================================================================
//  MEMORY LAYOUT
// ============================================================================

// Oscillator phases — single voice per osc + sub (mono mode)
MEM_OSC1_PHASE = 0;
MEM_OSC2_PHASE = 1;
MEM_SUB_PHASE  = 2;
MEM_NOISE_SEED = 3;

// Moog ladder filter state — 4 stages (mono mode)
MEM_LADDER = 10;  // 10..13

// Triangle oscillator integrators (mono mode)
MEM_TRI1_INT = 20;
MEM_TRI2_INT = 21;

// ---- Poly voice state ----
MAX_VOICES = 8;
VOICE_BASE = 300;
VOICE_STRIDE = 21;
// Per voice layout at VOICE_BASE + v * VOICE_STRIDE:
//  [0] osc1_phase  [1] osc2_phase  [2] sub_phase
//  [3] tri1_int    [4] tri2_int
//  [5..8] ladder stages 0-3
//  [9] amp_env_stage  [10] amp_env_level
//  [11] filt_env_stage  [12] filt_env_level
//  [13] gate  [14] note  [15] vel
//  [16] glide_freq  [17] target_freq
//  [18] age  [19] smooth_cutoff  [20] smooth_vel

// Init all voice state to zero
memset(VOICE_BASE, 0, MAX_VOICES * VOICE_STRIDE);
voice_age_counter = 0;

// Anti-click smoothing for retrigger
smooth_cutoff_m = 2000;  // mono mode smooth cutoff
smooth_vel_m = 0;        // mono mode smooth velocity

// Envelope states
amp_env_stage = 0;
amp_env_level = 0;
filt_env_stage = 0;
filt_env_level = 0;

// LFO
lfo_phase = 0;
lfo_value = 0;
lfo_sh_value = 0;
lfo_sh_prev = 0;
lfo_rand_target = 0;
lfo_rand_current = 0;

// Glide
glide_freq = 440;
target_freq = 440;
current_note = 60;
current_vel = 0;
note_on_flag = 0;
gate = 0;

// Mono voice tracking
notes_held = 0;
note_stack_base = 200;
note_stack_size = 0;

// DC blocker state
dc_l_x1 = 0; dc_l_y1 = 0;
dc_r_x1 = 0; dc_r_y1 = 0;

// Noise seed
MEM_NOISE_SEED[0] = 12345;

// Init oscillator phases
MEM_OSC1_PHASE[0] = rand();
MEM_OSC2_PHASE[0] = rand();
MEM_TRI1_INT[0] = 0;
MEM_TRI2_INT[0] = 0;
MEM_SUB_PHASE[0] = 0;

// Init ladder filter
i = 0;
loop(4,
  MEM_LADDER[i] = 0;
  i += 1;
);

// Init Multidrive saturation (3 characters, each needs own state)
sat_md.lms_sat_da_init();

// ============================================================================
//  SCOPE BUFFER
// ============================================================================
SCOPE_BUF = 1000;
SCOPE_SIZE = 1024;
scope_pos = 0;
memset(SCOPE_BUF, 0, SCOPE_SIZE);

// ============================================================================
//  PRESET DATA — 12 presets (INIT + 9 factory + 2 random triggers)
// ============================================================================
PRESET_DATA = SCOPE_BUF + SCOPE_SIZE + 100;
// Each preset = 43 values (slider1..slider43)
PRESET_COUNT = 70;
PRESET_STRIDE = 43;

// Preset 0: INIT — clean saw, open filter
p = PRESET_DATA + 0 * PRESET_STRIDE;
// s1-s5: OSC1
p[0]=0; p[1]=0; p[2]=0; p[3]=100; p[4]=50;
// s6-s10: OSC2
p[5]=0; p[6]=0; p[7]=7; p[8]=80; p[9]=50;
// s11-s12: SUB
p[10]=1; p[11]=60;
// s13-s14: MULTIDRIVE
p[12]=0; p[13]=0;
// s15-s19: FILTER
p[14]=2000; p[15]=0; p[16]=50; p[17]=0; p[18]=0;
// s20-s23: FILTER ADSR
p[19]=5; p[20]=200; p[21]=30; p[22]=200;
// s24-s27: AMP ADSR
p[23]=2; p[24]=200; p[25]=70; p[26]=300;
// s28-s34: LFO
p[27]=0; p[28]=3; p[29]=0; p[30]=0; p[31]=0; p[32]=0; p[33]=0;
// s35-s38: PERFORM
p[34]=0; p[35]=0; p[36]=100; p[37]=0;
// s39-s43: MASTER
p[38]=0; p[39]=0; p[40]=0; p[41]=0; p[42]=0;

// Preset 1: Fat Bass — saw+sq, low cutoff, high env, sub on
p = PRESET_DATA + 1 * PRESET_STRIDE;
p[0]=0; p[1]=-12; p[2]=0; p[3]=100; p[4]=50;
p[5]=1; p[6]=-12; p[7]=5; p[8]=90; p[9]=50;
p[10]=1; p[11]=80;
p[12]=20; p[13]=0;
p[14]=200; p[15]=30; p[16]=80; p[17]=0; p[18]=0;
p[19]=5; p[20]=300; p[21]=10; p[22]=200;
p[23]=2; p[24]=150; p[25]=80; p[26]=200;
p[27]=0; p[28]=3; p[29]=0; p[30]=0; p[31]=0; p[32]=0; p[33]=0;
p[34]=0; p[35]=0; p[36]=100; p[37]=30;
p[38]=0; p[39]=0; p[40]=1; p[41]=0; p[42]=0;

// Preset 2: Acid Squelch — saw, high res, env mod, grit drive
p = PRESET_DATA + 2 * PRESET_STRIDE;
p[0]=0; p[1]=0; p[2]=0; p[3]=100; p[4]=50;
p[5]=0; p[6]=0; p[7]=10; p[8]=60; p[9]=50;
